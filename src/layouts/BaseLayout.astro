---
import '../styles/global.css';
import FloatingUi from '../components/ui/FloatingUi.astro';
import MobileBottomCallBar from '../components/ui/MobileBottomCallBar.astro';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  noindex?: boolean;
  ogImage?: string;
}

const {
  title = 'Безрамное остекление в Санкт-Петербурге | Террасы, веранды, беседки — Raluma',
  description = 'Проектирование, изготовление и монтаж безрамного остекления для террас, веранд, беседок, балконов и коммерческих объектов в Санкт-Петербурге и Ленинградской области.',
  canonical = 'https://raluma.com.ru/',
  noindex = false,
  ogImage = '/images/hero/hero.jpg',
} = Astro.props;

const ogImageAbsolute = ogImage.startsWith('http') ? ogImage : `https://raluma.com.ru${ogImage}`;
const isHomePage = Astro.url.pathname === '/';
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#111111" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="canonical" href={canonical} />

    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/images/logo/raluma-logo-1.png" />
    <link rel="apple-touch-icon" href="/images/logo/raluma-logo-1.png" />
    {isHomePage && (
      <link rel="preload" as="image" href="/images/hero/hero.webp" type="image/webp" fetchpriority="high" />
    )}

    <!-- OpenGraph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Raluma" />
    <meta property="og:locale" content="ru_RU" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />

    <!-- Yandex.Metrika counter -->
    <script is:inline type="text/javascript">
      (function(m,e,t,r,i,k,a){
        m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
        m[i].l=1*new Date();
        for(var j=0;j<document.scripts.length;j++){if(document.scripts[j].src===r){return;}}
        k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)
      })(window,document,'script','https://mc.yandex.ru/metrika/tag.js','ym');

      ym(108496902,'init',{
        webvisor: true,
        clickmap: true,
        trackLinks: true,
        accurateTrackBounce: true
      });
    </script>
    <!-- /Yandex.Metrika counter -->

    <!-- Safe goal helper — always available before any inline scripts -->
    <script is:inline>
      window.safeReachGoal = function(id) {
        try { if (typeof ym === 'function') ym(108496902, 'reachGoal', id); } catch(_) {}
      };
    </script>
  </head>
  <body>
    <noscript>
      <div>
        <img src="https://mc.yandex.ru/watch/108496902" style="position:absolute; left:-9999px;" alt="" />
      </div>
    </noscript>

    <slot />
    <MobileBottomCallBar />
    <FloatingUi />

    <!-- Conversion event wiring: phone clicks, CTA clicks, form start, scroll to form -->
    <script is:inline>
      (function() {
        // Phone clicks are split by placement so the ad account can tell which
        // touchpoint earns calls. data-goal on the link names the placement;
        // anything unlabelled still reports the generic goal.
        document.addEventListener('click', function(e) {
          var phoneLink = e.target.closest('a[href^="tel:"]');
          if (!phoneLink) return;
          window.safeReachGoal(phoneLink.dataset.goal || 'phone_click');
          window.safeReachGoal('phone_click');
        });

        // CTA → lead form (hero, selection-cta, cases, why-raluma sections)
        document.addEventListener('click', function(e) {
          if (!e.target.closest('a[href="#lead-form"]')) return;
          window.safeReachGoal('cta_click');
          window.safeReachGoal('cta_calculate_click');
        });

        // Form start — first input interaction, once per page session
        document.addEventListener('DOMContentLoaded', function() {
          var formStartFired = false;
          var form = document.getElementById('lead-form-element');
          if (form) {
            form.addEventListener('focusin', function() {
              if (!formStartFired) {
                formStartFired = true;
                window.safeReachGoal('form_start');
                window.safeReachGoal('lead_form_start');
              }
            }, { passive: true });

            var fileInput = document.getElementById('lead-files-input');
            if (fileInput) {
              fileInput.addEventListener('change', function() {
                if (fileInput.files && fileInput.files.length) window.safeReachGoal('file_upload');
              }, { passive: true });
            }
          }

          // System selection (Слайд / Книжка / Лифт)
          document.addEventListener('click', function(e) {
            if (e.target.closest('[data-system-tab], .systems-selector__item')) {
              window.safeReachGoal('system_select');
            }
          });

          // Cases section viewed
          var casesSection = document.getElementById('cases');
          if (casesSection && typeof IntersectionObserver !== 'undefined') {
            var casesFired = false;
            var casesObserver = new IntersectionObserver(function(entries) {
              entries.forEach(function(entry) {
                if (entry.isIntersecting && !casesFired) {
                  casesFired = true;
                  window.safeReachGoal('cases_view');
                  casesObserver.disconnect();
                }
              });
            }, { threshold: 0.2 });
            casesObserver.observe(casesSection);
          }

          // Scroll to lead form — fires once when section becomes visible
          var leadSection = document.getElementById('lead-form');
          if (leadSection && typeof IntersectionObserver !== 'undefined') {
            var scrollFired = false;
            var observer = new IntersectionObserver(function(entries) {
              entries.forEach(function(entry) {
                if (entry.isIntersecting && !scrollFired) {
                  scrollFired = true;
                  window.safeReachGoal('scroll_to_lead_form');
                  observer.disconnect();
                }
              });
            }, { threshold: 0.2 });
            observer.observe(leadSection);
          }
        }, { once: true });
      })();
    </script>
  </body>
</html>
