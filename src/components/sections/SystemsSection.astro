---
const systems = [
  {
    id: 'slide',
    name: 'Слайд',
    short: 'Для широких проёмов',
    selectorText: 'Панорама для широких проёмов.',
    image: '/images/systems/slide/cover.webp',
    schema: '/images/systems/slide/slide-schema.webp',
    schemaAlt: 'Схема вариантов открывания системы Слайд',
    description:
      'Панорамная система для широких проёмов.',
    bullets: [
      'Максимум света и панорамного обзора',
      'Для террас, веранд и беседок',
      'Плавное открывание створок'
    ],
    schemaCaption:
      'Конфигурация подбирается под ширину проёма и способ открывания.',
    cta: 'Получить расчёт'
  },
  {
    id: 'book',
    name: 'Книжка',
    short: 'Компактное складывание',
    selectorText: 'Панели складываются к краю.',
    image: '/images/systems/book/cover.webp',
    schema: '/images/systems/book/Knizhka-schema.webp',
    schemaAlt: 'Схема вариантов открывания системы Книжка',
    description:
      'Панели складываются к одной стороне и освобождают проём.',
    bullets: [
      'Почти полностью освобождает проём',
      'Для активного сезонного использования',
      'Удобный выход во двор или на террасу'
    ],
    schemaCaption:
      'Панели последовательно складываются и уходят в сторону.',
    cta: 'Получить расчёт'
  },
  {
    id: 'lift',
    name: 'Лифт',
    short: 'Больше защиты и комфорта',
    selectorText: 'Более защищённый контур.',
    image: '/images/systems/lift/cover.webp',
    schema: '/images/systems/lift/Lift-schema.webp',
    schemaAlt: 'Схема открывания системы Лифт',
    description:
      'Система с более защищённым контуром и двумя вариантами исполнения.',
    bullets: [
      'Более собранный и защищённый контур',
      'Для зон с ветром и осадками',
      'Комфортное ежедневное использование'
    ],
    schemaCaption:
      'Варианты отличаются уровнем защиты и герметичности.',
    variants: [
      {
        id: 'standard',
        name: 'Стандарт',
        badge: 'Для сезонного использования',
        image: '/images/systems/lift/cover.webp',
        description:
          'Базовое исполнение для комфортного сезонного использования.',
        bullets: [
          'Защита от ветра и осадков',
          'Для террас и веранд',
          'Рациональный выбор по бюджету'
        ],
        cta: 'Получить расчёт'
      },
      {
        id: 'warm',
        name: 'Тёплый',
        badge: 'Для повышенного комфорта',
        image: '/images/systems/warm-lift/cover.webp',
        description:
          'Исполнение с повышенной герметичностью и защитой.',
        bullets: [
          'Более высокий уровень комфорта',
          'Для прохладной и переменчивой погоды',
          'Более защищённый контур'
        ],
        cta: 'Получить расчёт'
      }
    ]
  }
];

const initialSystem = systems[0];
const systemsJson = JSON.stringify(systems);
---

<section class="systems-section seams seams--deep" id="systems" aria-labelledby="systems-title">
  <div class="systems-section__container">
    <div class="systems-section__intro">
      <p class="systems-section__eyebrow">Подбор системы</p>
      <h2 class="systems-section__title" id="systems-title">
        Три системы для разных задач
      </h2>
      <p class="systems-section__lead">
        Сравните открывание, защиту и схему панелей.
      </p>
    </div>

    <div class="systems-selector-shell">
      <div class="systems-selector" role="tablist" aria-label="Типы систем">
        {systems.map((system, index) => (
          <button
            class={`systems-selector__item ${index === 0 ? 'is-active' : ''}`}
            type="button"
            role="tab"
            aria-selected={index === 0 ? 'true' : 'false'}
            aria-controls="systems-detail-panel"
            data-system-tab={system.id}
          >
            <span class="systems-selector__active-mark" aria-hidden="true"></span>

            <span class="systems-selector__thumb">
              {/* 84px thumb, so it loads a 84px-worth file rather than the cover. */}
              <img
                src={system.image.replace(/\.webp$/i, '-thumb.webp')}
                alt={`Система ${system.name}`}
                loading="lazy"
                decoding="async"
                width="110"
                height="84"
              />
            </span>

            <span class="systems-selector__content">
              <span class="systems-selector__name-row">
                <span class="systems-selector__name">{system.name}</span>
                <span class="systems-selector__selected-badge">Выбрано</span>
              </span>
              <span class="systems-selector__short">{system.short}</span>
              <span class="systems-selector__text">{system.selectorText}</span>
            </span>
          </button>
        ))}
      </div>

      <p class="systems-selector__mobile-hint" aria-hidden="true">
        <span class="systems-selector__hint-group systems-selector__hint-group--left">
          <i></i><i></i>
        </span>
        <span class="systems-selector__mobile-hint-text">Листайте системы</span>
        <span class="systems-selector__hint-group systems-selector__hint-group--right">
          <i></i><i></i>
        </span>
      </p>
    </div>

    <div class="systems-detail" id="systems-detail-panel">
      <article class="systems-detail__media">
        <div class="systems-detail__photo-frame">
          <img
            id="system-photo"
            src={initialSystem.image}
            alt={`Фото системы ${initialSystem.name}`}
            loading="lazy"
            fetchpriority="low"
          />
        </div>

        <div class="systems-detail__text">
          <div class="systems-detail__title-row">
            <div>
              <p class="systems-detail__label">Система</p>
              <h3 class="systems-detail__name" id="system-name">{initialSystem.name}</h3>
            </div>

            <span class="systems-detail__badge" id="system-badge">{initialSystem.short}</span>
          </div>

          <p class="systems-detail__description" id="system-description">
            {initialSystem.description}
          </p>

          <div class="systems-detail__variants" id="lift-variants" hidden>
            <p class="systems-detail__variants-label">Исполнение системы Лифт</p>

            <div class="systems-detail__variant-switch" role="tablist" aria-label="Варианты системы Лифт">
              <button
                class="systems-detail__variant-btn is-active"
                type="button"
                role="tab"
                aria-selected="true"
                data-variant-tab="standard"
              >
                <span>Стандарт</span>
                <small>Для сезонного использования</small>
              </button>

              <button
                class="systems-detail__variant-btn"
                type="button"
                role="tab"
                aria-selected="false"
                data-variant-tab="warm"
              >
                <span>Тёплый</span>
                <small>Для повышенного комфорта</small>
              </button>
            </div>
          </div>

          <ul class="systems-detail__bullets" id="system-bullets">
            {initialSystem.bullets.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      </article>

      <article class="systems-detail__schema-panel">
        <div class="systems-detail__schema-main">
          <div class="systems-detail__schema-head">
            <div>
              <p class="systems-detail__label">Схема открывания</p>
              <h3 class="systems-detail__schema-title">Варианты перемещения панелей</h3>
            </div>

            <button class="systems-detail__zoom" type="button" id="schema-zoom-button">
              Увеличить
            </button>
          </div>

          <button
            class="systems-detail__schema-frame"
            type="button"
            id="schema-open-button"
            aria-label="Открыть схему крупно"
          >
            <img
              id="system-schema"
              src={initialSystem.schema}
              alt={initialSystem.schemaAlt}
              loading="lazy"
            />
          </button>

          <p class="systems-detail__schema-caption" id="system-schema-caption">
            {initialSystem.schemaCaption}
          </p>

          <p class="systems-detail__schema-hint">Нажмите на схему, чтобы открыть её крупно.</p>
        </div>

        <div class="systems-detail__schema-actions">
          <a class="systems-detail__cta" href="#lead-form" id="system-cta">
            {initialSystem.cta}
          </a>

          <p class="systems-detail__hint">
            Конфигурация подбирается под ваш проём.
          </p>
        </div>
      </article>
    </div>
  </div>

  <dialog class="systems-lightbox" id="systems-schema-dialog" aria-label="Увеличенная схема открывания">
    <div class="systems-lightbox__inner">
      <button class="systems-lightbox__close" type="button" id="schema-close-button" aria-label="Закрыть">
        ×
      </button>
      <img id="lightbox-schema" src={initialSystem.schema} alt={initialSystem.schemaAlt} loading="lazy" decoding="async" />
      <p class="systems-lightbox__caption" id="lightbox-schema-caption">{initialSystem.schemaCaption}</p>
    </div>
  </dialog>
</section>

<script define:vars={{ systemsJson }}>
  const systems = JSON.parse(systemsJson);

  const section = document.querySelector('.systems-section');

  if (section) {
    const tabButtons = Array.from(section.querySelectorAll('[data-system-tab]'));
    const variantWrap = section.querySelector('#lift-variants');
    const variantButtons = Array.from(section.querySelectorAll('[data-variant-tab]'));
    const selectorEl = section.querySelector('.systems-selector');
    const detailEl = section.querySelector('.systems-detail');
    const hintArr = section.querySelector('.systems-selector__hint-arr');

    const photo = section.querySelector('#system-photo');
    const nameEl = section.querySelector('#system-name');
    const badgeEl = section.querySelector('#system-badge');
    const descriptionEl = section.querySelector('#system-description');
    const bulletsEl = section.querySelector('#system-bullets');
    const ctaEl = section.querySelector('#system-cta');
    const schemaEl = section.querySelector('#system-schema');
    const schemaCaptionEl = section.querySelector('#system-schema-caption');

    const openButton = section.querySelector('#schema-open-button');
    const zoomButton = section.querySelector('#schema-zoom-button');
    const dialog = section.querySelector('#systems-schema-dialog');
    const closeButton = section.querySelector('#schema-close-button');
    const lightboxSchema = section.querySelector('#lightbox-schema');
    const lightboxCaption = section.querySelector('#lightbox-schema-caption');

    let activeSystemId = systems[0]?.id ?? 'slide';
    let activeLiftVariantId = 'standard';
    let renderRequest = 0;
    const mediaCache = new Map();

    function loadMedia(src) {
      if (mediaCache.has(src)) return mediaCache.get(src);

      const request = new Promise((resolve, reject) => {
        const image = new Image();
        image.decoding = 'async';
        image.onload = () => {
          if (typeof image.decode === 'function') {
            image.decode().catch(() => {}).finally(() => resolve(src));
          } else {
            resolve(src);
          }
        };
        image.onerror = reject;
        image.src = src;
      });

      mediaCache.set(src, request);
      request.catch(() => mediaCache.delete(src));
      return request;
    }

    function renderBullets(items = []) {
      bulletsEl.innerHTML = '';
      items.forEach((item) => {
        const li = document.createElement('li');
        li.textContent = item;
        bulletsEl.appendChild(li);
      });
    }

    function setVariantButtons(activeId) {
      variantButtons.forEach((button) => {
        const isActive = button.dataset.variantTab === activeId;
        button.classList.toggle('is-active', isActive);
        button.setAttribute('aria-selected', String(isActive));
      });
    }

    function setSystemButtons(activeId) {
      tabButtons.forEach((button) => {
        const isActive = button.dataset.systemTab === activeId;
        button.classList.toggle('is-active', isActive);
        button.setAttribute('aria-selected', String(isActive));
      });
    }

    function updateHint() {
      return;
    }

    function getSystemIndexById(id) {
      return systems.findIndex((item) => item.id === id);
    }

    function scrollActiveTabIntoView() {
      const activeBtn = tabButtons.find((btn) => btn.dataset.systemTab === activeSystemId);
      if (!activeBtn) return;
      activeBtn.scrollIntoView({
        behavior: window.matchMedia('(prefers-reduced-motion: reduce)').matches ? 'auto' : 'smooth',
        block: 'nearest',
        inline: 'center'
      });
    }

    function changeSystemByStep(step) {
      const currentIndex = getSystemIndexById(activeSystemId);
      if (currentIndex === -1 || systems.length === 0) return;

      const nextIndex = (currentIndex + step + systems.length) % systems.length;
      const nextId = systems[nextIndex]?.id;

      if (nextId) {
        activate(nextId);
      }
    }

    function getActivePayload() {
      const system = systems.find((item) => item.id === activeSystemId) ?? systems[0];

      if (system.id === 'lift' && Array.isArray(system.variants)) {
        const variant =
          system.variants.find((item) => item.id === activeLiftVariantId) ?? system.variants[0];
        return {
          system,
          name: system.name,
          // The badge stays system-level: a variant badge here contradicted the
          // selector card the visitor just clicked. Variants carry their own
          // badge inside the variant switch.
          badge: system.short,
          description: variant.description,
          bullets: variant.bullets,
          image: variant.image || system.image,
          cta: variant.cta || 'Получить расчёт ' + system.name,
          schema: system.schema,
          schemaAlt: system.schemaAlt,
          schemaCaption: system.schemaCaption
        };
      }

      return {
        system,
        name: system.name,
        badge: system.short,
        description: system.description,
        bullets: system.bullets,
        image: system.image,
        cta: system.cta || 'Получить расчёт ' + system.name,
        schema: system.schema,
        schemaAlt: system.schemaAlt,
        schemaCaption: system.schemaCaption
      };
    }

    async function renderSystem() {
      const payload = getActivePayload();
      const request = ++renderRequest;

      nameEl.textContent = payload.name;
      badgeEl.textContent = payload.badge;
      descriptionEl.textContent = payload.description;
      renderBullets(payload.bullets);
      ctaEl.textContent = payload.cta;
      schemaCaptionEl.textContent = payload.schemaCaption;
      lightboxCaption.textContent = payload.schemaCaption;
      variantWrap.hidden = payload.system.id !== 'lift';

      detailEl?.classList.add('is-loading');
      detailEl?.setAttribute('aria-busy', 'true');

      try {
        await Promise.all([loadMedia(payload.image), loadMedia(payload.schema)]);
        if (request !== renderRequest) return;

        photo.classList.add('is-changing');
        schemaEl.classList.add('is-changing');
        await new Promise((resolve) => window.setTimeout(resolve, 80));
        if (request !== renderRequest) return;

        photo.src = payload.image;
        photo.alt = 'Фото системы ' + payload.name;
        schemaEl.src = payload.schema;
        schemaEl.alt = payload.schemaAlt;
        lightboxSchema.src = payload.schema;
        lightboxSchema.alt = payload.schemaAlt;

        await Promise.all([
          typeof photo.decode === 'function' ? photo.decode().catch(() => {}) : Promise.resolve(),
          typeof schemaEl.decode === 'function' ? schemaEl.decode().catch(() => {}) : Promise.resolve(),
        ]);

        window.requestAnimationFrame(() => {
          photo.classList.remove('is-changing');
          schemaEl.classList.remove('is-changing');
        });
      } catch (error) {
        console.warn('Не удалось загрузить изображение системы', error);
      } finally {
        if (request === renderRequest) {
          detailEl?.classList.remove('is-loading');
          detailEl?.removeAttribute('aria-busy');
        }
      }
    }

    function activate(id) {
      if (id === activeSystemId) return;
      activeSystemId = id;
      if (activeSystemId !== 'lift') {
        activeLiftVariantId = 'standard';
        setVariantButtons(activeLiftVariantId);
      }
      setSystemButtons(activeSystemId);
      renderSystem();
      updateHint();
      scrollActiveTabIntoView();
    }

    // клик по карточке
    tabButtons.forEach((button) => {
      button.addEventListener('click', () => activate(button.dataset.systemTab));
    });

    // клик по варианту Лифта
    variantButtons.forEach((button) => {
      button.addEventListener('click', () => {
        activeLiftVariantId = button.dataset.variantTab;
        setVariantButtons(activeLiftVariantId);
        renderSystem();
      });
    });

    // авто-выбор при горизонтальном скролле
    if (selectorEl) {
      let scrollTimer;
      selectorEl.addEventListener('scroll', () => {
        clearTimeout(scrollTimer);
        scrollTimer = setTimeout(() => {
          const center = selectorEl.scrollLeft + selectorEl.offsetWidth / 2;
          let closest = null;
          let minDist = Infinity;
          tabButtons.forEach((btn) => {
            const d = Math.abs((btn.offsetLeft + btn.offsetWidth / 2) - center);
            if (d < minDist) { minDist = d; closest = btn; }
          });
          if (closest) activate(closest.dataset.systemTab);
        }, 80);
      }, { passive: true });
    }

    // swipe по открытой карточке системы
    if (detailEl) {
      let touchStartX = 0;
      let touchStartY = 0;
      let lastDx = 0;
      let touchStarted = false;
      let isHorizontalSwipe = false;

      function resetSwipeShift() {
        detailEl.classList.remove('is-swiping');
        detailEl.style.removeProperty('--swipe-shift');
      }

      detailEl.addEventListener('touchstart', (event) => {
        if (event.touches.length !== 1) return;
        if (!window.matchMedia('(max-width: 1120px)').matches) return;

        touchStarted = true;
        isHorizontalSwipe = false;
        lastDx = 0;
        touchStartX = event.touches[0].clientX;
        touchStartY = event.touches[0].clientY;
        detailEl.classList.add('is-swiping');
        detailEl.style.setProperty('--swipe-shift', '0px');
      }, { passive: true });

      detailEl.addEventListener('touchmove', (event) => {
        if (!touchStarted || event.touches.length !== 1) return;
        if (!window.matchMedia('(max-width: 1120px)').matches) return;

        const dx = event.touches[0].clientX - touchStartX;
        const dy = event.touches[0].clientY - touchStartY;
        lastDx = dx;

        if (!isHorizontalSwipe) {
          if (Math.abs(dx) < 10) return;
          if (Math.abs(dx) <= Math.abs(dy) * 1.05) return;
          isHorizontalSwipe = true;
        }

        const limitedDx = Math.max(-26, Math.min(26, dx * 0.18));
        detailEl.style.setProperty('--swipe-shift', `${limitedDx}px`);
      }, { passive: true });

      detailEl.addEventListener('touchend', (event) => {
        if (!touchStarted) return;
        touchStarted = false;

        if (!window.matchMedia('(max-width: 1120px)').matches) {
          resetSwipeShift();
          return;
        }

        const dx = event.changedTouches.length === 1
          ? event.changedTouches[0].clientX - touchStartX
          : lastDx;

        const dy = event.changedTouches.length === 1
          ? event.changedTouches[0].clientY - touchStartY
          : 0;

        resetSwipeShift();

        if (Math.abs(dx) < 48) return;
        if (Math.abs(dx) < Math.abs(dy) * 1.2) return;

        if (dx < 0) {
          changeSystemByStep(1);
        } else {
          changeSystemByStep(-1);
        }
      }, { passive: true });

      detailEl.addEventListener('touchcancel', () => {
        touchStarted = false;
        isHorizontalSwipe = false;
        resetSwipeShift();
      }, { passive: true });
    }

    // диалог схемы
    function openDialog() {
      if (dialog && typeof dialog.showModal === 'function') dialog.showModal();
    }
    function closeDialog() {
      if (dialog?.open) dialog.close();
    }

    openButton?.addEventListener('click', openDialog);
    zoomButton?.addEventListener('click', openDialog);
    closeButton?.addEventListener('click', closeDialog);
    dialog?.addEventListener('click', (e) => { if (e.target === dialog) closeDialog(); });

    if (typeof IntersectionObserver === 'function') {
      const preloadObserver = new IntersectionObserver((entries) => {
        if (!entries.some((entry) => entry.isIntersecting)) return;
        const warmMedia = () => {
          systems.forEach((system) => {
            loadMedia(system.image).catch(() => {});
            loadMedia(system.schema).catch(() => {});
            system.variants?.forEach((variant) => loadMedia(variant.image).catch(() => {}));
          });
        };
        if (typeof window.requestIdleCallback === 'function') {
          window.requestIdleCallback(warmMedia, { timeout: 1200 });
        } else {
          window.setTimeout(warmMedia, 160);
        }
        preloadObserver.disconnect();
      }, { rootMargin: '240px 0px' });
      preloadObserver.observe(section);
    }

    // инициализация
    setSystemButtons(activeSystemId);
    setVariantButtons(activeLiftVariantId);
    updateHint();
  }
</script>

<style>
  .systems-section {
    /* overflow: clip on either axis makes this the scroll container and kills
       position: sticky inside; clipping only the x axis keeps both. */
    overflow-x: clip;
    overflow-y: visible;
    background:
      radial-gradient(circle at top left, rgba(47, 109, 95, 0.13), transparent 30%),
      linear-gradient(180deg, #141414 0%, #0f0f0f 100%);
    color: #ffffff;
  }

  .systems-section__container {
    max-width: 1280px;
    margin: 0 auto;
    padding: clamp(72px, 8vw, 128px) 24px;
  }

  .systems-section__intro {
    max-width: 1100px;
    margin: 0 auto 30px;
    text-align: center;
  }

  .systems-section__eyebrow {
  font-family: var(--f-mono);
  font-weight: 400;
  letter-spacing: 0.12em;
    margin: 0 0 14px;
    font-size: 12px;
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #2f6d5f;
  }

  .systems-section__title {
  font-family: var(--f-display);
  font-weight: 300;
    margin: 0 auto;
    max-width: none;
    width: min(100%, 18ch);
    font-size: clamp(42px, 4.9vw, 64px);
    line-height: 0.95;
    letter-spacing: -0.05em;
    font-weight: 500;
    text-wrap: balance;
  }

  .systems-section__title-break {
    display: block;
  }

  .systems-section__lead {
    margin: 20px auto 0;
    max-width: 760px;
    font-size: clamp(17px, 1.45vw, 20px);
    line-height: 1.68;
    color: rgba(255, 255, 255, 0.7);
    text-wrap: balance;
  }

  .systems-selector-shell {
    position: relative;
    min-width: 0;
  }

  .systems-selector {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
    color: #191d1c;
  }

  .systems-selector__item {
    position: relative;
    display: grid;
    grid-template-columns: 84px minmax(0, 1fr);
    gap: 12px;
    align-items: center;
    padding: 14px 14px 14px 16px;
    border: 1px solid rgba(17, 17, 17, 0.08);
    border-radius: 2px;
    background: rgba(255, 255, 255, 0.78);
    box-shadow:
      0 1px 0 rgba(17, 17, 17, 0.04),
      0 10px 24px rgba(17, 17, 17, 0.04);
    text-align: left;
    cursor: pointer;
    transition:
      transform 0.25s ease,
