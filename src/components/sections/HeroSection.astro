---
import '../../styles/sections/hero.css';
---

<section class="hero">
  <div class="hero__bg" aria-hidden="true"></div>
  <div class="hero__overlay" aria-hidden="true"></div>

  <div class="container hero__container">
    <div class="hero__content">
      <div class="hero__brand" aria-hidden="true">
        <img
          class="hero__brand-logo"
          src="/images/logo/raluma-logo-1.png"
          alt=""
          loading="eager"
          decoding="async"
        />
      </div>


      <h1 class="hero__title">
        Безрамное остекление
        <br />
        в Санкт-Петербурге и области
      </h1>

      <p class="hero__text">
        Проектируем, производим и монтируем системы для частных домов
        и бизнеса. Подберём решение под ваш объект и сценарий
        использования.
      </p>

      <div class="hero__actions">
        <a class="hero__button hero__button--primary" href="#lead-form">
          Получить расчёт
        </a>
        <a class="hero__button hero__button--secondary" href="#cases">
          Смотреть проекты
        </a>
      </div>

      <div class="hero__meta">
        <div class="hero__meta-item">
          <strong>12 лет</strong>
          <span>на рынке</span>
        </div>
        <div class="hero__meta-item">
          <strong>4000+</strong>
          <span>проектов по России</span>
        </div>
        <div class="hero__meta-item">
          <strong>от 100 000 ₽</strong>
          <span>стоимость решений под ключ</span>
        </div>
        <div class="hero__meta-item">
          <strong>Бесплатно</strong>
          <span>подбор системы и расчёт</span>
        </div>
      </div>
    </div>
  </div>
</section>
