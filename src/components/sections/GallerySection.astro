---
const images = [
  { src: "/images/gallery/verandy/slide-verandy-12.jpeg", alt: "Веранда" },
  { src: "/images/gallery/verandy/slide-verandy-6.jpeg",  alt: "Веранда" },
  { src: "/images/gallery/gallery-slide-enter.jpeg",      alt: "Вход" },
  { src: "/images/gallery/slide-extra.jpg",               alt: "Проект" },
  { src: "/images/gallery/lift/lift-4.jpg",               alt: "Лифт" },
  { src: "/images/gallery/lift/lift-5.jpg",               alt: "Лифт" },
  { src: "/images/gallery/knizhka-terrasy-1.png",         alt: "Книжка террасы" },
  { src: "/images/gallery/lift/lift-6.jpg",               alt: "Лифт" },
  { src: "/images/gallery/terrasy/slide-terrasy-2.jpg",   alt: "Терраса" },
  { src: "/images/gallery/lift/lift-7.png",               alt: "Лифт" },
  { src: "/images/gallery/lift/lift-8.jpg",               alt: "Лифт" },
  { src: "/images/gallery/terrasy/slide-terrasy-1.jpg",   alt: "Терраса" },
  { src: "/images/gallery/terrasy/slide-terrasy-3.jpg",   alt: "Терраса" },
  { src: "/images/gallery/verandy/slide-verandy-1.jpg",   alt: "Веранда" },
  { src: "/images/gallery/verandy/slide-verandy-3.jpeg",  alt: "Веранда" },
  { src: "/images/gallery/verandy/slide-verandy-11.jpeg", alt: "Веранда" },
  { src: "/images/gallery/verandy/slide-verandy-4.jpg",   alt: "Веранда" },
  { src: "/images/gallery/verandy/slide-verandy-5.png",   alt: "Веранда" },
  { src: "/images/gallery/verandy/slide-verandy-7.jpeg",  alt: "Веранда" },
  { src: "/images/gallery/verandy/slide-verandy-8.jpg",   alt: "Веранда" },
  { src: "/images/gallery/verandy/slide-verandy-10.jpg",  alt: "Веранда" },
];
---

<section class="gs" id="gallery" aria-labelledby="gs-title">
  <div class="gs__wrap">

    <div class="gs__head">
      <p class="gs__eyebrow">Фотогалерея</p>
      <h2 class="gs__title" id="gs-title">Остекление на реальных объектах</h2>
      <p class="gs__lead">Террасы, веранды, беседки и коммерческие объекты.</p>
    </div>

    <!-- Большая фото -->
    <button class="gs__featured" id="gsFeatured" aria-label="Открыть полный экран">
      <img class="gs__feat-img" id="gsFeatImg"
           src={images[0].src} alt={images[0].alt} decoding="async" />
      <span class="gs__feat-hint">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/>
        </svg>
      </span>
    </button>

    <!-- Лента превью -->
    <div class="gs__strip" id="gsStrip">
      {images.map((img, i) => (
        <button
          class={i === 0 ? "gs__thumb gs__thumb--active" : "gs__thumb"}
          data-i={i}
          aria-label={img.alt}
        >
          <img src={img.src} alt={img.alt} loading="lazy" decoding="async" />
        </button>
      ))}
    </div>

  </div>
</section>

<!-- Lightbox -->
<div class="lb" id="lb" hidden role="dialog" aria-modal="true">
  <button class="lb__close" id="lbClose" aria-label="Закрыть">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
         stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
      <path d="M18 6 6 18M6 6l12 12"/>
    </svg>
  </button>

  <button class="lb__arr lb__arr--l" id="lbPrev" aria-label="Назад">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none"
         stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M15 18 9 12l6-6"/>
    </svg>
  </button>

  <div class="lb__stage">
    <img class="lb__img" id="lbImg" src="" alt="" />
  </div>

  <button class="lb__arr lb__arr--r" id="lbNext" aria-label="Вперёд">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none"
         stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M9 18l6-6-6-6"/>
    </svg>
  </button>

  <p class="lb__count" id="lbCount"></p>
</div>

<style>
  /* ── Section ── */
  .gs {
    background:
      radial-gradient(circle at top left, rgba(228,67,54,.05), transparent 24%),
      linear-gradient(180deg, #f3f1ef 0%, #efedeb 100%);
    color: #111;
  }

  .gs__wrap {
    max-width: 1280px;
    margin: 0 auto;
    padding: clamp(64px, 8vw, 120px) 24px;
  }

  /* ── Header ── */
  .gs__head {
    margin-bottom: clamp(28px, 4vw, 44px);
    text-align: center;
  }

  .gs__eyebrow {
    margin: 0 0 12px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: #e44336;
  }

  .gs__title {
    margin: 0;
    font-size: clamp(32px, 5vw, 56px);
    line-height: .96;
    letter-spacing: -.04em;
    font-weight: 700;
  }

  .gs__lead {
    margin: 14px auto 0;
    font-size: clamp(15px, 1.3vw, 18px);
    line-height: 1.65;
    color: #5f6773;
  }

  /* ── Featured ── */
  .gs__featured {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    padding: 0;
    border: none;
    border-radius: 18px;
    overflow: hidden;
    cursor: zoom-in;
    background: #1c1c1e;
    position: relative;
    margin-bottom: 10px;
    touch-action: pan-y;
    user-select: none;
    -webkit-user-select: none;
  }

  .gs__featured.is-dragging {
    cursor: grabbing;
  }

  .gs__feat-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform .5s ease, opacity .22s ease;
  }

  .gs__feat-img.fade { opacity: 0; }

  .gs__featured:hover .gs__feat-img { transform: scale(1.025); }

  /* иконка "развернуть" при наведении */
  .gs__feat-hint {
    position: absolute;
    bottom: 14px;
    right: 14px;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0,0,0,.45);
    border-radius: 8px;
    color: #fff;
    opacity: 0;
    transition: opacity .2s;
    pointer-events: none;
  }

  .gs__featured:hover .gs__feat-hint { opacity: 1; }

  /* ── Filmstrip ── */
  .gs__strip {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding: 2px 2px 6px;
  }

  .gs__strip::-webkit-scrollbar { display: none; }

  /* ── Thumbnail ── */
  .gs__thumb {
    flex: 0 0 120px;
    height: 80px;
    scroll-snap-align: start;
    padding: 0;
    border: 2.5px solid transparent;
    border-radius: 10px;
    overflow: hidden;
    cursor: pointer;
    background: #ccc;
    opacity: .6;
    transition: opacity .2s, border-color .2s, transform .2s;
  }

  .gs__thumb:hover {
    opacity: .85;
    transform: translateY(-2px);
  }

  .gs__thumb--active {
    border-color: #e44336;
    opacity: 1;
  }

  .gs__thumb img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    pointer-events: none;
  }

  /* ── Lightbox ── */
  .lb {
    position: fixed;
    inset: 0;
    z-index: 9000;
    background: rgba(8,8,8,.96);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lb[hidden] { display: none; }

  .lb__stage {
    width: calc(100% - 130px);
    height: calc(100% - 80px);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lb__img {
    display: block;
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: 8px;
    box-shadow: 0 24px 80px rgba(0,0,0,.7);
    transition: opacity .15s ease;
  }

  .lb__img.fade { opacity: 0; }

  .lb__close {
    position: absolute;
    top: 16px;
    right: 16px;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255,255,255,.1);
    border: 1px solid rgba(255,255,255,.15);
    border-radius: 50%;
    color: #fff;
    cursor: pointer;
    transition: background .18s;
  }

  .lb__close:hover { background: rgba(255,255,255,.22); }

  .lb__arr {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 50px;
    height: 50px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255,255,255,.08);
    border: 1px solid rgba(255,255,255,.13);
    border-radius: 50%;
    color: #fff;
    cursor: pointer;
    transition: background .18s;
  }

  .lb__arr:hover { background: rgba(255,255,255,.2); }
  .lb__arr--l { left: 14px; }
  .lb__arr--r { right: 14px; }

  .lb__count {
    position: absolute;
    bottom: 16px;
    left: 50%;
    transform: translateX(-50%);
    margin: 0;
    font-size: 13px;
    color: rgba(255,255,255,.4);
    letter-spacing: .06em;
    pointer-events: none;
  }

  /* ── Mobile ── */
  @media (max-width: 600px) {
    .gs__wrap { padding: 48px 12px; }

    .gs__featured {
      aspect-ratio: 4 / 3;
      border-radius: 14px;
    }

    .gs__thumb {
      flex: 0 0 88px;
      height: 60px;
      border-radius: 8px;
    }

    .lb__stage {
      width: 100%;
      height: calc(100% - 60px);
    }

    .lb__arr { width: 38px; height: 38px; }
    .lb__arr--l { left: 6px; }
    .lb__arr--r { right: 6px; }
    .lb__img { border-radius: 4px; }
  }
</style>

<script>
  var thumbs   = Array.from(document.querySelectorAll('.gs__thumb'));
  var featBtn  = document.getElementById('gsFeatured');
  var featImg  = document.getElementById('gsFeatImg');
  var lb       = document.getElementById('lb');
  var lbImg    = document.getElementById('lbImg');
  var lbClose  = document.getElementById('lbClose');
  var lbPrev   = document.getElementById('lbPrev');
  var lbNext   = document.getElementById('lbNext');
  var lbCount  = document.getElementById('lbCount');

  var srcs  = thumbs.map(function(b){ return b.querySelector('img').getAttribute('src'); });
  var alts  = thumbs.map(function(b){ return b.querySelector('img').getAttribute('alt'); });
  var total = srcs.length;
  var cur   = 0;

  var featStartX = 0;
  var featStartY = 0;
  var featPointerDown = false;
  var suppressFeaturedClick = false;
  var wheelLock = false;

  /* ── Выбор превью ── */
  function selectThumb(i) {
    cur = i;
    thumbs.forEach(function(t, j){
      t.classList.toggle('gs__thumb--active', j === i);
    });
    thumbs[i].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });

    featImg.classList.add('fade');
    setTimeout(function(){
      featImg.src = srcs[i];
      featImg.alt = alts[i];
      featImg.classList.remove('fade');
    }, 180);
  }

  thumbs.forEach(function(b, i){
    b.addEventListener('click', function(){ selectThumb(i); });
  });

  function stepFeatured(step) {
    selectThumb((cur + step + total) % total);
  }

  /* ── Lightbox open/close ── */
  function lbShow(i) {
    cur = (i + total) % total;
    lbImg.classList.add('fade');
    setTimeout(function(){
      lbImg.src = srcs[cur];
      lbImg.alt = alts[cur];
      lbImg.classList.remove('fade');
    }, 120);
    lbCount.textContent = (cur + 1) + ' / ' + total;
  }

  function lbOpen(i) {
    cur = i;
    lb.removeAttribute('hidden');
    document.body.style.overflow = 'hidden';
    lbImg.src = srcs[cur];
    lbImg.alt = alts[cur];
    lbCount.textContent = (cur + 1) + ' / ' + total;
  }

  function lbClose2() {
    lb.setAttribute('hidden', '');
    document.body.style.overflow = '';
  }

  featBtn.addEventListener('click', function(e){
    if (suppressFeaturedClick) {
      e.preventDefault();
      suppressFeaturedClick = false;
      return;
    }
    lbOpen(cur);
  });

  featBtn.addEventListener('pointerdown', function(e){
    if (e.pointerType === 'mouse' && e.button !== 0) return;
    featPointerDown = true;
    featStartX = e.clientX;
    featStartY = e.clientY;
    featBtn.classList.add('is-dragging');
  });

  featBtn.addEventListener('pointerup', function(e){
    if (!featPointerDown) return;
    featPointerDown = false;
    featBtn.classList.remove('is-dragging');

    var dx = e.clientX - featStartX;
    var dy = e.clientY - featStartY;

    if (Math.abs(dx) < 36) return;
    if (Math.abs(dx) < Math.abs(dy) * 1.15) return;

    suppressFeaturedClick = true;
    stepFeatured(dx < 0 ? 1 : -1);

    setTimeout(function(){
      suppressFeaturedClick = false;
    }, 220);
  });

  featBtn.addEventListener('pointercancel', function(){
    featPointerDown = false;
    featBtn.classList.remove('is-dragging');
  });

  featBtn.addEventListener('pointerleave', function(){
    if (!featPointerDown) return;
    featPointerDown = false;
    featBtn.classList.remove('is-dragging');
  });

  featBtn.addEventListener('wheel', function(e){
    if (wheelLock) return;

    var mostlyHorizontal = Math.abs(e.deltaX) > Math.abs(e.deltaY);
    if (!mostlyHorizontal || Math.abs(e.deltaX) < 14) return;

    e.preventDefault();
    wheelLock = true;
    stepFeatured(e.deltaX > 0 ? 1 : -1);

    setTimeout(function(){
      wheelLock = false;
    }, 260);
  }, { passive: false });

  lbClose.addEventListener('click', lbClose2);
  lbPrev.addEventListener('click',  function(){ lbShow(cur - 1); });
  lbNext.addEventListener('click',  function(){ lbShow(cur + 1); });

  lb.addEventListener('click', function(e){ if (e.target === lb) lbClose2(); });

  document.addEventListener('keydown', function(e){
    if (lb.hasAttribute('hidden')) return;
    if (e.key === 'Escape')     lbClose2();
    if (e.key === 'ArrowLeft')  lbShow(cur - 1);
    if (e.key === 'ArrowRight') lbShow(cur + 1);
  });

  /* ── Swipe в lightbox ── */
  var tx = 0;
  lb.addEventListener('touchstart', function(e){ tx = e.changedTouches[0].clientX; }, { passive: true });
  lb.addEventListener('touchend',   function(e){
    var dx = e.changedTouches[0].clientX - tx;
    if (Math.abs(dx) < 40) return;
    lbShow(dx < 0 ? cur + 1 : cur - 1);
  }, { passive: true });
</script>
