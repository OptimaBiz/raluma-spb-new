---
import '../../styles/sections/faq.css';
---

<section class="faq" id="faq">
  <div class="container">
    <div class="faq__head">
      <p class="faq__eyebrow">FAQ</p>
      <h2 class="faq__title">Монтаж, размеры и гарантия</h2>
    </div>

    <div class="faq__list">
      <details class="faq__item" open>
        <summary class="faq__summary">
          <span class="faq__question">Подходит ли для готового объекта без демонтажа?</span>
          <span class="faq__icon" aria-hidden="true"></span>
        </summary>
        <div class="faq__content">
          <p class="faq__answer">
            Да. Нижнеопорные системы крепятся к полу и потолочной балке — без нагрузки
            на кровлю и без вскрытия конструктива. Монтируем на готовые дома, рестораны
            и коммерческие объекты.
          </p>
        </div>
      </details>

      <details class="faq__item">
        <summary class="faq__summary">
          <span class="faq__question">Как долго идёт монтаж?</span>
          <span class="faq__icon" aria-hidden="true"></span>
        </summary>
        <div class="faq__content">
          <p class="faq__answer">
            Стандартный объект — 1–3 рабочих дня. Сложные проёмы или большие площади —
            скажем точнее на выезде. Работаем аккуратно, без строительного мусора внутри.
          </p>
        </div>
      </details>

      <details class="faq__item">
        <summary class="faq__summary">
          <span class="faq__question">Возможен нестандартный размер?</span>
          <span class="faq__icon" aria-hidden="true"></span>
        </summary>
        <div class="faq__content">
          <p class="faq__answer">
            Да. Производим системы под конкретные размеры, архитектуру и конфигурацию
            проёма. Расчёт всегда под ваш объект, а не под шаблон.
          </p>
        </div>
      </details>

      <details class="faq__item">
        <summary class="faq__summary">
          <span class="faq__question">Какая гарантия на конструкцию?</span>
          <span class="faq__icon" aria-hidden="true"></span>
        </summary>
        <div class="faq__content">
          <p class="faq__answer">
            Даём гарантию на профиль, стекло и монтаж. Конкретные сроки зависят от
            системы и объекта — уточним при подготовке расчёта.
          </p>
        </div>
      </details>
    </div>
  </div>
</section>

<script>
  const faqItems = Array.from(document.querySelectorAll('.faq__item'));
  const faqReduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  faqItems.forEach((item) => {
    const summary = item.querySelector('.faq__summary');
    if (!(item instanceof HTMLDetailsElement) || !(summary instanceof HTMLElement)) return;

    summary.addEventListener('click', (event) => {
      event.preventDefault();
      if (item.dataset.animating === 'true') return;

      const opening = !item.open;
      if (faqReduceMotion || typeof item.animate !== 'function') {
        item.open = opening;
        return;
      }

      const startHeight = item.offsetHeight;
      if (opening) item.open = true;
      const endHeight = opening ? item.scrollHeight : summary.offsetHeight + 2;

      item.dataset.animating = 'true';
      const animation = item.animate(
        [{ height: `${startHeight}px` }, { height: `${endHeight}px` }],
        { duration: 360, easing: 'cubic-bezier(0.22, 1, 0.36, 1)' },
      );

      animation.onfinish = () => {
        if (!opening) item.open = false;
        delete item.dataset.animating;
      };

      animation.oncancel = () => {
        delete item.dataset.animating;
      };
    });
  });
</script>
