---
import '../../styles/sections/selection-cta.css';
---

<section class="selection-cta">
  <div class="container">
    <div class="selection-cta__box">
      <div class="selection-cta__content">
        <p class="selection-cta__eyebrow">Бесплатный подбор решения</p>
        <h2 class="selection-cta__title">
          Пришлите фото или чертёж — подберём систему под ваш объект
        </h2>
        <p class="selection-cta__text">
          Свяжемся в течение рабочего дня, уточним проём и сценарий использования,
          затем подготовим предварительный расчёт.
        </p>

        <div class="selection-cta__badges">
          <span class="selection-cta__badge">По фото объекта</span>
          <span class="selection-cta__badge">По чертежу</span>
        </div>
      </div>

      <div class="selection-cta__actions">
        <a class="selection-cta__button selection-cta__button--primary" href="#lead-form">
          Получить предварительный расчёт
        </a>
        <p class="selection-cta__note">Бесплатно · без обязательств</p>
      </div>
    </div>
  </div>
</section>
