---
const cards = [
  {
    area: 'panorama',
    label: '01',
    title: 'Панорама без лишних стоек',
    text: 'Максимум света и обзора без тяжёлых вертикальных рам и визуального шума.'
  },
  {
    area: 'protection',
    label: '02',
    title: 'Защита от ветра и осадков',
    text: 'Терраса, веранда или беседка становятся комфортнее даже в переменчивую погоду.'
  },
  {
    area: 'season',
    label: '03',
    title: 'Дольше по сезону',
    text: 'Пространством можно полноценно пользоваться не только в идеальные дни.'
  },
  {
    area: 'selection',
    label: '04',
    title: 'Подбор под архитектуру объекта',
    text: 'Система выбирается под проём, сценарий открывания и характер конкретного дома.'
  },
  {
    area: 'status',
    label: '05',
    title: 'Статусный внешний вид',
    text: 'Остекление делает объект аккуратнее, современнее и визуально дороже.'
  }
];
---

<section class="benefits-v2" id="benefits" aria-labelledby="benefits-title">
  <div class="benefits-v2__inner">
    <div class="benefits-v2__intro">
      <p class="benefits-v2__eyebrow">Что вы получаете</p>

      <h2 class="benefits-v2__title" id="benefits-title">
        Защита без потери панорамы
      </h2>

      <p class="benefits-v2__lead">
        Больше света и комфорта на террасе, веранде или в беседке.
      </p>

      <div class="benefits-v2__meta" aria-label="Ключевые преимущества">
        <span>Свет</span>
        <span>Защита</span>
        <span>Архитектура</span>
        <span>Комфорт</span>
      </div>

      <p class="benefits-v2__note">Подбор под ваш проём и сценарий использования.</p>
    </div>

    <div class="benefits-v2__board">
      <article class="benefits-v2__card benefits-v2__card--featured">
        <div class="benefits-v2__featured-glow" aria-hidden="true"></div>

        <p class="benefits-v2__card-label benefits-v2__card-label--light">
          Ключевой эффект
        </p>

        <h3 class="benefits-v2__featured-title">
          Открытое пространство без тяжёлых рам
        </h3>

        <p class="benefits-v2__featured-text">
          Больше света, чище линии фасада и свободный обзор.
        </p>

        <div class="benefits-v2__featured-tags" aria-hidden="true">
          <span>Панорама</span>
          <span>Лёгкость</span>
          <span>Статус</span>
        </div>
      </article>

      {cards.map((card) => (
        <article class={`benefits-v2__card benefits-v2__card--${card.area}`}>
          <p class="benefits-v2__card-label">{card.label}</p>
          <h3 class="benefits-v2__card-title">{card.title}</h3>
          <p class="benefits-v2__card-text">{card.text}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .benefits-v2 {
    background:
      radial-gradient(circle at top left, rgba(236, 58, 47, 0.14), transparent 32%),
      linear-gradient(180deg, #161616 0%, #101010 100%);
    color: #ffffff;
  }

  .benefits-v2__inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: clamp(72px, 8vw, 128px) 24px;
    display: grid;
    grid-template-columns: minmax(280px, 0.92fr) minmax(0, 1.28fr);
    gap: clamp(28px, 4vw, 56px);
    align-items: start;
  }

  .benefits-v2__intro {
    position: sticky;
    top: 104px;
  }

  .benefits-v2__eyebrow {
    margin: 0 0 18px;
    font-size: 12px;
    line-height: 1.2;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #e44336;
  }

  .benefits-v2__title {
    margin: 0;
    max-width: 11ch;
    font-size: clamp(40px, 5.4vw, 72px);
    line-height: 0.98;
    letter-spacing: -0.04em;
    font-weight: 700;
  }

  .benefits-v2__lead {
    margin: 24px 0 0;
    max-width: 620px;
    font-size: clamp(18px, 1.55vw, 22px);
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.72);
  }

  .benefits-v2__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 28px;
  }

  .benefits-v2__meta span {
    display: inline-flex;
    align-items: center;
    min-height: 38px;
    padding: 0 14px;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    font-size: 13px;
    line-height: 1;
    font-weight: 600;
    color: #ffffff;
    backdrop-filter: blur(10px);
  }

  .benefits-v2__note {
    margin: 22px 0 0;
    max-width: 460px;
    font-size: 15px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.56);
  }

  .benefits-v2__board {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    grid-template-areas:
      "featured featured panorama"
      "featured featured protection"
      "season selection status";
    gap: 18px;
  }

  .benefits-v2__card {
    position: relative;
    overflow: hidden;
    min-height: 230px;
    padding: 24px 22px 22px;
    border-radius: 28px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.10);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.04) inset,
      0 18px 48px rgba(0, 0, 0, 0.24);
    transition:
      transform 0.28s ease,
      box-shadow 0.28s ease,
      border-color 0.28s ease;
  }

  .benefits-v2__card:hover {
    transform: translateY(-4px);
    border-color: rgba(228, 67, 54, 0.42);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.06) inset,
      0 24px 64px rgba(0, 0, 0, 0.32);
  }

  .benefits-v2__card::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.06), transparent 30%),
      linear-gradient(120deg, transparent 35%, rgba(228, 67, 54, 0.10) 100%);
  }

  .benefits-v2__card--featured {
    grid-area: featured;
    min-height: 478px;
    padding: 30px 30px 28px;
    background:
      radial-gradient(circle at top right, rgba(228, 67, 54, 0.10), transparent 38%),
      linear-gradient(180deg, #ffffff 0%, #f4f1ef 100%);
    border-color: rgba(255, 255, 255, 0.9);
    box-shadow: 0 28px 80px rgba(0, 0, 0, 0.38);
    color: #111111;
  }

  .benefits-v2__card--featured:hover {
    border-color: #ffffff;
    box-shadow: 0 32px 92px rgba(0, 0, 0, 0.46);
  }

  .benefits-v2__featured-glow {
    position: absolute;
    right: -40px;
    top: -40px;
    width: 220px;
    height: 220px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(228, 67, 54, 0.32) 0%, rgba(228, 67, 54, 0) 72%);
    pointer-events: none;
    filter: blur(8px);
  }

  .benefits-v2__card-label {
    position: relative;
    z-index: 1;
    margin: 0 0 18px;
    font-size: 12px;
    line-height: 1.2;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #e44336;
  }

  .benefits-v2__card-label--light {
    color: #8b929c;
  }

  .benefits-v2__featured-title {
    position: relative;
    z-index: 1;
    margin: 0;
    max-width: 12ch;
    font-size: clamp(30px, 3vw, 44px);
    line-height: 1.03;
    letter-spacing: -0.04em;
    font-weight: 700;
  }

  .benefits-v2__featured-text {
    position: relative;
    z-index: 1;
    max-width: 36ch;
    margin: 22px 0 0;
    font-size: 17px;
    line-height: 1.68;
    color: #55606f;
  }

  .benefits-v2__featured-tags {
    position: relative;
    z-index: 1;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 28px;
  }

  .benefits-v2__featured-tags span {
    display: inline-flex;
    align-items: center;
    min-height: 36px;
    padding: 0 13px;
    border-radius: 999px;
    background: rgba(17, 17, 17, 0.06);
    border: 1px solid rgba(17, 17, 17, 0.10);
    font-size: 13px;
    line-height: 1;
    font-weight: 600;
    color: #111111;
  }

  .benefits-v2__card-title {
    position: relative;
    z-index: 1;
    margin: 0;
    max-width: 14ch;
    font-size: clamp(22px, 1.9vw, 28px);
    line-height: 1.1;
    letter-spacing: -0.03em;
    font-weight: 700;
    color: #ffffff;
  }

  .benefits-v2__card-text {
    position: relative;
    z-index: 1;
    margin: 16px 0 0;
    max-width: 28ch;
    font-size: 16px;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.66);
  }

  .benefits-v2__card--panorama { grid-area: panorama; }
  .benefits-v2__card--protection { grid-area: protection; }
  .benefits-v2__card--season { grid-area: season; }
  .benefits-v2__card--selection { grid-area: selection; }
  .benefits-v2__card--status { grid-area: status; }

  @media (max-width: 1120px) {
    .benefits-v2__inner {
      grid-template-columns: 1fr;
    }

    .benefits-v2__intro {
      position: static;
    }

    .benefits-v2__title {
      max-width: 12ch;
    }

    .benefits-v2__board {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      grid-template-areas:
        "featured featured"
        "panorama protection"
        "season selection"
        "status status";
    }

    .benefits-v2__card--featured {
      min-height: 360px;
    }
  }

  @media (max-width: 720px) {
    .benefits-v2__card:not(.benefits-v2__card--featured) {
      display: none;
    }

    .benefits-v2__inner {
      padding: 64px 18px;
      gap: 24px;
    }

    .benefits-v2__title {
      max-width: none;
      font-size: clamp(34px, 10vw, 52px);
      line-height: 0.98;
    }

    .benefits-v2__lead {
      margin-top: 18px;
      font-size: 17px;
      line-height: 1.6;
    }

    .benefits-v2__note {
      font-size: 14px;
      margin-top: 18px;
    }

    .benefits-v2__board {
      grid-template-columns: 1fr;
      grid-template-areas: "featured";
      gap: 0;
    }

    .benefits-v2__card,
    .benefits-v2__card--featured {
      min-height: auto;
      padding: 22px 18px 20px;
      border-radius: 22px;
    }

    .benefits-v2__featured-title {
      max-width: none;
      font-size: 28px;
    }

    .benefits-v2__featured-text,
    .benefits-v2__card-text {
      max-width: none;
    }

    .benefits-v2__card-title {
      max-width: none;
      font-size: 24px;
    }

    .benefits-v2__meta {
      gap: 8px;
    }

    .benefits-v2__meta span,
    .benefits-v2__featured-tags span {
      min-height: 34px;
      font-size: 12px;
    }
  }
</style>
