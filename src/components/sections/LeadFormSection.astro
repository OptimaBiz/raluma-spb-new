---
import '../../styles/sections/lead-form.css';
---

<section class="lead-form" id="lead-form">
  <div class="lead-form__bg" aria-hidden="true"></div>
  <div class="lead-form__overlay" aria-hidden="true"></div>

  <div class="container lead-form__container">
    <div class="lead-form__card">
      <p class="lead-form__eyebrow">Форма для связи</p>

      <h2 class="lead-form__title">Рассчитаем решение под ваш объект</h2>

      <p class="lead-form__text">
        Фото или чертёж помогут сделать расчёт точнее.
      </p>

      <form
        class="lead-form__form"
        id="lead-form-element"
        action="https://script.google.com/macros/s/AKfycbxcf47z7AnQvhfcGi9CGJ3zowcPNX8nS7157L5RUgymKInR8Rxq8q4PSqjmLjDrW6Re/exec"
        method="post"
        accept-charset="UTF-8"
        novalidate
      >
        <input type="hidden" name="action" value="submit" />
        <input
          type="text"
          name="website"
          tabindex="-1"
          autocomplete="off"
          aria-hidden="true"
          style="display: none"
        />

        <label class="lead-form__field">
          <span class="lead-form__label">Имя</span>
          <input
            class="lead-form__input"
            id="lead-name-input"
            type="text"
            name="name"
            placeholder="ваше имя"
            autocomplete="name"
          />
        </label>

        <label class="lead-form__field">
          <span class="lead-form__label">Телефон</span>
          <input
            class="lead-form__input"
            id="lead-phone-input"
            type="tel"
            name="phone"
            placeholder="+7 999 123-45-67"
            autocomplete="tel"
          />
          <span class="lead-form__hint">Укажите не менее 7 цифр в любом формате</span>
        </label>

        <label class="lead-form__field">
          <span class="lead-form__label">
            Комментарий <small>необязательно</small>
          </span>
          <textarea
            class="lead-form__input lead-form__textarea"
            name="comment"
            rows="3"
            maxlength="600"
            placeholder="Адрес объекта, дополнительные пожелания"
          ></textarea>
        </label>

        <div class="lead-form__upload" data-file-upload>
          <input
            class="lead-form__file-input"
            id="lead-files-input"
            type="file"
            name="attachment"
            accept="image/jpeg,image/png,image/webp,image/heic,image/heif,application/pdf,.heic,.heif,.pdf"
            aria-describedby="lead-file-help lead-file-error"
          />

          <label class="lead-form__file-drop" for="lead-files-input">
            <span class="lead-form__upload-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="22" height="22" fill="none">
                <path d="M12 16V4m0 0L7.5 8.5M12 4l4.5 4.5M5 14v4a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            <span class="lead-form__upload-copy">
              <strong>Добавить фото или чертёж</strong>
              <small id="lead-file-help">1 файл: JPG, PNG, HEIC, WebP или PDF</small>
            </span>
            <span class="lead-form__upload-action">Выбрать</span>
          </label>

          <ul class="lead-form__file-list" id="lead-file-list" aria-label="Выбранный файл" hidden></ul>
          <p class="lead-form__file-error" id="lead-file-error" role="alert" aria-live="polite" hidden></p>
          <p class="lead-form__upload-safety">До 10 МБ.</p>
        </div>

        <div class="lead-form__consent-box">
          <div class="lead-form__consent-row">
            <input
              class="lead-form__checkbox"
              type="checkbox"
              id="lead-consent-checkbox"
              name="consent"
              value="yes"
            />

            <label
              class="lead-form__checkbox-ui"
              for="lead-consent-checkbox"
              aria-label="Согласие"
            ></label>

            <p class="lead-form__consent-text">
              Я даю
              <button
                class="lead-form__inline-link"
                type="button"
                data-dialog-open="consent-dialog"
              >
                согласие на обработку персональных данных
              </button>
              и подтверждаю ознакомление с
              <button
                class="lead-form__inline-link"
                type="button"
                data-dialog-open="privacy-dialog"
              >
                политикой конфиденциальности
              </button>.
            </p>
          </div>
        </div>

        <button
          class="lead-form__button"
          id="lead-submit-button"
          type="submit"
          disabled
        >
          Получить предварительный расчёт
        </button>

        <p class="lead-form__status" id="lead-form-status" role="status" aria-live="polite" hidden></p>
      </form>
    </div>
  </div>

  <dialog class="lead-form__dialog" id="consent-dialog">
    <div class="lead-form__dialog-inner">
      <div class="lead-form__dialog-head">
        <div>
          <p class="lead-form__dialog-eyebrow">Документ</p>
          <h3 class="lead-form__dialog-title">Согласие на обработку персональных данных</h3>
        </div>
        <button class="lead-form__dialog-close" type="button" data-dialog-close aria-label="Закрыть">×</button>
      </div>

      <div class="lead-form__dialog-body">
        <p>
          Я, заполняя форму на сайте, даю своё согласие на обработку моих персональных
          данных: имени, телефона, адреса электронной почты, а также иных сведений,
          указанных в сообщении и добровольно прикреплённых файлах.
        </p>

        <p>
          Обработка персональных данных осуществляется в целях рассмотрения обращения,
          обратной связи со мной, подготовки ответа на запрос, предложения услуг по
          заявленной задаче и заключения договора.
        </p>

        <p>
          Под обработкой персональных данных понимаются сбор, запись, систематизация,
          накопление, хранение, уточнение, использование и удаление персональных данных
          в соответствии с действующим законодательством Российской Федерации.
        </p>

        <p>
          Согласие действует до достижения целей обработки персональных данных либо до
          момента его отзыва субъектом персональных данных.
        </p>

        <p>
          Полные правила изложены в Политике конфиденциальности.
        </p>
      </div>
    </div>
  </dialog>

  <dialog class="lead-form__dialog" id="privacy-dialog">
    <div class="lead-form__dialog-inner lead-form__dialog-inner--wide">
      <div class="lead-form__dialog-head">
        <div>
          <p class="lead-form__dialog-eyebrow">Документ</p>
          <h3 class="lead-form__dialog-title">Политика конфиденциальности</h3>
        </div>
        <button class="lead-form__dialog-close" type="button" data-dialog-close aria-label="Закрыть">×</button>
      </div>

      <div class="lead-form__dialog-body">
        <pre class="lead-form__policy-text">Политика конфиденциальности

Настоящая Политика конфиденциальности определяет порядок обработки и защиты персональных данных пользователей сайта https://raluma.com.ru (далее — «Сайт»).

Оператор персональных данных (ОГРНИП: 324784700069042 ) принимает необходимые правовые, организационные и технические меры для защиты персональных данных в соответствии с требованиями Федерального закона №152-ФЗ «О персональных данных».
---
1. Какие данные мы собираем

Мы можем собирать следующие персональные данные:

    Имя
    Номер телефона
    Адрес электронной почты
    Иные сведения, указанные пользователем в форме на сайте
    Файлы, добровольно прикреплённые пользователем к форме
    Паспортные данные, ИНН, адрес регистрации (только при заключении договора)

---
2. Цели обработки персональных данных

    Обработка обращений и обратная связь с пользователем
    Подготовка и исполнение договоров
    Информирование о статусе заказа (включая SMS и email)
    Предоставление услуг и консультаций
    Исполнение требований законодательства РФ
    Предоставление специальных предложений (при согласии пользователя)

---
3. Передача персональных данных третьим лицам

Персональные данные могут передаваться третьим лицам исключительно для достижения указанных целей:

    Сервисам отправки уведомлений (например, SMS и CRM-системам, таким как Битрикс24)
    Логистическим и монтажным компаниям
    Информационным системам, используемым для обработки заявок

Все третьи лица обязаны соблюдать конфиденциальность и использовать данные только в рамках заявленных целей.
---
4. Правовые основания обработки

Обработка персональных данных осуществляется на основании:

    Федерального закона №152-ФЗ «О персональных данных»
    Согласия субъекта персональных данных
    Необходимости исполнения договора

---
5. Сроки обработки и хранения данных

Персональные данные обрабатываются до достижения целей обработки либо до момента отзыва согласия пользователем, если иное не предусмотрено законодательством Российской Федерации.
---
6. Права пользователя

Пользователь имеет право:

    Получить информацию о своих персональных данных
    Требовать их уточнения, блокировки или удаления
    Отозвать согласие на обработку персональных данных

Для реализации своих прав пользователь может обратиться по адресу электронной почты: hello@raluma.com.ru

Или по почтовому адресу: 198335, Россия, Санкт-Петербург, Ленинский пр-т, д. 55, корпус 2, литера А.
---
7. Защита персональных данных

Оператор принимает необходимые меры для защиты персональных данных:

    Использование защищённых каналов передачи данных (HTTPS)
    Ограничение доступа к данным
    Применение технических и организационных мер безопасности

---
8. Отзыв согласия

Пользователь вправе отозвать согласие на обработку персональных данных, направив запрос на указанный email. Запрос обрабатывается в течение 30 календарных дней.
---
9. Заключительные положения

Отправляя данные через формы на сайте, пользователь подтверждает своё согласие с настоящей Политикой конфиденциальности.

Оператор вправе вносить изменения в настоящую Политику без согласия пользователя. Актуальная версия всегда доступна на данной странице.</pre>
      </div>
    </div>
  </dialog>

  <script is:inline>
    const form = document.getElementById('lead-form-element');
    const thankYouUrl = '/thank-you/';
    const backendEndpoint = 'https://script.google.com/macros/s/AKfycbxcf47z7AnQvhfcGi9CGJ3zowcPNX8nS7157L5RUgymKInR8Rxq8q4PSqjmLjDrW6Re/exec';
    const checkbox = document.getElementById('lead-consent-checkbox');
    const submitButton = document.getElementById('lead-submit-button');
    const nameInput = document.getElementById('lead-name-input');
    const phoneInput = document.getElementById('lead-phone-input');
    const commentInput = form?.querySelector('[name="comment"]');
    const fileInput = document.getElementById('lead-files-input');
    const fileList = document.getElementById('lead-file-list');
    const fileError = document.getElementById('lead-file-error');
    const formStatus = document.getElementById('lead-form-status');
    const defaultButtonText = 'Получить предварительный расчёт';
    const maxFiles = 1;
    const maxTotalFileSize = 10 * 1024 * 1024;
    const imageOptimizationThreshold = 1.5 * 1024 * 1024;
    const optimizedImageMaxSide = 2400;
    let filesAreValid = true;
    let uploadState = 'idle';
    let activeUploadId = '';
    let uploadVersion = 0;
    let uploadPromise = Promise.resolve(true);
    let isSubmitting = false;

    const hasValue = (input) => Boolean(input && input.value.trim().length > 0);

    const getDigits = (value) => String(value || '').replace(/\D/g, '');
    const phoneLooksValid = (input) => getDigits(input?.value).length >= 7;

    const formatFileSize = (bytes) => {
      if (bytes < 1024 * 1024) return `${Math.ceil(bytes / 1024)} КБ`;
      return `${(bytes / (1024 * 1024)).toFixed(1).replace('.0', '')} МБ`;
    };

    const showFileError = (message = '') => {
      filesAreValid = !message;
      if (!fileError) return;
      fileError.textContent = message;
      fileError.hidden = !message;
    };

    const showFormStatus = (message = '', type = 'error') => {
      if (!formStatus) return;
      formStatus.textContent = message;
      formStatus.dataset.type = type;
      formStatus.hidden = !message;
    };

    const validateFiles = (files) => {
      if (files.length > maxFiles) {
        return 'Можно прикрепить только один файл.';
      }

      const totalFileSize = files.reduce((total, file) => total + file.size, 0);
      if (totalFileSize > maxTotalFileSize) {
        return `Размер файла — ${formatFileSize(totalFileSize)}. Допустимо не более 10 МБ.`;
      }

      const allowedExtensions = /\.(jpe?g|png|webp|heic|heif|pdf)$/i;
      const unsupportedFile = files.find((file) => !allowedExtensions.test(file.name));
      if (unsupportedFile) {
        return `Формат файла «${unsupportedFile.name}» не поддерживается.`;
      }

      return '';
    };

    const optimizeImageForUpload = async (file) => {
      const canOptimize =
        file.size > imageOptimizationThreshold &&
        /^image\/(jpeg|png|webp)$/i.test(file.type) &&
        typeof createImageBitmap === 'function';

      if (!canOptimize) return file;

      try {
        const bitmap = await createImageBitmap(file);
        const scale = Math.min(1, optimizedImageMaxSide / Math.max(bitmap.width, bitmap.height));
        const canvas = document.createElement('canvas');
        canvas.width = Math.max(1, Math.round(bitmap.width * scale));
        canvas.height = Math.max(1, Math.round(bitmap.height * scale));

        const context = canvas.getContext('2d');
        if (!context) {
          bitmap.close();
          return file;
        }

        context.fillStyle = '#ffffff';
        context.fillRect(0, 0, canvas.width, canvas.height);
        context.drawImage(bitmap, 0, 0, canvas.width, canvas.height);
        bitmap.close();

        const blob = await new Promise((resolve) => {
          canvas.toBlob(resolve, 'image/jpeg', 0.84);
        });

        if (!blob || blob.size >= file.size) return file;

        const optimizedName = file.name.replace(/\.[^.]+$/, '') + '-optimized.jpg';
        return new File([blob], optimizedName, {
          type: 'image/jpeg',
          lastModified: file.lastModified,
        });
      } catch (_) {
        return file;
      }
    };

    const createUploadId = () => {
      if (typeof globalThis.crypto?.randomUUID === 'function') return globalThis.crypto.randomUUID();
      return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, (character) => {
        const random = Math.floor(Math.random() * 16);
        const value = character === 'x' ? random : (random & 0x3) | 0x8;
        return value.toString(16);
      });
    };

    const replaceSelectedFile = (file) => {
      if (!fileInput || typeof DataTransfer !== 'function') return;
      const transfer = new DataTransfer();
      transfer.items.add(file);
      fileInput.files = transfer.files;
    };

    const readFileAsDataUrl = (file) => new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.addEventListener('load', () => resolve(String(reader.result || '')), { once: true });
      reader.addEventListener('error', () => reject(new Error('FILE_READ_ERROR')), { once: true });
      reader.readAsDataURL(file);
    });

    const getUploadMimeType = (file) => {
      if (file.type === 'image/jpg') return 'image/jpeg';
      if (file.type) return file.type.toLowerCase();
      const extension = file.name.split('.').pop()?.toLowerCase();
      const mimeTypes = {
        jpg: 'image/jpeg',
        jpeg: 'image/jpeg',
        png: 'image/png',
        webp: 'image/webp',
        heic: 'image/heic',
        heif: 'image/heif',
        pdf: 'application/pdf',
      };
      return mimeTypes[extension] || 'application/octet-stream';
    };

    const postToBackend = async (fields, timeoutMs = 90000) => {
      const frameName = `raluma-backend-${Date.now()}-${Math.random().toString(16).slice(2)}`;
      const frame = document.createElement('iframe');
      frame.name = frameName;
      frame.src = 'about:blank';
      frame.title = 'Служебная отправка формы';
      frame.setAttribute('aria-hidden', 'true');
      frame.hidden = true;

      const initialFrameReady = new Promise((resolve) => {
        frame.addEventListener('load', resolve, { once: true });
      });
      document.body.append(frame);
      await initialFrameReady;

      const transientForm = document.createElement('form');
      transientForm.method = 'post';
      transientForm.action = backendEndpoint;
      transientForm.target = frameName;
      transientForm.acceptCharset = 'UTF-8';
      transientForm.hidden = true;

      Object.entries(fields).forEach(([name, value]) => {
        const input = document.createElement('input');
        input.type = 'hidden';
        input.name = name;
        input.value = String(value ?? '');
        transientForm.append(input);
      });
      document.body.append(transientForm);

      return new Promise((resolve, reject) => {
        let settled = false;
        let fallbackTimer = 0;
        let requestTimer = 0;

        const cleanup = () => {
          window.clearTimeout(fallbackTimer);
          window.clearTimeout(requestTimer);
          window.removeEventListener('message', handleMessage);
          transientForm.remove();
          frame.remove();
        };

        const finish = (error, result = null) => {
          if (settled) return;
          settled = true;
          cleanup();
          if (error) reject(error);
          else resolve(result || { ok: true });
        };

        const handleMessage = (event) => {
          const payload = event.data;
          if (!payload || typeof payload !== 'object' || payload.type !== fields.action) return;
          if (fields.uploadId && payload.uploadId && payload.uploadId !== fields.uploadId) return;
          if (payload.ok === false) finish(new Error(payload.code || 'SERVER_ERROR'));
          else finish(null, payload);
        };

        window.addEventListener('message', handleMessage);
        frame.addEventListener('load', () => {
          fallbackTimer = window.setTimeout(() => finish(null, { ok: true }), 1200);
        }, { once: true });

        requestTimer = window.setTimeout(() => finish(new Error('REQUEST_TIMEOUT')), timeoutMs);
        transientForm.submit();
      });
    };

    const uploadSelectedFile = async (file, version) => {
      const originalSize = file.size;
      uploadState = 'preparing';
      showFormStatus('Подготавливаем файл…', 'progress');
      syncSubmitState();

      try {
        const preparedFile = await optimizeImageForUpload(file);
        if (version !== uploadVersion) return false;

        replaceSelectedFile(preparedFile);
        renderFiles();
        uploadState = 'uploading';
        showFormStatus(`Загружаем файл ${formatFileSize(preparedFile.size)}…`, 'progress');
        syncSubmitState();

        const fileBase64 = await readFileAsDataUrl(preparedFile);
        if (version !== uploadVersion) return false;

        activeUploadId = activeUploadId || createUploadId();
        await postToBackend({
          action: 'upload',
          uploadId: activeUploadId,
          fileName: preparedFile.name,
          fileType: getUploadMimeType(preparedFile),
          fileBase64,
          website: '',
        });
        if (version !== uploadVersion) return false;

        uploadState = 'uploaded';
        showFormStatus(
          preparedFile.size < originalSize
            ? `Файл загружен: ${formatFileSize(originalSize)} → ${formatFileSize(preparedFile.size)}.`
            : 'Файл загружен и готов к отправке.',
          'success',
        );
        syncSubmitState();
        return true;
      } catch (error) {
        if (version !== uploadVersion) return false;
        uploadState = 'error';
        const errorCode = error instanceof Error ? error.message : 'UPLOAD_ERROR';
        const uploadMessages = {
          FILE_READ_ERROR: 'Не удалось прочитать файл. Выберите его ещё раз.',
          FILE_TOO_BIG: 'Файл превышает допустимые 10 МБ.',
          UNSUPPORTED_FILE: 'Этот формат файла не поддерживается.',
          REQUEST_TIMEOUT: 'Загрузка заняла слишком много времени. Попробуйте ещё раз.',
          SERVER_ERROR: 'Не удалось загрузить файл. Попробуйте ещё раз.',
        };
        showFormStatus(uploadMessages[errorCode] || uploadMessages.SERVER_ERROR);
        syncSubmitState();
        return false;
      }
    };

    const renderFiles = () => {
      if (!fileInput || !fileList) return;
      const files = Array.from(fileInput.files || []);
      fileList.replaceChildren();
      fileList.hidden = files.length === 0;

      files.forEach((file) => {
        const item = document.createElement('li');
        const details = document.createElement('span');
        const name = document.createElement('strong');
        const size = document.createElement('small');
        const removeButton = document.createElement('button');

        name.textContent = file.name;
        size.textContent = formatFileSize(file.size);
        details.append(name, size);

        removeButton.type = 'button';
        removeButton.className = 'lead-form__file-remove';
        removeButton.setAttribute('aria-label', `Удалить файл ${file.name}`);
        removeButton.textContent = '×';
        removeButton.addEventListener('click', () => {
          uploadVersion += 1;
          fileInput.value = '';
          activeUploadId = '';
          uploadState = 'idle';
          uploadPromise = Promise.resolve(true);
          showFileError();
          showFormStatus();
          renderFiles();
          syncSubmitState();
        });

        item.append(details, removeButton);
        fileList.append(item);
      });
    };

    const syncSubmitState = () => {
      const enabled =
        Boolean(checkbox && checkbox.checked) &&
        hasValue(nameInput) &&
        phoneLooksValid(phoneInput) &&
        filesAreValid &&
        !['preparing', 'uploading', 'error'].includes(uploadState) &&
        !isSubmitting;

      if (submitButton) {
        submitButton.disabled = !enabled;
        submitButton.setAttribute('aria-disabled', String(!enabled));
        submitButton.classList.toggle('is-enabled', enabled);
      }
    };

    syncSubmitState();

    checkbox?.addEventListener('change', syncSubmitState);
    nameInput?.addEventListener('input', syncSubmitState);
    phoneInput?.addEventListener('input', syncSubmitState);
    fileInput?.addEventListener('change', () => {
      const files = Array.from(fileInput.files || []);
      const validationMessage = validateFiles(files);
      const version = ++uploadVersion;

      if (validationMessage) {
        fileInput.value = '';
        activeUploadId = '';
        uploadState = 'idle';
        uploadPromise = Promise.resolve(false);
        showFileError(validationMessage);
        showFormStatus();
      } else {
        showFileError();
        const selectedFile = files[0];
        if (selectedFile) {
          uploadPromise = uploadSelectedFile(selectedFile, version);
        } else {
          activeUploadId = '';
          uploadState = 'idle';
          uploadPromise = Promise.resolve(true);
          showFormStatus();
        }
      }

      renderFiles();
      syncSubmitState();
    });

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      event.stopImmediatePropagation();

      if (!form || !submitButton) return;

      const ready =
        Boolean(checkbox && checkbox.checked) &&
        hasValue(nameInput) &&
        phoneLooksValid(phoneInput) &&
        filesAreValid &&
        !['preparing', 'uploading', 'error'].includes(uploadState);

      if (!ready) return;

      isSubmitting = true;
      submitButton.disabled = true;
      const hasAttachment = Boolean(fileInput?.files?.length);
      submitButton.textContent = 'Отправляем…';
      showFormStatus('Отправляем заявку…', 'progress');

      try {
        const uploadSucceeded = await uploadPromise;
        if (hasAttachment && (!uploadSucceeded || uploadState !== 'uploaded')) {
          throw new Error('UPLOAD_NOT_READY');
        }

        await postToBackend({
          action: 'submit',
          uploadId: hasAttachment ? activeUploadId : '',
          name: nameInput?.value.trim() || '',
          phone: phoneInput?.value.trim() || '',
          comment: commentInput?.value.trim() || '',
          consent: 'yes',
          website: form.querySelector('[name="website"]')?.value || '',
        });

        window.safeReachGoal?.('lead_form_submit');
        window.location.replace(thankYouUrl);
      } catch (error) {
        const messages = {
          UPLOAD_NOT_READY: 'Файл ещё не загружен. Выберите его повторно или отправьте заявку без файла.',
          INVALID_FORM: 'Проверьте имя, телефон и согласие на обработку данных.',
          UPLOAD_NOT_FOUND: 'Файл не найден. Выберите его повторно.',
          REQUEST_TIMEOUT: 'Сервер отвечает слишком долго. Попробуйте ещё раз.',
          SERVER_ERROR: 'Не удалось отправить заявку. Попробуйте ещё раз или позвоните нам.',
          NETWORK_ERROR: 'Нет связи с сервером. Проверьте интернет и попробуйте снова.'
        };
        const errorCode = error instanceof Error ? error.message : 'NETWORK_ERROR';
        const message = messages[errorCode] || messages.NETWORK_ERROR;
        showFormStatus(message);
        isSubmitting = false;
        submitButton.textContent = defaultButtonText;
        syncSubmitState();
      }

      return false;
    });


    const dialogs = Array.from(document.querySelectorAll('.lead-form__dialog'));

    document.querySelectorAll('[data-dialog-open]').forEach((button) => {
      button.addEventListener('click', () => {
        const targetId = button.getAttribute('data-dialog-open');
        const dialog = targetId ? document.getElementById(targetId) : null;
        if (dialog && typeof dialog.showModal === 'function') {
          dialog.showModal();
        }
      });
    });

    document.querySelectorAll('[data-dialog-close]').forEach((button) => {
      button.addEventListener('click', () => {
        button.closest('dialog')?.close();
      });
    });

    dialogs.forEach((dialog) => {
      dialog.addEventListener('click', (event) => {
        const rect = dialog.getBoundingClientRect();
        const inside =
          rect.top <= event.clientY &&
          event.clientY <= rect.top + rect.height &&
          rect.left <= event.clientX &&
          event.clientX <= rect.left + rect.width;

        if (inside === false) {
          dialog.close();
        }
      });
    });
  </script>
</section>
