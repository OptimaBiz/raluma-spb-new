---
import '../../styles/sections/cases.css';

const cases = [
  {
    id: 'case-2024-wooden-gazebo',
    active: true,
    year: '2022',
    type: 'Деревянная беседка / зона барбекю',
    system: 'Слайд',
    price: '480 000 ₽',
    title: 'Остекление деревянной беседки',
    description:
      'Система «Слайд» с москитной сеткой-плиссе.',
    task:
      'Защитить беседку от ветра, осадков и насекомых, сохранив проветривание и вид.',
    result:
      'Комфортное использование с весны до осени без потери ощущения открытого пространства.',
    features: [
      'Система Слайд',
      'Встроенная москитная сетка-плиссе',
      '4 + статичное остекление 2 яруса',
    ],
    images: [
      {
        src: '/images/cases/wooden-gazebo/main-1.webp',
        alt: 'Остекление деревянной беседки, основной вид',
      },
      {
        src: '/images/cases/wooden-gazebo/main-2.webp',
        alt: 'Остекление деревянной беседки, второй ракурс',
      },
    ],
  },
  {
    id: 'case-2025-terrace-sertolovo',
    active: true,
    year: '2024',
    type: 'Веранда',
    system: 'Слайд',
    price: '880 000 ₽',
    title: 'Остекление веранды',
    description:
      'Система «Слайд»: два проёма, открывание от центра и тонированное стекло.',
    task:
      'Защитить веранду, сохранив панораму и возможность раскрывать проёмы.',
    result:
      'Защита от ветра и осадков без потери ощущения открытого пространства.',
    features: [
      'Открывание от центра в стороны',
      'Тонированное стекло',
    ],
    images: [
      {
        src: '/images/cases/terrace-moscow/main.webp',
        alt: 'Остекление веранды в Сертолово, основной вид',
      },
    ],
  },
  {
    id: 'case-2026-lenoblast-pavilion',
    active: true,
    year: '2026',
    type: 'Павильон / зона отдыха',
    system: 'Слайд',
    price: '450 000 ₽',
    title: 'Остекление павильона в Ленинградской области',
    description:
      'Безрамное остекление двух смежных фасадов системой «Слайд».',
    task:
      'Защитить зону отдыха от ветра и осадков, сохранив свет и обзор участка.',
    result:
      'Защита от непогоды и почти 180° обзора изнутри.',
    features: [
      'Система Слайд',
      'Два смежных фасада',
      'Панорамное остекление',
    ],
    images: [
      {
        src: '/images/cases/lenoblast-pavilion-2026/interior-panorama.webp',
        alt: 'Панорамное остекление павильона в Ленинградской области, вид изнутри на два смежных фасада',
      },
      {
        src: '/images/cases/lenoblast-pavilion-2026/exterior.webp',
        alt: 'Панорамное остекление павильона в Ленинградской области, вид снаружи',
      },
    ],
  },
];

// Newest object first: the most recent work is the strongest proof.
const visibleCases = cases
  .filter((item) => item.active && item.title && item.system && item.price && item.images.length > 0)
  .sort((a, b) => Number(b.year) - Number(a.year));
---

<section class="cases seams" id="cases" aria-labelledby="cases-title">
  <div class="shell">
    <header class="cases__head rise">
      <p class="eyebrow">Реализованные объекты</p>
      <h2 class="cases__title" id="cases-title">Паспорта проектов</h2>
      <p class="lead">
        Что за объект, какая система, сколько стоило.
      </p>
    </header>

    <div class="cases__list">
      {visibleCases.map((c) => (
        <article class="passport rise">
          <div
            class:list={['passport__media', { 'passport__media--multi': c.images.length > 1 }]}
            data-case-gallery={c.id}
          >
            <div class="passport__stage">
              <img
                class="passport__img"
                data-case-main-image
                src={c.images[0].src}
                alt={c.images[0].alt}
                loading="lazy"
                decoding="async"
              />

              {c.images.length > 1 && (
                <>
                  <button class="passport__nav passport__nav--prev" type="button" data-case-prev aria-label="Предыдущее фото">
                    <span aria-hidden="true">←</span>
                  </button>
                  <button class="passport__nav passport__nav--next" type="button" data-case-next aria-label="Следующее фото">
                    <span aria-hidden="true">→</span>
                  </button>
                </>
              )}
            </div>

            {c.images.length > 1 && (
              <div class="passport__thumbs" aria-label="Мини-галерея проекта">
                {c.images.map((image, index) => (
                  <button
                    class:list={['passport__thumb', { 'is-active': index === 0 }]}
                    type="button"
                    data-case-thumb
                    data-src={image.src}
                    data-alt={image.alt}
                    aria-label={`Показать фото ${index + 1}`}
                  >
                    <img src={image.src.replace(/\.(webp|jpe?g|png)$/i, '-thumb.webp')} alt="" loading="lazy" decoding="async" width="108" height="80" />
                  </button>
                ))}
              </div>
            )}
          </div>

          <div class="passport__sheet">
            <h3 class="passport__name">{c.title}</h3>

            <dl class="passport__specs figure">
              <div><dt>Объект</dt><dd>{c.type}</dd></div>
              <div><dt>Система</dt><dd>{c.system}</dd></div>
              <div><dt>Год</dt><dd>{c.year}</dd></div>
              <div class="passport__specs-total"><dt>Стоимость</dt><dd>{c.price}</dd></div>
            </dl>

            <div class="passport__notes">
              <p><span>Задача</span>{c.task}</p>
              <p><span>Решение</span>{c.description}</p>
              <p><span>Результат</span>{c.result}</p>
            </div>

            <ul class="passport__features">
              {c.features.map((feature) => <li>{feature}</li>)}
            </ul>

            <a class="passport__cta" href="#lead-form">
              Рассчитать похожий проект
              <span aria-hidden="true">→</span>
            </a>
          </div>
        </article>
      ))}

      {/* Stands in for the case we do not have yet, and puts the ask right where
          the visitor has just read three real prices. */}
      <article class="passport passport--ask rise">
        <div class="passport__sheet passport__sheet--ask">
          <p class="eyebrow">Ваш объект</p>
          <h3 class="passport__name">Сколько выйдет у вас?</h3>
          <p class="lead passport__ask-text">
            Пришлите фото или чертёж проёма — вернёмся с системой, сроком и
            стоимостью в течение рабочего дня.
          </p>

          <div class="passport__ask-actions">
            <a class="btn btn--solid" href="#lead-form">Отправить фото или чертёж</a>
            <a class="passport__ask-phone figure" href="tel:+78123307415" data-goal="phone_click_cases">
              +7 (812) 330-74-15
            </a>
          </div>
        </div>
      </article>
    </div>
  </div>
</section>

<script>
  const initCaseGalleries = () => {
    const galleries = document.querySelectorAll('[data-case-gallery]');

    galleries.forEach((gallery) => {
      const mainImage = gallery.querySelector('[data-case-main-image]');
      const prevButton = gallery.querySelector('[data-case-prev]');
      const nextButton = gallery.querySelector('[data-case-next]');
      const thumbs = Array.from(gallery.querySelectorAll('[data-case-thumb]'));

      if (!mainImage || thumbs.length < 2) return;

      let current = 0;
      let requestId = 0;
      const imageCache = new Map();

      const loadImage = (src) => {
        if (imageCache.has(src)) return imageCache.get(src);

        const request = new Promise((resolve, reject) => {
          const image = new Image();
          image.decoding = 'async';
          image.onload = () => {
            if (typeof image.decode === 'function') {
              image.decode().catch(() => {}).finally(() => resolve(src));
            } else {
              resolve(src);
            }
          };
          image.onerror = reject;
          image.src = src;
        });

        imageCache.set(src, request);
        request.catch(() => imageCache.delete(src));
        return request;
      };

      const warmAdjacent = (index) => {
        [index - 1, index + 1].forEach((nextIndex) => {
          const thumb = thumbs[(nextIndex + thumbs.length) % thumbs.length];
          if (thumb?.dataset.src) loadImage(thumb.dataset.src).catch(() => {});
        });
      };

      const setActive = async (index) => {
        current = (index + thumbs.length) % thumbs.length;
        const thumb = thumbs[current];
        const nextSrc = thumb.dataset.src;
        const thisRequest = ++requestId;

        thumbs.forEach((button, buttonIndex) => {
          button.classList.toggle('is-active', buttonIndex === current);
        });

        if (!nextSrc) return;
        gallery.classList.add('is-loading');
        gallery.setAttribute('aria-busy', 'true');

        try {
          await loadImage(nextSrc);
          if (thisRequest !== requestId) return;
          mainImage.classList.add('is-changing');
          await new Promise((resolve) => window.setTimeout(resolve, 80));
          if (thisRequest !== requestId) return;
          mainImage.src = nextSrc;
          mainImage.alt = thumb.dataset.alt || '';
          if (typeof mainImage.decode === 'function') await mainImage.decode().catch(() => {});
          window.requestAnimationFrame(() => mainImage.classList.remove('is-changing'));
          warmAdjacent(current);
        } catch (error) {
          console.warn('Не удалось загрузить изображение проекта', error);
        } finally {
          if (thisRequest === requestId) {
            gallery.classList.remove('is-loading');
            gallery.removeAttribute('aria-busy');
          }
        }
      };

      prevButton?.addEventListener('click', () => setActive(current - 1));
      nextButton?.addEventListener('click', () => setActive(current + 1));

      thumbs.forEach((button, index) => {
        button.addEventListener('click', () => setActive(index));
      });

      if (typeof IntersectionObserver === 'function') {
        const observer = new IntersectionObserver((entries) => {
          if (!entries.some((entry) => entry.isIntersecting)) return;
          warmAdjacent(current);
          observer.disconnect();
        }, { rootMargin: '240px 0px' });
        observer.observe(gallery);
      }
    });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCaseGalleries, { once: true });
  } else {
    initCaseGalleries();
  }
</script>
