---
import '../../styles/sections/cases.css';

const cases = [
  {
    id: 'case-2022-terrace-moscow',
    year: '2022',
    type: 'Веранда',
    system: 'Слайд',
    price: '880 000 ₽',
    title: 'Остекление веранды в Подмосковье',
    task: 'Остеклить веранду безрамной системой с раскрывающимися проёмами.',
    solution:
      'Использовали систему «Слайд»: панели перемещаются параллельно друг за другом и позволяют раскрывать проёмы в тёплую погоду.',
    result:
      'Веранда получила защиту от ветра и осадков, сохранив обзор и возможность раскрытия проёмов.',
    features: [
      '4 проёма',
      'Высота 256 см',
      'Длина 305 см',
      'Тонированное стекло',
      'Открывание от центра в стороны',
    ],
    image: '/images/cases/terrace-moscow.png',
    imageAlt: 'Остекление веранды в Подмосковье, система Слайд',
  },
  {
    id: 'case-2024-wooden-gazebo',
    year: '2024',
    type: 'Деревянная беседка / зона барбекю',
    system: 'Слайд',
    price: '480 000 ₽',
    title: 'Остекление в деревянной беседке',
    task:
      'Остеклить деревянную беседку, которая используется как зона барбекю весной, летом и осенью.',
    solution:
      'Смонтировали раздвижную систему «Слайд» и встроили москитную сетку-плиссе в один из проёмов.',
    result:
      'Беседка стала защищённой от ветра, осадков и насекомых, сохранив возможность проветривания и раскрытия проёмов.',
    features: [
      '4 проёма',
      'Высота 256 см',
      'Длина 305 см',
      'Москитная сетка-плиссе',
      'Раздвижное остекление в деревянной конструкции',
    ],
    image: '/images/cases/wooden-gazebo.jpg',
    imageAlt: 'Остекление в деревянной беседке, система Слайд',
  },
];
---

<section class="cases" id="cases" aria-labelledby="cases-title">
  <div class="cases__wrap">
    <div class="cases__head">
      <p class="cases__eyebrow">Реализованные объекты</p>
      <h2 class="cases__title" id="cases-title">Два реальных кейса с ценой, системой и деталями проекта</h2>
      <p class="cases__lead">
        Показаны только подтверждённые объекты Raluma: фото, год, система, цена,
        особенности, решение и результат.
      </p>
    </div>

    <div class="cases__grid">
      {cases.map((c) => (
        <article class="case-card">
          <div class="case-card__media">
            <img
              class="case-card__img"
              src={c.image}
              alt={c.imageAlt}
              loading="lazy"
              decoding="async"
            />
            <div class="case-card__badges" aria-hidden="true">
              <span class="case-card__year">{c.year}</span>
              <span class="case-card__system">{c.system}</span>
            </div>
          </div>

          <div class="case-card__body">
            <div class="case-card__meta">
              <span class="case-card__type">{c.type}</span>
            </div>

            <h3 class="case-card__name">{c.title}</h3>

            <div class="case-card__price" aria-label={`Цена проекта ${c.price}`}>
              <span class="case-card__price-label">Цена</span>
              <strong class="case-card__price-value">{c.price}</strong>
            </div>

            <div class="case-card__stack">
              <div class="case-card__copy-block">
                <span class="case-card__label">Задача</span>
                <p class="case-card__text">{c.task}</p>
              </div>

              <div class="case-card__copy-block">
                <span class="case-card__label">Решение</span>
                <p class="case-card__text">{c.solution}</p>
              </div>

              <div class="case-card__copy-block">
                <span class="case-card__label">Результат</span>
                <p class="case-card__text">{c.result}</p>
              </div>
            </div>

            <div class="case-card__chips" aria-label="Особенности проекта">
              {c.features.map((feature) => (
                <span class="case-card__chip">{feature}</span>
              ))}
            </div>

            <div class="case-card__actions">
              <a class="case-card__cta" href="#lead-form">Обсудить похожий проект</a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
