---
import '../../styles/sections/cases.css';

const cases = [
  {
    id: 'case-2024-wooden-gazebo',
    active: true,
    year: '2024',
    type: 'Деревянная беседка / зона барбекю',
    system: 'Слайд',
    price: '480 000 ₽',
    title: 'Остекление в деревянной беседке',
    description:
      'Система «Слайд» с москитной сеткой-плиссе.',
    task:
      'Защитить зону барбекю от ветра, осадков и насекомых, сохранив проветривание.',
    result:
      'Комфортное использование с весны до осени без потери ощущения открытого пространства.',
    features: [
      'Система Слайд',
      'Встроенная москитная сетка-плиссе',
      '4 + статичное остекление 2 яруса',
    ],
    images: [
      {
        src: '/images/cases/wooden-gazebo/main-1.jpg',
        alt: 'Остекление в деревянной беседке, основной вид',
      },
      {
        src: '/images/cases/wooden-gazebo/main-2.jpeg',
        alt: 'Остекление в деревянной беседке, второй ракурс',
      },
      {
        src: '/images/cases/wooden-gazebo/detail.jpg',
        alt: 'Остекление в деревянной беседке, деталь конструкции',
      },
    ],
  },
  {
    id: 'case-2022-terrace-moscow',
    active: true,
    year: '2022',
    type: 'Веранда',
    system: 'Слайд',
    price: '880 000 ₽',
    title: 'Остекление веранды в Подмосковье',
    description:
      'Система «Слайд»: два проёма, открывание от центра и тонированное стекло.',
    task:
      'Защитить веранду, сохранив панораму и возможность раскрывать проёмы.',
    result:
      'Защита от ветра и осадков без потери ощущения открытого пространства.',
    features: [
      'Открывание от центра в стороны',
      'Тонированное стекло',
    ],
    images: [
      {
        src: '/images/cases/terrace-moscow/main.webp',
        alt: 'Остекление веранды в Подмосковье, основной вид',
      },
    ],
  },
  {
    id: 'case-2026-lenoblast-pavilion',
    active: true,
    year: '2026',
    type: 'Павильон / зона отдыха',
    system: 'Слайд',
    price: '450 000 ₽',
    title: 'Остекление павильона в Ленинградской области',
    description:
      'Безрамное остекление двух смежных фасадов системой «Слайд».',
    task:
      'Защитить зону отдыха от ветра и осадков, сохранив свет и обзор участка.',
    result:
      'Закрытое от непогоды пространство с панорамным видом и возможностью раскрывать проёмы.',
    features: [
      'Система Слайд',
      'Два смежных фасада',
      'Панорамное остекление',
    ],
    images: [
      {
        src: '/images/cases/lenoblast-pavilion-2026/exterior.webp',
        alt: 'Панорамное остекление павильона в Ленинградской области, вид снаружи',
      },
      {
        src: '/images/cases/lenoblast-pavilion-2026/interior.webp',
        alt: 'Панорамное остекление павильона в Ленинградской области, вид изнутри',
      },
    ],
  },
];

const visibleCases = cases.filter(
  (item) => item.active && item.title && item.system && item.price && item.images.length > 0,
);
---

<section class="cases" id="cases" aria-labelledby="cases-title">
  <div class="cases__wrap">
    <div class="cases__head">
      <p class="cases__eyebrow">Реализованные объекты</p>
      <h2 class="cases__title" id="cases-title">Проекты с ценами и результатами</h2>
      <p class="cases__lead">
        Задача, решение и результат — без общих обещаний.
      </p>
    </div>

    <div class="cases__grid">
      {visibleCases.map((c) => (
        <article class="case-card">
          <div
            class:list={['case-card__media', { 'case-card__media--multi': c.images.length > 1 }]}
            data-case-gallery={c.id}
          >
            <div class="case-card__stage">
              <img
                class="case-card__img"
                data-case-main-image
                src={c.images[0].src}
                alt={c.images[0].alt}
                loading="lazy"
                decoding="async"
              />

              {c.images.length > 1 && (
                <>
                  <button class="case-card__nav case-card__nav--prev" type="button" data-case-prev aria-label="Предыдущее фото">
                    <span aria-hidden="true">‹</span>
                  </button>
                  <button class="case-card__nav case-card__nav--next" type="button" data-case-next aria-label="Следующее фото">
                    <span aria-hidden="true">›</span>
                  </button>
                </>
              )}
            </div>

            {c.images.length > 1 && (
              <div class="case-card__thumbs" aria-label="Мини-галерея проекта">
                {c.images.map((image, index) => (
                  <button
                    class:list={['case-card__thumb', { 'is-active': index === 0 }]}
                    type="button"
                    data-case-thumb
                    data-src={image.src}
                    data-alt={image.alt}
                    aria-label={`Показать фото ${index + 1}`}
                  >
                    <img src={image.src} alt="" loading="lazy" decoding="async" />
                  </button>
                ))}
              </div>
            )}

            <div class="case-card__badges" aria-hidden="true">
              <span class="case-card__year">{c.year}</span>
              <span class="case-card__system">{c.system}</span>
            </div>
          </div>

          <div class="case-card__body">
            <div class="case-card__meta">
              <span class="case-card__type">{c.type}</span>
            </div>

            <h3 class="case-card__name">{c.title}</h3>

            <div class="case-card__price" aria-label={`Стоимость проекта ${c.price}`}>
              <span class="case-card__price-label">Стоимость</span>
              <strong class="case-card__price-value">{c.price}</strong>
            </div>

            <div class="case-card__copy-block">
              <span class="case-card__label">Что сделали</span>
              <p class="case-card__text">{c.description}</p>
            </div>

            <div class="case-card__copy-block">
              <span class="case-card__label">Задача</span>
              <p class="case-card__text">{c.task}</p>
            </div>

            <div class="case-card__copy-block">
              <span class="case-card__label">Результат</span>
              <p class="case-card__text">{c.result}</p>
            </div>

            <div class="case-card__chips" aria-label="Особенности проекта">
              {c.features.map((feature) => (
                <span class="case-card__chip">{feature}</span>
              ))}
            </div>

            <div class="case-card__actions">
              <a class="case-card__cta" href="#lead-form">Рассчитать похожий проект</a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<script>
  const initCaseGalleries = () => {
    const galleries = document.querySelectorAll('[data-case-gallery]');

    galleries.forEach((gallery) => {
      const mainImage = gallery.querySelector('[data-case-main-image]');
      const prevButton = gallery.querySelector('[data-case-prev]');
      const nextButton = gallery.querySelector('[data-case-next]');
      const thumbs = Array.from(gallery.querySelectorAll('[data-case-thumb]'));

      if (!mainImage || thumbs.length < 2) return;

      let current = 0;
      let requestId = 0;
      const imageCache = new Map();

      const loadImage = (src) => {
        if (imageCache.has(src)) return imageCache.get(src);

        const request = new Promise((resolve, reject) => {
          const image = new Image();
          image.decoding = 'async';
          image.onload = () => {
            if (typeof image.decode === 'function') {
              image.decode().catch(() => {}).finally(() => resolve(src));
            } else {
              resolve(src);
            }
          };
          image.onerror = reject;
          image.src = src;
        });

        imageCache.set(src, request);
        request.catch(() => imageCache.delete(src));
        return request;
      };

      const warmAdjacent = (index) => {
        [index - 1, index + 1].forEach((nextIndex) => {
          const thumb = thumbs[(nextIndex + thumbs.length) % thumbs.length];
          if (thumb?.dataset.src) loadImage(thumb.dataset.src).catch(() => {});
        });
      };

      const setActive = async (index) => {
        current = (index + thumbs.length) % thumbs.length;
        const thumb = thumbs[current];
        const nextSrc = thumb.dataset.src;
        const thisRequest = ++requestId;

        thumbs.forEach((button, buttonIndex) => {
          button.classList.toggle('is-active', buttonIndex === current);
        });

        if (!nextSrc) return;
        gallery.classList.add('is-loading');
        gallery.setAttribute('aria-busy', 'true');

        try {
          await loadImage(nextSrc);
          if (thisRequest !== requestId) return;
          mainImage.classList.add('is-changing');
          await new Promise((resolve) => window.setTimeout(resolve, 80));
          if (thisRequest !== requestId) return;
          mainImage.src = nextSrc;
          mainImage.alt = thumb.dataset.alt || '';
          if (typeof mainImage.decode === 'function') await mainImage.decode().catch(() => {});
          window.requestAnimationFrame(() => mainImage.classList.remove('is-changing'));
          warmAdjacent(current);
        } catch (error) {
          console.warn('Не удалось загрузить изображение проекта', error);
        } finally {
          if (thisRequest === requestId) {
            gallery.classList.remove('is-loading');
            gallery.removeAttribute('aria-busy');
          }
        }
      };

      prevButton?.addEventListener('click', () => setActive(current - 1));
      nextButton?.addEventListener('click', () => setActive(current + 1));

      thumbs.forEach((button, index) => {
        button.addEventListener('click', () => setActive(index));
      });

      if (typeof IntersectionObserver === 'function') {
        const observer = new IntersectionObserver((entries) => {
          if (!entries.some((entry) => entry.isIntersecting)) return;
          warmAdjacent(current);
          observer.disconnect();
        }, { rootMargin: '240px 0px' });
        observer.observe(gallery);
      }
    });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCaseGalleries, { once: true });
  } else {
    initCaseGalleries();
  }
</script>
