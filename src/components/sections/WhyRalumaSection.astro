---
import '../../styles/sections/why-raluma.css';

const proofCards = [
  {
    id: 'experience',
    type: 'featured',
    label: 'Нам доверяют',
    title: '12 лет опыта и 4000+ реализованных проектов',
    text:
      'Решения Raluma проверены на большом количестве частных и коммерческих объектов. Это отработанная система с понятной технологией, монтажом и эксплуатацией.'
  },
  {
    id: 'production',
    type: 'standard',
    label: 'Производство',
    title: 'Собственное производство',
    text:
      'Контролируем качество, сроки и монтаж.'
  },
  {
    id: 'stock',
    type: 'standard',
    label: 'Поставки',
    title: 'Комплектующие всегда в наличии',
    text:
      'Снижаем риск задержек по поставке и делаем реализацию проекта более предсказуемой.'
  },
  {
    id: 'support',
    type: 'standard',
    label: 'Конструкция',
    title: 'Нижнеопорные системы',
    text:
      'Подходят для готовых объектов, где важно не перегружать кровлю и существующие конструкции.'
  },
  {
    id: 'anod',
    type: 'standard',
    label: 'Защита',
    title: 'Технология ANOD+',
    text:
      'Дополнительная защита алюминия от коррозии, износа и механических воздействий в реальной эксплуатации.'
  },
];
---

<section class="why-raluma" id="why-raluma" aria-labelledby="why-raluma-title">
  <div class="why-raluma__container">
    <div class="why-raluma__intro">
      <p class="why-raluma__eyebrow">Почему Raluma</p>

      <h2 class="why-raluma__title" id="why-raluma-title">
        Системы Raluma не подведут вас
      </h2>

      <p class="why-raluma__lead">
        Производство, инженерный подход, комплектующие в наличии и решения,
        рассчитанные на реальную эксплуатацию, а не только на красивую
        картинку в каталоге.
      </p>
    </div>

    <div class="why-raluma__grid">
      {proofCards.map((card, index) => (
        <article class={`proof-card proof-card--${card.type} proof-card--${card.id}`}>
          <div class="proof-card__head">
            <span class="proof-card__index">
              {String(index + 1).padStart(2, '0')}
            </span>

            <p class="proof-card__label">{card.label}</p>
          </div>

          <h3 class="proof-card__title">{card.title}</h3>

          <p class="proof-card__text">
            {card.text}
          </p>
        </article>
      ))}
    </div>

    <div class="why-raluma__footer">
      <div class="why-raluma__footer-copy">
        <p class="why-raluma__footer-title">
          Подбираем решение не по шаблону, а под конструкцию, сценарий
          использования и архитектуру объекта.
        </p>

        <p class="why-raluma__footer-text">
          Учитываем проём, нагрузку, тип объекта, монтажные ограничения
          и то, как системой будут пользоваться каждый день.
        </p>
      </div>

      <a class="why-raluma__cta" href="#lead-form">
        Подобрать систему
      </a>
    </div>
  </div>
</section>
