<style is:global>
  .pergola-roof__control-panel {
    display: grid;
    gap: 20px;
    min-width: 0;
  }

  .pergola-roof__interaction {
    display: grid;
    gap: 14px;
    padding: 20px;
    border: 1px solid var(--c-seam);
    background: var(--c-light-raised);
  }

  .pergola-roof__interaction-copy {
    display: grid;
    gap: 6px;
  }

  .pergola-roof__interaction-copy strong {
    font-family: var(--f-display);
    font-size: 22px;
    font-weight: 300;
    line-height: 1.15;
    color: var(--c-ink);
  }

  .pergola-roof__interaction-copy span {
    font-size: 14px;
    line-height: 1.5;
    color: var(--c-ink-soft);
  }

  .pergola-roof__quick-switch {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 8px;
  }

  .pergola-roof__quick-button {
    min-height: 48px;
    padding: 10px 12px;
    border: 1px solid var(--c-seam);
    border-radius: 2px;
    background: var(--c-light);
    color: var(--c-ink);
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: background-color var(--dur-fast) ease, color var(--dur-fast) ease, border-color var(--dur-fast) ease;
  }

  .pergola-roof__quick-button:hover,
  .pergola-roof__quick-button.is-active {
    border-color: var(--c-edge);
    background: var(--c-edge);
    color: #fff;
  }

  .pergola-roof__status {
    position: absolute;
    left: 18px;
    bottom: 18px;
    z-index: 2;
    margin: 0;
    padding: 10px 12px;
    border: 1px solid rgba(255,255,255,.42);
    background: rgba(14,20,19,.78);
    color: #fff;
    font-size: 13px;
    line-height: 1.2;
    backdrop-filter: blur(10px);
  }

  .pergola-roof__tab {
    transition: background-color var(--dur-fast) ease, border-color var(--dur-fast) ease;
  }

  .pergola-roof__tab:hover,
  .pergola-roof__tab.is-active {
    background: rgba(47, 109, 95, 0.07);
  }

  .pergola-glazing__cta-row {
    grid-column: 2;
    display: flex;
    justify-content: flex-start;
    margin-top: -4px;
  }

  .pergola-glazing__cta-row .btn {
    margin: 0 !important;
    justify-content: space-between;
    gap: 20px;
  }

  .pergola-glazing__cta-arrow {
    display: inline-block;
    flex: 0 0 auto;
    font-size: 1.15em;
    line-height: 1;
    transition: transform var(--dur-fast) ease;
  }

  .pergola-glazing__cta-row .btn:hover .pergola-glazing__cta-arrow {
    transform: translate(2px, -2px);
  }

  @media (max-width: 900px) {
    .pergola-glazing__cta-row {
      grid-column: 1;
      margin-top: 6px;
    }
  }

  @media (max-width: 820px) {
    .pergola-roof__control-panel {
      gap: 14px;
    }

    .pergola-roof__interaction {
      order: -1;
      padding: 18px;
    }

    .pergola-roof__interaction-copy strong {
      font-size: 20px;
    }

    .pergola-roof__interaction-copy span {
      font-size: 15px;
    }

    .pergola-roof__quick-switch {
      gap: 6px;
    }

    .pergola-roof__quick-button {
      min-height: 52px;
      padding: 10px 8px;
      font-size: 12px;
    }

    .pergola-roof__status {
      left: 12px;
      bottom: 12px;
      max-width: calc(100% - 94px);
      font-size: 12px;
    }

    .pergola-roof__tab {
      padding-inline: 16px !important;
    }

    .pergola-glazing__cta-row,
    .pergola-glazing__cta-row .btn {
      width: 100%;
    }
  }
</style>

<script is:inline>
  (function () {
    function replaceSizeImage() {
      var cards = Array.from(document.querySelectorAll('.pergola-sizes__grid .pergola-size'));
      var card = cards.find(function (candidate) {
        var label = candidate.querySelector('.pergola-size__body strong');
        return label && (label.textContent || '').replace(/\s+/g, ' ').trim() === '4 × 5 м';
      });
      var image = card && card.querySelector('.pergola-size__media img');
      if (!image) return;

      image.src = '/images/pergolas/3.jpg.webp';
      image.removeAttribute('srcset');
      image.alt = 'Биоклиматическая пергола Raluma размером 4 × 5 м';
      image.dataset.sizeImage = '4x5';
    }

    function initRoofInteraction() {
      var section = document.querySelector('[data-roof-section]');
      if (!section || section.dataset.enhancedRoof === 'true') return;

      var layout = section.querySelector('.pergola-roof__layout');
      var controls = section.querySelector('.pergola-roof__controls');
      var visual = section.querySelector('[data-roof-visual]');
      var angle = section.querySelector('[data-roof-angle]');
      var tabs = Array.from(section.querySelectorAll('[data-roof-tab]'));
      if (!layout || !controls || !visual || tabs.length === 0) return;

      section.dataset.enhancedRoof = 'true';

      var labels = {
        closed: 'Закрыта',
        shade: 'Полуоткрыта',
        open: 'Открыта'
      };

      var statuses = {
        closed: 'Сейчас: крыша полностью закрыта',
        shade: 'Сейчас: тень и вентиляция',
        open: 'Сейчас: крыша полностью открыта'
      };

      var panel = document.createElement('div');
      panel.className = 'pergola-roof__control-panel';
      controls.parentNode.insertBefore(panel, controls);

      var interaction = document.createElement('div');
      interaction.className = 'pergola-roof__interaction';
      interaction.innerHTML = '<div class="pergola-roof__interaction-copy"><strong>Выберите состояние крыши</strong><span>Нажмите на положение ламелей и посмотрите, как меняется пространство.</span></div><div class="pergola-roof__quick-switch" role="group" aria-label="Быстрое переключение положения крыши"></div>';

      var quickSwitch = interaction.querySelector('.pergola-roof__quick-switch');
      var quickButtons = [];

      tabs.forEach(function (tab) {
        var state = tab.getAttribute('data-roof-tab') || 'closed';
        var button = document.createElement('button');
        button.type = 'button';
        button.className = 'pergola-roof__quick-button';
        button.dataset.quickRoof = state;
        button.textContent = labels[state] || state;
        button.addEventListener('click', function () {
          stopDemo();
          tab.click();
        });
        quickSwitch.appendChild(button);
        quickButtons.push(button);
      });

      panel.appendChild(interaction);
      panel.appendChild(controls);

      var status = document.createElement('p');
      status.className = 'pergola-roof__status';
      visual.appendChild(status);

      var demoTimers = [];
      var demoStopped = false;

      function clearDemoTimers() {
        demoTimers.forEach(function (timer) { window.clearTimeout(timer); });
        demoTimers = [];
      }

      function stopDemo() {
        demoStopped = true;
        clearDemoTimers();
      }

      function syncAux(state) {
        quickButtons.forEach(function (button) {
          var active = button.dataset.quickRoof === state;
          button.classList.toggle('is-active', active);
          button.setAttribute('aria-pressed', String(active));
        });
        status.textContent = statuses[state] || '';
      }

      function applyDemoState(state) {
        var target = tabs.find(function (tab) {
          return tab.getAttribute('data-roof-tab') === state;
        });
        if (!target) return;

        tabs.forEach(function (tab) {
          var active = tab === target;
          tab.classList.toggle('is-active', active);
          tab.setAttribute('aria-selected', String(active));
        });
        visual.setAttribute('data-roof-visual', state);
        if (angle) angle.textContent = target.getAttribute('data-angle') || '';
        syncAux(state);
      }

      tabs.forEach(function (tab) {
        tab.addEventListener('click', function () {
          stopDemo();
          syncAux(tab.getAttribute('data-roof-tab') || 'closed');
        });
      });

      var initial = tabs.find(function (tab) { return tab.classList.contains('is-active'); });
      syncAux(initial ? initial.getAttribute('data-roof-tab') || 'closed' : 'closed');

      var reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      var demoSeen = false;
      try { demoSeen = sessionStorage.getItem('raluma-roof-demo') === '1'; } catch (_) {}

      if (!reducedMotion && !demoSeen && typeof IntersectionObserver === 'function') {
        var observer = new IntersectionObserver(function (entries) {
          if (!entries.some(function (entry) { return entry.isIntersecting; })) return;
          observer.disconnect();
          try { sessionStorage.setItem('raluma-roof-demo', '1'); } catch (_) {}

          var sequence = ['shade', 'open', 'closed'];
          sequence.forEach(function (state, index) {
            demoTimers.push(window.setTimeout(function () {
              if (!demoStopped) applyDemoState(state);
            }, 700 + index * 1100));
          });
        }, { threshold: 0.35 });
        observer.observe(section);
      }
    }

    function moveGlazingButton() {
      var layout = document.querySelector('.pergola-glazing__layout');
      var systems = layout && layout.querySelector('.pergola-glazing__systems');
      var link = layout && layout.querySelector('.pergola-glazing__intro .btn');
      if (!layout || !systems || !link || layout.querySelector('.pergola-glazing__cta-row')) return;

      if (!link.querySelector('.pergola-glazing__cta-arrow')) {
        var arrow = document.createElement('span');
        arrow.className = 'pergola-glazing__cta-arrow';
        arrow.setAttribute('aria-hidden', 'true');
        arrow.textContent = '↗';
        link.appendChild(arrow);
      }

      var row = document.createElement('div');
      row.className = 'pergola-glazing__cta-row';
      row.appendChild(link);
      systems.insertAdjacentElement('afterend', row);
    }

    function init() {
      replaceSizeImage();
      initRoofInteraction();
      moveGlazingButton();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init, { once: true });
    } else {
      init();
    }
  })();
</script>
