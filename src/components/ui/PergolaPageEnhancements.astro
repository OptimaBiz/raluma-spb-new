<style is:global>
  /* The legacy CSS roof illustration must never be visible. */
  .pergola-roof .pergola-roof__frame,
  .pergola-roof .pergola-roof__angle {
    display: none !important;
  }

  .pergola-roof[data-roof-real-photos="v5"] .pergola-roof__layout {
    align-items: stretch;
  }

  .pergola-roof[data-roof-real-photos="v5"] .pergola-roof__visual {
    position: relative;
    width: 100%;
    min-height: 0 !important;
    aspect-ratio: 3 / 2;
    overflow: hidden;
    border: 1px solid var(--c-seam);
    background: #101615;
    isolation: isolate;
  }

  .pergola-roof__photo-stack,
  .pergola-roof__photo,
  .pergola-roof__photo-crop {
    position: absolute;
    inset: 0;
  }

  .pergola-roof__photo-stack {
    z-index: 1;
    overflow: hidden;
  }

  .pergola-roof__photo {
    z-index: 1;
    overflow: hidden;
    opacity: 0;
    visibility: hidden;
    transform: scale(1.025);
    transition:
      opacity 520ms cubic-bezier(.2,.8,.2,1),
      transform 820ms cubic-bezier(.2,.8,.2,1),
      visibility 0s linear 520ms;
    pointer-events: none;
  }

  .pergola-roof__photo.is-active {
    z-index: 2;
    opacity: 1;
    visibility: visible;
    transform: scale(1);
    transition:
      opacity 520ms cubic-bezier(.2,.8,.2,1),
      transform 820ms cubic-bezier(.2,.8,.2,1),
      visibility 0s linear 0s;
  }

  .pergola-roof__photo-crop {
    overflow: hidden;
    background: #101615;
  }

  .pergola-roof__photo-crop img {
    position: absolute;
    left: 0;
    display: block;
    width: 100%;
    max-width: none;
    height: 300%;
    object-fit: fill;
    transform: none !important;
  }

  [data-roof-photo="closed"] .pergola-roof__photo-crop img { top: 0; }
  [data-roof-photo="shade"] .pergola-roof__photo-crop img { top: -100%; }
  [data-roof-photo="open"] .pergola-roof__photo-crop img { top: -200%; }

  .pergola-roof__status {
    position: absolute;
    left: 18px;
    bottom: 18px;
    z-index: 5;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    max-width: calc(100% - 112px);
    margin: 0;
    padding: 11px 14px;
    border: 1px solid rgba(255,255,255,.44);
    background: rgba(14,20,19,.84);
    color: #fff;
    font-size: 13px;
    line-height: 1.25;
    backdrop-filter: blur(10px);
  }

  .pergola-roof__status::before {
    content: '';
    flex: 0 0 auto;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--c-edge-on-deep);
  }

  .pergola-roof__progress {
    position: absolute;
    right: 18px;
    bottom: 22px;
    z-index: 5;
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 8px 10px;
    border: 1px solid rgba(255,255,255,.32);
    background: rgba(14,20,19,.72);
    backdrop-filter: blur(8px);
  }

  .pergola-roof__progress span {
    display: block;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: rgba(255,255,255,.42);
    transition: width 220ms ease, background-color 220ms ease;
  }

  .pergola-roof__progress span.is-active {
    width: 22px;
    border-radius: 99px;
    background: var(--c-edge-on-deep);
  }

  .pergola-roof__instruction {
    display: grid;
    gap: 6px;
    margin-bottom: 10px;
    padding: 0 0 18px;
    border-bottom: 1px solid var(--c-seam);
  }

  .pergola-roof__instruction strong {
    font-family: var(--f-display);
    font-size: 24px;
    font-weight: 300;
    line-height: 1.15;
    color: var(--c-ink);
  }

  .pergola-roof__instruction span {
    font-size: 14px;
    line-height: 1.5;
    color: var(--c-ink-soft);
  }

  .pergola-roof[data-roof-real-photos="v5"] .pergola-roof__controls {
    display: grid;
    gap: 10px;
    border: 0;
  }

  .pergola-roof[data-roof-real-photos="v5"] .pergola-roof__tab {
    position: relative;
    display: grid;
    grid-template-columns: 42px minmax(0, 1fr) auto;
    gap: 14px;
    align-items: start;
    width: 100%;
    padding: 18px;
    border: 1px solid var(--c-seam);
    background: var(--c-light-raised);
    color: var(--c-ink);
    text-align: left;
    cursor: pointer;
    transition:
      border-color 180ms ease,
      background-color 180ms ease,
      transform 180ms ease;
  }

  .pergola-roof[data-roof-real-photos="v5"] .pergola-roof__tab:hover {
    border-color: rgba(47,109,95,.48);
    transform: translateX(2px);
  }

  .pergola-roof[data-roof-real-photos="v5"] .pergola-roof__tab.is-active {
    border-color: var(--c-edge);
    background: rgba(47,109,95,.08);
  }

  .pergola-roof[data-roof-real-photos="v5"] .pergola-roof__tab::after {
    content: '→';
    align-self: center;
    color: var(--c-ink-mute);
    font-size: 18px;
    transition: transform 180ms ease, color 180ms ease;
  }

  .pergola-roof[data-roof-real-photos="v5"] .pergola-roof__tab.is-active::after {
    color: var(--c-edge);
    transform: translateX(3px);
  }

  .pergola-roof[data-roof-real-photos="v5"] .pergola-roof__tab-number {
    padding-top: 2px;
    color: var(--c-ink-mute);
  }

  .pergola-roof[data-roof-real-photos="v5"] .pergola-roof__tab.is-active .pergola-roof__tab-number,
  .pergola-roof[data-roof-real-photos="v5"] .pergola-roof__tab.is-active strong {
    color: var(--c-edge);
  }

  .pergola-roof[data-roof-real-photos="v5"] .pergola-roof__tab strong {
    display: block;
    font-size: 18px;
    font-weight: 500;
    line-height: 1.25;
  }

  .pergola-roof[data-roof-real-photos="v5"] .pergola-roof__tab small {
    display: block;
    max-width: 46ch;
    margin-top: 7px;
    font-size: 14px;
    line-height: 1.5;
    color: var(--c-ink-soft);
  }

  /* Sizes: three cards stay proportional and show every product in full. */
  .pergola-sizes .pergola-sizes__grid {
    display: grid !important;
    grid-template-columns: repeat(3, minmax(0, 1fr)) !important;
    gap: clamp(14px, 2vw, 24px) !important;
    align-items: stretch;
    border: 0 !important;
    background: transparent !important;
  }

  .pergola-sizes .pergola-size {
    min-width: 0;
    overflow: hidden;
    border: 1px solid var(--c-seam);
    background: var(--c-light);
  }

  .pergola-sizes .pergola-size__media {
    display: grid;
    place-items: center;
    width: 100%;
    aspect-ratio: 4 / 3;
    padding: clamp(12px, 1.8vw, 24px);
    overflow: hidden;
    background: #f2f4f2;
    border-bottom: 1px solid var(--c-seam);
  }

  .pergola-sizes .pergola-size__media img {
    width: 100% !important;
    height: 100% !important;
    max-width: 100%;
    object-fit: contain !important;
    object-position: center !important;
    transform: none !important;
  }

  .pergola-sizes .pergola-size__body {
    padding: clamp(18px, 2vw, 26px) !important;
  }

  .pergola-sizes .pergola-size--custom {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    column-gap: 28px;
    align-items: center;
    padding: clamp(24px, 3vw, 38px);
  }

  .pergola-sizes .pergola-size--custom .eyebrow,
  .pergola-sizes .pergola-size--custom h3,
  .pergola-sizes .pergola-size--custom p {
    grid-column: 1;
  }

  .pergola-sizes .pergola-size--custom .btn {
    grid-column: 2;
    grid-row: 1 / span 3;
    align-self: center;
    margin: 0;
  }

  .pergola-glazing__cta-row {
    grid-column: 2;
    display: flex;
    justify-content: flex-start;
    margin-top: -4px;
  }

  .pergola-glazing__cta-row .btn {
    margin: 0 !important;
    justify-content: space-between;
    gap: 20px;
  }

  .pergola-glazing__cta-arrow {
    display: inline-block;
    flex: 0 0 auto;
    font-size: 1.15em;
    line-height: 1;
    transition: transform var(--dur-fast) ease;
  }

  .pergola-glazing__cta-row .btn:hover .pergola-glazing__cta-arrow {
    transform: translate(2px, -2px);
  }

  @media (max-width: 980px) {
    .pergola-sizes .pergola-sizes__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
    }

    .pergola-sizes .pergola-size:nth-child(3) {
      grid-column: 1 / -1;
      width: min(100%, 620px);
      justify-self: center;
    }

    .pergola-glazing__cta-row {
      grid-column: 1;
      margin-top: 6px;
    }
  }

  @media (max-width: 820px) {
    .pergola-roof[data-roof-real-photos="v5"] .pergola-roof__layout {
      gap: 22px !important;
    }

    .pergola-roof[data-roof-real-photos="v5"] .pergola-roof__visual {
      width: 100%;
      aspect-ratio: 3 / 2;
    }

    .pergola-roof__status {
      left: 12px;
      bottom: 12px;
      max-width: calc(100% - 94px);
      padding: 9px 11px;
      font-size: 12px;
    }

    .pergola-roof__progress {
      right: 12px;
      bottom: 14px;
    }

    .pergola-roof__instruction {
      margin-bottom: 2px;
      padding-bottom: 16px;
    }

    .pergola-roof__instruction strong {
      font-size: 21px;
    }

    .pergola-roof__instruction span {
      font-size: 15px;
    }

    .pergola-roof[data-roof-real-photos="v5"] .pergola-roof__tab {
      grid-template-columns: 34px minmax(0, 1fr) auto !important;
      gap: 11px;
      padding: 16px !important;
      transform: none !important;
    }

    .pergola-roof[data-roof-real-photos="v5"] .pergola-roof__tab strong {
      font-size: 17px;
    }

    .pergola-roof[data-roof-real-photos="v5"] .pergola-roof__tab small {
      font-size: 15px;
      line-height: 1.5;
    }

    .pergola-glazing__cta-row,
    .pergola-glazing__cta-row .btn {
      width: 100%;
    }
  }

  @media (max-width: 640px) {
    .pergola-sizes .pergola-sizes__grid {
      grid-template-columns: 1fr !important;
      gap: 16px !important;
    }

    .pergola-sizes .pergola-size:nth-child(3) {
      grid-column: auto;
      width: 100%;
    }

    .pergola-sizes .pergola-size__media {
      aspect-ratio: 4 / 3;
      padding: 16px;
    }

    .pergola-sizes .pergola-size--custom {
      grid-column: auto;
      display: block;
      padding: 24px;
    }

    .pergola-sizes .pergola-size--custom .btn {
      width: 100%;
      margin-top: 22px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pergola-roof__photo,
    .pergola-roof[data-roof-real-photos="v5"] .pergola-roof__tab {
      transition: none !important;
    }
  }
</style>

<script is:inline>
  (function () {
    function replaceSizeImage() {
      var cards = Array.from(document.querySelectorAll('.pergola-sizes__grid .pergola-size'));
      var card = cards.find(function (candidate) {
        var label = candidate.querySelector('.pergola-size__body strong');
        return label && (label.textContent || '').replace(/\s+/g, ' ').trim() === '4 × 5 м';
      });
      var image = card && card.querySelector('.pergola-size__media img');
      if (!image) return;

      image.src = '/images/pergolas/3.jpg.webp';
      image.removeAttribute('srcset');
      image.alt = 'Биоклиматическая пергола Raluma размером 4 × 5 м';
      image.dataset.sizeImage = '4x5';
    }

    function initRoofInteraction() {
      var section = document.querySelector('[data-roof-section]');
      if (!section || section.dataset.roofPhotosBound === 'true') return;

      var controls = section.querySelector('.pergola-roof__controls');
      var visual = section.querySelector('[data-roof-visual]');
      var tabs = Array.from(section.querySelectorAll('[data-roof-tab]'));
      if (!controls || !visual || tabs.length !== 3) return;

      section.dataset.roofPhotosBound = 'true';
      section.dataset.roofRealPhotos = 'v5';

      var states = {
        closed: {
          number: '01',
          title: 'Закрыта',
          text: 'Ламели сомкнуты: защита от дождя и прямого солнца.',
          status: 'Крыша закрыта · защита от осадков',
          alt: 'Пергола с полностью закрытой ламельной крышей'
        },
        shade: {
          number: '02',
          title: 'Полуоткрыта',
          text: 'Ламели под углом: мягкая тень и естественная вентиляция.',
          status: 'Крыша полуоткрыта · тень и вентиляция',
          alt: 'Пергола с полуоткрытой ламельной крышей'
        },
        open: {
          number: '03',
          title: 'Открыта',
          text: 'Ламели раскрыты: максимум света и открытого неба.',
          status: 'Крыша открыта · максимум света',
          alt: 'Пергола с полностью открытой ламельной крышей'
        }
      };

      var preload = document.createElement('link');
      preload.rel = 'preload';
      preload.as = 'image';
      preload.href = '/images/pergolas/roof-states.webp?v=5';
      document.head.appendChild(preload);

      var stack = document.createElement('div');
      stack.className = 'pergola-roof__photo-stack';
      stack.setAttribute('aria-label', 'Три фотографии положений ламельной крыши');

      var photos = {};
      var images = [];

      Object.keys(states).forEach(function (state) {
        var layer = document.createElement('div');
        layer.className = 'pergola-roof__photo' + (state === 'closed' ? ' is-active' : '');
        layer.setAttribute('data-roof-photo', state);
        layer.setAttribute('aria-hidden', state === 'closed' ? 'false' : 'true');

        var crop = document.createElement('div');
        crop.className = 'pergola-roof__photo-crop';

        var image = document.createElement('img');
        image.src = '/images/pergolas/roof-states.webp?v=5';
        image.alt = states[state].alt;
        image.width = 960;
        image.height = 1920;
        image.loading = 'eager';
        image.decoding = 'async';

        crop.appendChild(image);
        layer.appendChild(crop);
        stack.appendChild(layer);
        photos[state] = layer;
        images.push(image);
      });

      var status = document.createElement('p');
      status.className = 'pergola-roof__status';
      status.setAttribute('aria-live', 'polite');
      status.textContent = states.closed.status;

      var progress = document.createElement('div');
      progress.className = 'pergola-roof__progress';
      progress.setAttribute('aria-hidden', 'true');

      var dots = {};
      Object.keys(states).forEach(function (state) {
        var dot = document.createElement('span');
        if (state === 'closed') dot.className = 'is-active';
        dot.setAttribute('data-roof-dot', state);
        progress.appendChild(dot);
        dots[state] = dot;
      });

      visual.replaceChildren(stack, status, progress);
      visual.setAttribute('role', 'img');
      visual.setAttribute('aria-label', states.closed.alt);

      if (!controls.querySelector('.pergola-roof__instruction')) {
        var instruction = document.createElement('div');
        instruction.className = 'pergola-roof__instruction';
        instruction.innerHTML = '<strong>Выберите положение крыши</strong><span>Нажмите на режим — фотография плавно изменится.</span>';
        controls.insertBefore(instruction, controls.firstChild);
      }

      tabs.forEach(function (tab) {
        var state = tab.getAttribute('data-roof-tab') || 'closed';
        var config = states[state];
        var number = tab.querySelector('.pergola-roof__tab-number');
        var title = tab.querySelector('strong');
        var text = tab.querySelector('small');
        if (number) number.textContent = config.number;
        if (title) title.textContent = config.title;
        if (text) text.textContent = config.text;
      });

      var demoTimers = [];
      var demoStopped = false;

      function clearDemo() {
        demoTimers.forEach(function (timer) { window.clearTimeout(timer); });
        demoTimers = [];
      }

      function stopDemo() {
        demoStopped = true;
        clearDemo();
      }

      function setState(state, manual) {
        if (!states[state]) return;
        if (manual) stopDemo();

        visual.setAttribute('data-roof-visual', state);
        visual.setAttribute('aria-label', states[state].alt);
        status.textContent = states[state].status;

        Object.keys(photos).forEach(function (photoState) {
          var active = photoState === state;
          photos[photoState].classList.toggle('is-active', active);
          photos[photoState].setAttribute('aria-hidden', String(!active));
          dots[photoState].classList.toggle('is-active', active);
        });

        tabs.forEach(function (tab) {
          var active = tab.getAttribute('data-roof-tab') === state;
          tab.classList.toggle('is-active', active);
          tab.setAttribute('aria-selected', String(active));
          tab.setAttribute('tabindex', active ? '0' : '-1');
        });
      }

      tabs.forEach(function (tab, index) {
        tab.addEventListener('pointerdown', stopDemo, { passive: true });

        tab.addEventListener('click', function () {
          setState(tab.getAttribute('data-roof-tab') || 'closed', true);
        });

        tab.addEventListener('keydown', function (event) {
          if (event.key !== 'ArrowLeft' && event.key !== 'ArrowRight') return;
          event.preventDefault();
          stopDemo();
          var delta = event.key === 'ArrowRight' ? 1 : -1;
          var next = tabs[(index + delta + tabs.length) % tabs.length];
          next.focus();
          setState(next.getAttribute('data-roof-tab') || 'closed', true);
        });
      });

      setState('closed', false);

      function startDemoWhenVisible() {
        var reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        var demoSeen = false;
        try { demoSeen = sessionStorage.getItem('raluma-roof-real-photos-v5') === '1'; } catch (_) {}
        if (reducedMotion || demoSeen || typeof IntersectionObserver !== 'function') return;

        var observer = new IntersectionObserver(function (entries) {
          if (!entries.some(function (entry) { return entry.isIntersecting; })) return;
          observer.disconnect();
          try { sessionStorage.setItem('raluma-roof-real-photos-v5', '1'); } catch (_) {}

          [
            ['shade', 900],
            ['open', 2400],
            ['closed', 4100]
          ].forEach(function (step) {
            demoTimers.push(window.setTimeout(function () {
              if (!demoStopped) setState(step[0], false);
            }, step[1]));
          });
        }, { threshold: 0.38 });

        observer.observe(section);
      }

      var readiness = images.map(function (image) {
        if (image.complete && image.naturalWidth) return Promise.resolve();
        return new Promise(function (resolve) {
          image.addEventListener('load', resolve, { once: true });
          image.addEventListener('error', resolve, { once: true });
        });
      });

      Promise.all(readiness).then(startDemoWhenVisible);
    }

    function moveGlazingButton() {
      var layout = document.querySelector('.pergola-glazing__layout');
      var systems = layout && layout.querySelector('.pergola-glazing__systems');
      var link = layout && layout.querySelector('.pergola-glazing__intro .btn');
      if (!layout || !systems || !link || layout.querySelector('.pergola-glazing__cta-row')) return;

      if (!link.querySelector('.pergola-glazing__cta-arrow')) {
        var arrow = document.createElement('span');
        arrow.className = 'pergola-glazing__cta-arrow';
        arrow.setAttribute('aria-hidden', 'true');
        arrow.textContent = '↗';
        link.appendChild(arrow);
      }

      var row = document.createElement('div');
      row.className = 'pergola-glazing__cta-row';
      row.appendChild(link);
      systems.insertAdjacentElement('afterend', row);
    }

    function init() {
      replaceSizeImage();
      // Roof interaction is owned exclusively by PergolaRoofPhotosV7.astro.
      moveGlazingButton();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init, { once: true });
    } else {
      init();
    }
  })();
</script>
