<style is:global>
  /* Roof states: keep the original fallback visible until the real image is decoded. */
  .pergola-roof[data-roof-stable="true"] .pergola-roof__layout {
    align-items: stretch;
  }

  .pergola-roof[data-roof-stable="true"] .pergola-roof__visual {
    position: relative;
    min-height: 0 !important;
    aspect-ratio: 3 / 2;
    overflow: hidden;
    border: 1px solid var(--c-seam);
    background: #eef2f0;
    isolation: isolate;
  }

  .pergola-roof__sprite-viewport {
    position: absolute;
    inset: 0;
    z-index: 1;
    overflow: hidden;
    background: #eef2f0;
  }

  .pergola-roof__sprite-image {
    position: absolute;
    top: 0;
    left: 0;
    display: block;
    width: 100%;
    max-width: none;
    height: 300%;
    object-fit: fill;
    transform: translate3d(0, 0, 0);
    transition: transform 620ms cubic-bezier(.2,.8,.2,1);
    will-change: transform;
  }

  .pergola-roof[data-roof-stable="true"] [data-roof-visual="shade"] .pergola-roof__sprite-image {
    transform: translate3d(0, -33.333333%, 0);
  }

  .pergola-roof[data-roof-stable="true"] [data-roof-visual="open"] .pergola-roof__sprite-image {
    transform: translate3d(0, -66.666667%, 0);
  }

  .pergola-roof__status {
    position: absolute;
    left: 18px;
    bottom: 18px;
    z-index: 4;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    max-width: calc(100% - 36px);
    margin: 0;
    padding: 11px 14px;
    border: 1px solid rgba(255,255,255,.44);
    background: rgba(14,20,19,.82);
    color: #fff;
    font-size: 13px;
    line-height: 1.25;
    backdrop-filter: blur(10px);
  }

  .pergola-roof__status::before {
    content: '';
    flex: 0 0 auto;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--c-edge-on-deep);
  }

  .pergola-roof__instruction {
    display: grid;
    gap: 6px;
    margin-bottom: 10px;
    padding: 0 0 18px;
    border-bottom: 1px solid var(--c-seam);
  }

  .pergola-roof__instruction strong {
    font-family: var(--f-display);
    font-size: 24px;
    font-weight: 300;
    line-height: 1.15;
    color: var(--c-ink);
  }

  .pergola-roof__instruction span {
    font-size: 14px;
    line-height: 1.5;
    color: var(--c-ink-soft);
  }

  .pergola-roof[data-roof-stable="true"] .pergola-roof__controls {
    display: grid;
    gap: 10px;
    border: 0;
  }

  .pergola-roof[data-roof-stable="true"] .pergola-roof__tab {
    position: relative;
    display: grid;
    grid-template-columns: 42px minmax(0, 1fr) auto;
    gap: 14px;
    align-items: start;
    width: 100%;
    padding: 18px;
    border: 1px solid var(--c-seam);
    background: var(--c-light-raised);
    color: var(--c-ink);
    text-align: left;
    cursor: pointer;
    transition: border-color 180ms ease, background-color 180ms ease, transform 180ms ease;
  }

  .pergola-roof[data-roof-stable="true"] .pergola-roof__tab:hover {
    border-color: rgba(47,109,95,.48);
    transform: translateX(2px);
  }

  .pergola-roof[data-roof-stable="true"] .pergola-roof__tab.is-active {
    border-color: var(--c-edge);
    background: rgba(47,109,95,.08);
  }

  .pergola-roof[data-roof-stable="true"] .pergola-roof__tab::after {
    content: '→';
    align-self: center;
    color: var(--c-ink-mute);
    font-size: 18px;
    transition: transform 180ms ease, color 180ms ease;
  }

  .pergola-roof[data-roof-stable="true"] .pergola-roof__tab.is-active::after {
    color: var(--c-edge);
    transform: translateX(3px);
  }

  .pergola-roof[data-roof-stable="true"] .pergola-roof__tab-number {
    padding-top: 2px;
    color: var(--c-ink-mute);
  }

  .pergola-roof[data-roof-stable="true"] .pergola-roof__tab.is-active .pergola-roof__tab-number,
  .pergola-roof[data-roof-stable="true"] .pergola-roof__tab.is-active strong {
    color: var(--c-edge);
  }

  .pergola-roof[data-roof-stable="true"] .pergola-roof__tab strong {
    display: block;
    font-size: 18px;
    font-weight: 500;
    line-height: 1.25;
  }

  .pergola-roof[data-roof-stable="true"] .pergola-roof__tab small {
    display: block;
    max-width: 46ch;
    margin-top: 7px;
    font-size: 14px;
    line-height: 1.5;
    color: var(--c-ink-soft);
  }

  /* Sizes: three image cards stay proportional and show every product in full. */
  .pergola-sizes .pergola-sizes__grid {
    display: grid !important;
    grid-template-columns: repeat(3, minmax(0, 1fr)) !important;
    gap: clamp(14px, 2vw, 24px) !important;
    align-items: stretch;
    border: 0 !important;
    background: transparent !important;
  }

  .pergola-sizes .pergola-size {
    min-width: 0;
    overflow: hidden;
    border: 1px solid var(--c-seam);
    background: var(--c-light);
  }

  .pergola-sizes .pergola-size__media {
    display: grid;
    place-items: center;
    width: 100%;
    aspect-ratio: 4 / 3;
    padding: clamp(12px, 1.8vw, 24px);
    overflow: hidden;
    background: #f2f4f2;
    border-bottom: 1px solid var(--c-seam);
  }

  .pergola-sizes .pergola-size__media img {
    width: 100% !important;
    height: 100% !important;
    max-width: 100%;
    object-fit: contain !important;
    object-position: center !important;
    transform: none !important;
  }

  .pergola-sizes .pergola-size__body {
    padding: clamp(18px, 2vw, 26px) !important;
  }

  .pergola-sizes .pergola-size--custom {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    column-gap: 28px;
    align-items: center;
    padding: clamp(24px, 3vw, 38px);
  }

  .pergola-sizes .pergola-size--custom .eyebrow,
  .pergola-sizes .pergola-size--custom h3,
  .pergola-sizes .pergola-size--custom p {
    grid-column: 1;
  }

  .pergola-sizes .pergola-size--custom .btn {
    grid-column: 2;
    grid-row: 1 / span 3;
    align-self: center;
    margin: 0;
  }

  .pergola-glazing__cta-row {
    grid-column: 2;
    display: flex;
    justify-content: flex-start;
    margin-top: -4px;
  }

  .pergola-glazing__cta-row .btn {
    margin: 0 !important;
    justify-content: space-between;
    gap: 20px;
  }

  .pergola-glazing__cta-arrow {
    display: inline-block;
    flex: 0 0 auto;
    font-size: 1.15em;
    line-height: 1;
    transition: transform var(--dur-fast) ease;
  }

  .pergola-glazing__cta-row .btn:hover .pergola-glazing__cta-arrow {
    transform: translate(2px, -2px);
  }

  @media (max-width: 980px) {
    .pergola-sizes .pergola-sizes__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
    }

    .pergola-sizes .pergola-size:nth-child(3) {
      grid-column: 1 / -1;
      width: min(100%, 620px);
      justify-self: center;
    }

    .pergola-glazing__cta-row {
      grid-column: 1;
      margin-top: 6px;
    }
  }

  @media (max-width: 820px) {
    .pergola-roof[data-roof-stable="true"] .pergola-roof__layout {
      gap: 22px !important;
    }

    .pergola-roof[data-roof-stable="true"] .pergola-roof__visual {
      width: 100%;
      aspect-ratio: 3 / 2;
    }

    .pergola-roof__status {
      left: 12px;
      bottom: 12px;
      max-width: calc(100% - 24px);
      padding: 9px 11px;
      font-size: 12px;
    }

    .pergola-roof__instruction {
      margin-bottom: 2px;
      padding-bottom: 16px;
    }

    .pergola-roof__instruction strong {
      font-size: 21px;
    }

    .pergola-roof__instruction span {
      font-size: 15px;
    }

    .pergola-roof[data-roof-stable="true"] .pergola-roof__tab {
      grid-template-columns: 34px minmax(0, 1fr) auto !important;
      gap: 11px;
      padding: 16px !important;
      transform: none !important;
    }

    .pergola-roof[data-roof-stable="true"] .pergola-roof__tab strong {
      font-size: 17px;
    }

    .pergola-roof[data-roof-stable="true"] .pergola-roof__tab small {
      font-size: 15px;
      line-height: 1.5;
    }

    .pergola-glazing__cta-row,
    .pergola-glazing__cta-row .btn {
      width: 100%;
    }
  }

  @media (max-width: 640px) {
    .pergola-sizes .pergola-sizes__grid {
      grid-template-columns: 1fr !important;
      gap: 16px !important;
    }

    .pergola-sizes .pergola-size:nth-child(3) {
      grid-column: auto;
      width: 100%;
    }

    .pergola-sizes .pergola-size__media {
      aspect-ratio: 4 / 3;
      padding: 16px;
    }

    .pergola-sizes .pergola-size--custom {
      grid-column: auto;
      display: block;
      padding: 24px;
    }

    .pergola-sizes .pergola-size--custom .btn {
      width: 100%;
      margin-top: 22px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pergola-roof__sprite-image,
    .pergola-roof[data-roof-stable="true"] .pergola-roof__tab {
      transition: none !important;
    }
  }
</style>

<script is:inline>
  (function () {
    function replaceSizeImage() {
      var cards = Array.from(document.querySelectorAll('.pergola-sizes__grid .pergola-size'));
      var card = cards.find(function (candidate) {
        var label = candidate.querySelector('.pergola-size__body strong');
        return label && (label.textContent || '').replace(/\s+/g, ' ').trim() === '4 × 5 м';
      });
      var image = card && card.querySelector('.pergola-size__media img');
      if (!image) return;

      image.src = '/images/pergolas/3.jpg.webp';
      image.removeAttribute('srcset');
      image.alt = 'Биоклиматическая пергола Raluma размером 4 × 5 м';
      image.dataset.sizeImage = '4x5';
    }

    function initRoofInteraction() {
      var section = document.querySelector('[data-roof-section]');
      if (!section || section.dataset.roofStableBound === 'true') return;

      var controls = section.querySelector('.pergola-roof__controls');
      var visual = section.querySelector('[data-roof-visual]');
      var tabs = Array.from(section.querySelectorAll('[data-roof-tab]'));
      if (!controls || !visual || tabs.length !== 3) return;

      section.dataset.roofStableBound = 'true';

      var states = {
        closed: {
          number: '01',
          title: 'Закрыта',
          text: 'Ламели сомкнуты: защита от дождя и прямого солнца.',
          status: 'Крыша закрыта · защита от осадков'
        },
        shade: {
          number: '02',
          title: 'Тень и вентиляция',
          text: 'Ламели под углом: мягкая тень и естественный воздухообмен.',
          status: 'Ламели под углом · тень и воздух'
        },
        open: {
          number: '03',
          title: 'Открыта',
          text: 'Ламели раскрыты: максимум света и открытого неба.',
          status: 'Крыша открыта · максимум света'
        }
      };

      if (!controls.querySelector('.pergola-roof__instruction')) {
        var instruction = document.createElement('div');
        instruction.className = 'pergola-roof__instruction';
        instruction.innerHTML = '<strong>Выберите положение крыши</strong><span>Нажмите на одну из трёх карточек — фотография изменится.</span>';
        controls.insertBefore(instruction, controls.firstChild);
      }

      tabs.forEach(function (tab) {
        var state = tab.getAttribute('data-roof-tab') || 'closed';
        var config = states[state];
        var number = tab.querySelector('.pergola-roof__tab-number');
        var title = tab.querySelector('strong');
        var text = tab.querySelector('small');
        if (number) number.textContent = config.number;
        if (title) title.textContent = config.title;
        if (text) text.textContent = config.text;
      });

      var mounted = false;
      var pendingState = 'closed';
      var status = null;
      var demoTimers = [];
      var demoStopped = false;

      function clearDemo() {
        demoTimers.forEach(function (timer) { window.clearTimeout(timer); });
        demoTimers = [];
      }

      function stopDemo() {
        demoStopped = true;
        clearDemo();
      }

      function syncState(state) {
        if (!states[state]) return;
        pendingState = state;

        tabs.forEach(function (tab) {
          var active = tab.getAttribute('data-roof-tab') === state;
          tab.classList.toggle('is-active', active);
          tab.setAttribute('aria-selected', String(active));
          tab.setAttribute('tabindex', active ? '0' : '-1');
        });

        visual.setAttribute('data-roof-visual', state);
        if (status) status.textContent = states[state].status;
      }

      tabs.forEach(function (tab, index) {
        tab.addEventListener('click', function () {
          stopDemo();
          syncState(tab.getAttribute('data-roof-tab') || 'closed');
        });

        tab.addEventListener('keydown', function (event) {
          if (event.key !== 'ArrowLeft' && event.key !== 'ArrowRight') return;
          event.preventDefault();
          stopDemo();
          var delta = event.key === 'ArrowRight' ? 1 : -1;
          var next = tabs[(index + delta + tabs.length) % tabs.length];
          next.focus();
          next.click();
        });
      });

      syncState('closed');

      function mountStableImage(image) {
        if (mounted || !image.naturalWidth) return;
        mounted = true;

        var viewport = document.createElement('div');
        viewport.className = 'pergola-roof__sprite-viewport';
        image.className = 'pergola-roof__sprite-image';
        image.alt = '';
        image.setAttribute('aria-hidden', 'true');
        viewport.appendChild(image);

        status = document.createElement('p');
        status.className = 'pergola-roof__status';
        status.setAttribute('aria-live', 'polite');

        visual.replaceChildren(viewport, status);
        visual.setAttribute('role', 'img');
        visual.setAttribute('aria-label', 'Три положения ламельной крыши перголы');
        section.dataset.roofStable = 'true';
        syncState(pendingState);

        var reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        var demoSeen = false;
        try { demoSeen = sessionStorage.getItem('raluma-roof-stable-demo-v3') === '1'; } catch (_) {}

        if (!reducedMotion && !demoSeen && typeof IntersectionObserver === 'function') {
          var observer = new IntersectionObserver(function (entries) {
            if (!entries.some(function (entry) { return entry.isIntersecting; })) return;
            observer.disconnect();
            try { sessionStorage.setItem('raluma-roof-stable-demo-v3', '1'); } catch (_) {}

            [
              ['shade', 900],
              ['open', 2200],
              ['closed', 3500]
            ].forEach(function (step) {
              demoTimers.push(window.setTimeout(function () {
                if (!demoStopped) syncState(step[0]);
              }, step[1]));
            });
          }, { threshold: 0.42 });
          observer.observe(section);
        }
      }

      var image = new Image();
      image.width = 960;
      image.height = 1920;
      image.decoding = 'async';
      image.loading = 'eager';
      image.onload = function () { mountStableImage(image); };
      image.onerror = function () {
        /* Keep the original roof illustration as a visible fallback. */
        section.dataset.roofImageError = 'true';
      };
      image.src = '/images/pergolas/roof-states.webp?v=3';

      if (image.complete && image.naturalWidth) mountStableImage(image);
    }

    function moveGlazingButton() {
      var layout = document.querySelector('.pergola-glazing__layout');
      var systems = layout && layout.querySelector('.pergola-glazing__systems');
      var link = layout && layout.querySelector('.pergola-glazing__intro .btn');
      if (!layout || !systems || !link || layout.querySelector('.pergola-glazing__cta-row')) return;

      if (!link.querySelector('.pergola-glazing__cta-arrow')) {
        var arrow = document.createElement('span');
        arrow.className = 'pergola-glazing__cta-arrow';
        arrow.setAttribute('aria-hidden', 'true');
        arrow.textContent = '↗';
        link.appendChild(arrow);
      }

      var row = document.createElement('div');
      row.className = 'pergola-glazing__cta-row';
      row.appendChild(link);
      systems.insertAdjacentElement('afterend', row);
    }

    function init() {
      replaceSizeImage();
      initRoofInteraction();
      moveGlazingButton();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init, { once: true });
    } else {
      init();
    }
  })();
</script>
