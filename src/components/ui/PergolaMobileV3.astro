<style is:global>
  .pergola-option__mobile-copy {
    display: none;
  }

  @media (max-width: 820px) {
    .pergolas-teaser,
    .pergolas-page {
      --pg-display: clamp(30px, 8.4vw, 38px);
      --pg-section-title: clamp(26px, 7.2vw, 32px);
      --pg-card-title: clamp(20px, 5.5vw, 24px);
      --pg-lead: 17px;
      --pg-body: 16px;
      --pg-meta: 12px;
    }

    .pergolas-page,
    .pergolas-page .shell,
    .pergolas-page :is(.pergola-head, .pergola-hero__copy, .pergola-type__body, .pergola-climate__intro,
      .pergola-roof__controls, .pergola-size__body, .pergola-size--custom, .pergola-glazing__intro,
      .pergola-glazing__system, .pergola-benefit, .pergola-option > div, .pergola-process__steps li,
      .pergola-faq__intro, .pergola-faq__item, .pergola-final-cta__inner) {
      min-width: 0 !important;
      max-width: 100% !important;
    }

    /* Headings remain on one line, but are fitted to the real available width by JS. */
    .pergolas-teaser__title,
    .pergolas-page h1,
    .pergolas-page h2,
    .pergolas-page h3 {
      display: block !important;
      width: 100% !important;
      max-width: 100% !important;
      margin-inline: 0 !important;
      white-space: nowrap !important;
      text-wrap: nowrap !important;
      overflow: visible !important;
      text-overflow: clip !important;
      overflow-wrap: normal !important;
      word-break: normal !important;
      hyphens: none !important;
      font-weight: 300 !important;
      letter-spacing: -0.025em !important;
    }

    .pergolas-teaser__title,
    .pergola-hero__title {
      font-size: var(--pg-display) !important;
      line-height: 1.03 !important;
    }

    .pergolas-page h2 {
      font-size: var(--pg-section-title) !important;
      line-height: 1.08 !important;
    }

    .pergolas-page h3 {
      font-size: var(--pg-card-title) !important;
      line-height: 1.14 !important;
    }

    /* All prose is allowed to wrap and grow. No clamps, ellipses or hidden lines. */
    .pergolas-page :is(p, li, dd, small, summary span, .btn),
    .pergolas-teaser :is(p, span, .btn) {
      max-width: 100% !important;
      white-space: normal !important;
      overflow: visible !important;
      text-overflow: clip !important;
      overflow-wrap: break-word !important;
      word-break: normal !important;
      hyphens: none !important;
      -webkit-line-clamp: unset !important;
      line-clamp: unset !important;
      -webkit-box-orient: initial !important;
    }

    .pergolas-teaser .eyebrow,
    .pergolas-page .eyebrow,
    .pergola-benefit > .figure,
    .pergola-type__number {
      font-size: var(--pg-meta) !important;
      line-height: 1.35 !important;
      letter-spacing: 0.08em !important;
    }

    .pergolas-teaser__lead,
    .pergola-hero__lead,
    .pergola-head .lead,
    .pergola-climate__intro > p:last-child,
    .pergola-glazing__intro > p,
    .pergola-final-cta p,
    .pergola-faq__intro .lead {
      font-size: var(--pg-lead) !important;
      line-height: 1.6 !important;
    }

    .pergola-type p,
    .pergola-type li,
    .pergola-spec p,
    .pergola-roof__tab small,
    .pergola-size--custom p:not(.eyebrow),
    .pergola-glazing__system p,
    .pergola-benefit p,
    .pergola-option p:last-child,
    .pergola-option__mobile-copy,
    .pergola-process__steps p,
    .pergola-faq__item > p {
      display: block !important;
      height: auto !important;
      max-height: none !important;
      font-size: var(--pg-body) !important;
      line-height: 1.6 !important;
    }

    .pergola-roof__tab strong,
    .pergola-process__steps strong,
    .pergola-size__body strong {
      display: block !important;
      min-width: 0 !important;
      max-width: 100% !important;
      white-space: normal !important;
      overflow: visible !important;
      font-size: var(--pg-card-title) !important;
      line-height: 1.2 !important;
    }

    /* Every content card grows with its text. */
    .pergolas-page :is(.pergola-type, .pergola-spec, .pergola-size, .pergola-size--custom,
      .pergola-glazing__system, .pergola-benefit, .pergola-option, .pergola-process__steps li,
      .pergola-faq__item, .pergola-roof__tab) {
      min-height: 0 !important;
      height: auto !important;
      max-height: none !important;
    }

    .pergolas-page :is(.pergola-type__body, .pergola-size__body, .pergola-size--custom,
      .pergola-glazing__system, .pergola-benefit, .pergola-option > div,
      .pergola-process__steps li, .pergola-faq__item) {
      overflow: visible !important;
    }

    .pergola-options__grid {
      grid-template-columns: 1fr !important;
      gap: 16px !important;
    }

    .pergola-option,
    .pergola-option--large {
      display: block !important;
      grid-column: auto !important;
      overflow: visible !important;
      border: 1px solid var(--c-seam);
      background: var(--c-light);
    }

    .pergola-option img {
      display: block;
      width: 100%;
      height: auto !important;
      aspect-ratio: 16 / 10 !important;
      object-fit: cover;
      object-position: center;
    }

    .pergola-option > div {
      display: block !important;
      padding: 22px 20px 24px !important;
      border-top: 1px solid var(--c-seam);
    }

    .pergola-option .eyebrow {
      margin: 0 0 10px;
    }

    .pergola-option h3 {
      margin: 0 !important;
    }

    .pergola-option p:last-child,
    .pergola-option__mobile-copy {
      display: block;
      max-width: 42ch;
      margin: 12px 0 0 !important;
      color: var(--c-ink-soft);
    }

    .pergola-benefits__grid {
      display: grid !important;
      grid-template-columns: 1fr !important;
      gap: 12px !important;
      overflow: visible !important;
      border: 0 !important;
      background: transparent !important;
    }

    .pergola-benefit {
      box-sizing: border-box;
      min-width: 0;
      padding: 22px 20px 24px !important;
      border: 1px solid var(--c-seam);
      background: var(--c-light-raised);
    }

    .pergola-benefit h3 {
      max-width: none !important;
      margin: 18px 0 0 !important;
    }

    .pergola-benefit p {
      max-width: none !important;
      margin: 12px 0 0 !important;
    }

    .pergola-glazing__system {
      grid-template-columns: 36px minmax(0, 1fr) !important;
      align-items: start !important;
    }

    .pergola-glazing__system p {
      grid-column: 2 !important;
      min-width: 0 !important;
    }

    .pergola-roof__tab {
      grid-template-columns: 34px minmax(0, 1fr) !important;
      align-items: start !important;
    }

    .pergola-roof__tab > span:last-child {
      min-width: 0 !important;
    }

    .pergola-faq__item summary {
      display: grid !important;
      grid-template-columns: minmax(0, 1fr) auto !important;
      align-items: start !important;
      gap: 14px !important;
      font-size: 16px !important;
      line-height: 1.4 !important;
    }

    .pergola-faq__item summary span:first-child {
      min-width: 0 !important;
    }

    .pergola-faq__item > p {
      padding-right: 0 !important;
    }

    .pergola-faq__item summary,
    .pergola-hero__actions .btn,
    .pergola-final-cta__button,
    .pergola-size--custom .btn,
    .pergola-glazing__cta-row .btn,
    .pergola-roof__quick-button {
      font-size: 15px !important;
      line-height: 1.3 !important;
    }

    .pergolas-page .btn {
      min-height: 50px !important;
      height: auto !important;
      padding-block: 13px !important;
      text-align: center !important;
    }
  }

  @media (max-width: 340px) {
    .pergolas-teaser,
    .pergolas-page {
      --pg-display: 28px;
      --pg-section-title: 24px;
      --pg-card-title: 20px;
      --pg-lead: 16px;
      --pg-body: 16px;
    }
  }
</style>

<script is:inline>
  (function () {
    var headingSelector = '.pergolas-teaser__title, .pergolas-page h1, .pergolas-page h2, .pergolas-page h3';
    var replacements = {
      'Биоклиматические перголы под ключ': 'Биоклиматические перголы',
      'Два решения для разных сценариев': 'Два типа крыши',
      'Регулируемая биоклиматическая крыша': 'Ламельная крыша',
      'Пергола со стеклянной крышей': 'Стеклянная крыша',
      'Не летний навес, а инженерная конструкция': 'Инженерная пергола',
      'Погода меняется — пространство остаётся вашим': 'Три режима крыши',
      'Стандартные модули и индивидуальный проект': 'Размеры перголы',
      'Индивидуальный размер': 'Размер под объект',
      'Из открытой террасы — в защищённое пространство': 'Остекление перголы',
      'Терраса работает дольше и выглядит частью дома': 'Комфорт круглый год',
      'Управляемое естественное освещение': 'Свет по сценарию',
      'Режим естественной вентиляции': 'Свежий воздух',
      'Водоотвод спрятан в конструкции': 'Скрытый водоотвод',
      'Единая архитектура с домом': 'В стиле дома',
      'Не только белый или графит': 'Материалы и опции',
      'Окрашивание по RAL и декор': 'Цвет и декор',
      'Прозрачное, осветлённое или тонированное стекло': 'Три варианта стекла',
      'Освещение, датчики погоды и обогрев': 'Свет и автоматика',
      'От фотографии участка до настроенной автоматики': 'Как создаётся пергола',
      'Пришлите фотографию фасада или участка': 'Расчёт по фотографии',
      'Узнайте стоимость под ваш объект': 'Рассчитать стоимость'
    };

    function fitHeading(el) {
      if (!window.matchMedia('(max-width: 820px)').matches) {
        el.style.removeProperty('font-size');
        el.style.removeProperty('letter-spacing');
        return;
      }

      el.style.removeProperty('font-size');
      el.style.removeProperty('letter-spacing');

      var available = Math.floor(el.getBoundingClientRect().width || el.parentElement?.clientWidth || 0);
      if (!available) return;

      var computed = window.getComputedStyle(el);
      var start = Math.round(parseFloat(computed.fontSize) || 24);
      var min = el.tagName === 'H1' ? 20 : el.tagName === 'H2' ? 18 : 16;
      var size = start;

      el.style.setProperty('font-size', size + 'px', 'important');
      while (size > min && el.scrollWidth > available + 1) {
        size -= 0.5;
        el.style.setProperty('font-size', size + 'px', 'important');
      }

      if (el.scrollWidth > available + 1) {
        el.style.setProperty('letter-spacing', '-0.055em', 'important');
        while (size > 14 && el.scrollWidth > available + 1) {
          size -= 0.5;
          el.style.setProperty('font-size', size + 'px', 'important');
        }
      }
    }

    function applyMobileCopyAndFit() {
      var mobile = window.matchMedia('(max-width: 820px)').matches;

      document.querySelectorAll('.pergolas-teaser, .pergolas-page').forEach(function (el) {
        el.setAttribute('data-mobile-layout', 'adaptive-type-v6');
      });

      document.querySelectorAll(headingSelector).forEach(function (el) {
        if (!el.dataset.desktopTitle) el.dataset.desktopTitle = (el.textContent || '').trim();
        var original = el.dataset.desktopTitle;
        var mobileTitle = replacements[original] || original;

        if (el.matches('.pergolas-teaser__title')) mobileTitle = 'Перголы Raluma';
        if (el.matches('.pergola-hero__title')) mobileTitle = 'Перголы под ключ';

        el.textContent = mobile ? mobileTitle : original;
        fitHeading(el);
      });

      document.querySelectorAll('.pergola-option').forEach(function (card) {
        var title = card.querySelector('h3');
        var body = card.querySelector(':scope > div');
        if (!title || !body || body.querySelector('.pergola-option__mobile-copy')) return;

        var original = title.dataset.desktopTitle || (title.textContent || '').trim();
        var copy = '';
        if (original === 'Прозрачное, осветлённое или тонированное стекло') {
          copy = 'Прозрачное, осветлённое или тонированное — под свет, приватность и архитектуру.';
        }
        if (original === 'Освещение, датчики погоды и обогрев') {
          copy = 'Интегрируем освещение, погодную автоматику и обогрев без визуального перегруза.';
        }
        if (!copy) return;

        var paragraph = document.createElement('p');
        paragraph.className = 'pergola-option__mobile-copy';
        paragraph.textContent = copy;
        body.appendChild(paragraph);
      });
    }

    var timer;
    function schedule() {
      window.clearTimeout(timer);
      timer = window.setTimeout(applyMobileCopyAndFit, 60);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', applyMobileCopyAndFit, { once: true });
    } else {
      applyMobileCopyAndFit();
    }

    if (document.fonts && document.fonts.ready) document.fonts.ready.then(applyMobileCopyAndFit);
    window.addEventListener('resize', schedule, { passive: true });

    if (typeof ResizeObserver === 'function') {
      var observer = new ResizeObserver(schedule);
      document.querySelectorAll('.pergolas-teaser, .pergolas-page').forEach(function (el) {
        observer.observe(el);
      });
    }
  })();
</script>
