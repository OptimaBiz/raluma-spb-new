<style is:global>
  .pergola-option__mobile-copy {
    display: none;
  }

  @media (max-width: 820px) {
    .pergolas-teaser,
    .pergolas-page {
      --pg-display: 22px;
      --pg-section-title: 20px;
      --pg-card-title: 17px;
      --pg-lead: 16px;
      --pg-body: 15px;
      --pg-meta: 11px;
    }

    .pergolas-teaser__title,
    .pergolas-page h1,
    .pergolas-page h2,
    .pergolas-page h3 {
      display: block;
      width: 100%;
      max-width: 100% !important;
      white-space: nowrap !important;
      text-wrap: nowrap !important;
      overflow-wrap: normal !important;
      word-break: normal !important;
      hyphens: none !important;
      font-weight: 300 !important;
      letter-spacing: -0.025em !important;
    }

    .pergolas-teaser__title,
    .pergola-hero__title {
      font-size: var(--pg-display) !important;
      line-height: 1.05 !important;
    }

    .pergolas-page h2 {
      font-size: var(--pg-section-title) !important;
      line-height: 1.08 !important;
    }

    .pergolas-page h3 {
      font-size: var(--pg-card-title) !important;
      line-height: 1.12 !important;
    }

    .pergolas-teaser .eyebrow,
    .pergolas-page .eyebrow,
    .pergola-benefit > .figure,
    .pergola-type__number {
      font-size: var(--pg-meta) !important;
      line-height: 1.35 !important;
      letter-spacing: 0.08em !important;
    }

    .pergolas-teaser__lead,
    .pergola-hero__lead,
    .pergola-head .lead,
    .pergola-climate__intro > p:last-child,
    .pergola-glazing__intro > p,
    .pergola-final-cta p,
    .pergola-faq__intro .lead {
      font-size: var(--pg-lead) !important;
      line-height: 1.55 !important;
    }

    .pergola-type p,
    .pergola-type li,
    .pergola-spec p,
    .pergola-roof__tab small,
    .pergola-size--custom p:not(.eyebrow),
    .pergola-glazing__system p,
    .pergola-benefit p,
    .pergola-option p:last-child,
    .pergola-option__mobile-copy,
    .pergola-process__steps p,
    .pergola-faq__item > p {
      font-size: var(--pg-body) !important;
      line-height: 1.55 !important;
    }

    .pergola-roof__tab strong,
    .pergola-process__steps strong,
    .pergola-size__body strong {
      font-size: var(--pg-card-title) !important;
      line-height: 1.2 !important;
    }

    .pergola-options__grid {
      grid-template-columns: 1fr !important;
      gap: 16px !important;
    }

    .pergola-option,
    .pergola-option--large {
      display: block !important;
      grid-column: auto !important;
      min-height: 0 !important;
      height: auto !important;
      overflow: visible !important;
      border: 1px solid var(--c-seam);
      background: var(--c-light);
    }

    .pergola-option img {
      display: block;
      width: 100%;
      height: auto !important;
      aspect-ratio: 16 / 10 !important;
      object-fit: cover;
      object-position: center;
    }

    .pergola-option > div {
      display: block !important;
      padding: 22px 20px 24px !important;
      border-top: 1px solid var(--c-seam);
    }

    .pergola-option .eyebrow {
      margin: 0 0 10px;
    }

    .pergola-option h3 {
      margin: 0 !important;
    }

    .pergola-option p:last-child,
    .pergola-option__mobile-copy {
      display: block;
      max-width: 42ch;
      margin: 12px 0 0 !important;
      color: var(--c-ink-soft);
    }

    .pergola-benefits__grid {
      display: grid !important;
      grid-template-columns: 1fr !important;
      gap: 12px !important;
      overflow: visible !important;
      border: 0 !important;
      background: transparent !important;
    }

    .pergola-benefit {
      box-sizing: border-box;
      min-width: 0;
      min-height: 0 !important;
      height: auto !important;
      overflow: visible !important;
      padding: 22px 20px 24px !important;
      border: 1px solid var(--c-seam);
      background: var(--c-light-raised);
    }

    .pergola-benefit h3 {
      max-width: none !important;
      margin: 18px 0 0 !important;
    }

    .pergola-benefit p {
      max-width: none !important;
      margin: 12px 0 0 !important;
    }

    .pergola-faq__item summary,
    .pergola-hero__actions .btn,
    .pergola-final-cta__button,
    .pergola-size--custom .btn,
    .pergola-glazing__intro .btn {
      font-size: 15px !important;
      line-height: 1.3 !important;
    }
  }

  @media (max-width: 340px) {
    .pergolas-teaser,
    .pergolas-page {
      --pg-display: 20px;
      --pg-section-title: 18px;
      --pg-card-title: 16px;
      --pg-lead: 15px;
      --pg-body: 15px;
    }
  }
</style>

<script is:inline>
  (function () {
    var selector = '.pergolas-teaser__title, .pergolas-page h1, .pergolas-page h2, .pergolas-page h3';
    var replacements = {
      'Биоклиматические перголы под ключ': 'Биоклиматические перголы',
      'Два решения для разных сценариев': 'Два типа крыши',
      'Регулируемая биоклиматическая крыша': 'Ламельная крыша',
      'Пергола со стеклянной крышей': 'Стеклянная крыша',
      'Не летний навес, а инженерная конструкция': 'Инженерная конструкция',
      'Погода меняется — пространство остаётся вашим': 'Три режима крыши',
      'Стандартные модули и индивидуальный проект': 'Размеры и конфигурации',
      'Индивидуальный размер': 'Размер под объект',
      'Из открытой террасы — в защищённое пространство': 'Остекление перголы',
      'Терраса работает дольше и выглядит частью дома': 'Комфорт круглый сезон',
      'Управляемое естественное освещение': 'Свет по сценарию',
      'Режим естественной вентиляции': 'Естественная вентиляция',
      'Водоотвод спрятан в конструкции': 'Скрытый водоотвод',
      'Единая архитектура с домом': 'В едином стиле с домом',
      'Не только белый или графит': 'Цвета, стекло и комфорт',
      'Окрашивание по RAL и декор': 'Цвет по RAL и декор',
      'Прозрачное, осветлённое или тонированное стекло': 'Три варианта стекла',
      'Освещение, датчики погоды и обогрев': 'Свет, датчики и обогрев',
      'От фотографии участка до настроенной автоматики': 'Как создаётся пергола',
      'Пришлите фотографию фасада или участка': 'Расчёт по фотографии'
    };

    function applyMobileCopy() {
      var mobile = window.matchMedia('(max-width: 820px)').matches;

      document.querySelectorAll('.pergolas-teaser, .pergolas-page').forEach(function (el) {
        el.setAttribute('data-mobile-layout', 'type-scale-v4');
      });

      document.querySelectorAll(selector).forEach(function (el) {
        if (!el.dataset.desktopTitle) el.dataset.desktopTitle = (el.textContent || '').trim();
        var original = el.dataset.desktopTitle;
        var mobileTitle = replacements[original] || original;

        if (original === 'Биоклиматические перголы под ключ' && el.matches('.pergolas-teaser__title')) {
          mobileTitle = 'Перголы Raluma';
        }
        if (original === 'Биоклиматические перголы под ключ' && el.matches('.pergola-hero__title')) {
          mobileTitle = 'Перголы под ключ';
        }

        el.textContent = mobile ? mobileTitle : original;
      });

      document.querySelectorAll('.pergola-option').forEach(function (card) {
        var title = card.querySelector('h3');
        var body = card.querySelector(':scope > div');
        if (!title || !body || body.querySelector('.pergola-option__mobile-copy')) return;

        var original = title.dataset.desktopTitle || (title.textContent || '').trim();
        var copy = '';
        if (original === 'Прозрачное, осветлённое или тонированное стекло') {
          copy = 'Прозрачное, осветлённое или тонированное — под свет, приватность и архитектуру.';
        }
        if (original === 'Освещение, датчики погоды и обогрев') {
          copy = 'Интегрируем освещение, погодную автоматику и обогрев без визуального перегруза.';
        }
        if (!copy) return;

        var paragraph = document.createElement('p');
        paragraph.className = 'pergola-option__mobile-copy';
        paragraph.textContent = copy;
        body.appendChild(paragraph);
      });
    }

    var timer;
    function schedule() {
      window.clearTimeout(timer);
      timer = window.setTimeout(applyMobileCopy, 40);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', applyMobileCopy, { once: true });
    } else {
      applyMobileCopy();
    }

    if (document.fonts && document.fonts.ready) document.fonts.ready.then(applyMobileCopy);
    window.addEventListener('resize', schedule, { passive: true });
  })();
</script>
