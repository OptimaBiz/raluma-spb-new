---
const phoneHref = 'tel:+78123307415';
const phoneDisplay = '+7 (812) 330-74-15';
const isHomePage = Astro.url.pathname === '/';
const base = isHomePage ? '' : '/';

const navLinks = [
  { href: `${base}#systems`, label: 'Системы' },
  { href: `${base}#cases`, label: 'Проекты' },
  { href: `${base}#why-raluma`, label: 'О нас' },
  { href: `${base}#faq`, label: 'Вопросы' },
];
---

<header class="site-header" data-site-header>
  <div class="container site-header__inner">
    <a class="site-header__logo" href="/" aria-label="Raluma — на главную">
      <img src="/images/logo/raluma-logo.png" alt="" width="30" height="30" />
      <span class="site-header__logo-word">Ралюма СПб</span>
    </a>

    <nav class="site-header__nav" aria-label="Разделы сайта">
      {navLinks.map((link) => (
        <a class="site-header__nav-link" href={link.href}>{link.label}</a>
      ))}
    </nav>

    <div class="site-header__actions">
      <a class="site-header__phone" href={phoneHref} data-goal="phone_click_header">
        <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.86 19.86 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.86 19.86 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.12.9.35 1.78.68 2.62a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.46-1.25a2 2 0 0 1 2.11-.45c.84.33 1.72.56 2.62.68A2 2 0 0 1 22 16.92z" />
        </svg>
        <span>{phoneDisplay}</span>
      </a>

      <a class="site-header__cta" href={`${base}#lead-form`}>Рассчитать</a>

      <button
        class="site-header__burger"
        type="button"
        aria-label="Открыть меню"
        aria-expanded="false"
        aria-controls="site-header-menu"
        data-header-burger
      >
        <span aria-hidden="true"></span>
        <span aria-hidden="true"></span>
      </button>
    </div>
  </div>

  <div class="site-header__menu" id="site-header-menu" data-header-menu hidden>
    <nav class="site-header__menu-nav" aria-label="Разделы сайта">
      {navLinks.map((link) => (
        <a class="site-header__menu-link" href={link.href}>{link.label}</a>
      ))}
    </nav>

    <a class="site-header__menu-phone" href={phoneHref} data-goal="phone_click_header">{phoneDisplay}</a>
    <p class="site-header__menu-hours">Ежедневно 9:00–21:00</p>
  </div>
</header>

<script>
  const header = document.querySelector('[data-site-header]');
  const burger = document.querySelector('[data-header-burger]');
  const menu = document.querySelector('[data-header-menu]');

  if (header) {
    // Compact state after the hero so the header stops competing with it.
    let ticking = false;
    const update = () => {
      header.classList.toggle('is-compact', window.scrollY > 40);
      ticking = false;
    };
    window.addEventListener('scroll', () => {
      if (ticking) return;
      ticking = true;
      window.requestAnimationFrame(update);
    }, { passive: true });
    update();
  }

  if (burger && menu) {
    const setMenu = (open) => {
      menu.hidden = !open;
      burger.setAttribute('aria-expanded', String(open));
      burger.setAttribute('aria-label', open ? 'Закрыть меню' : 'Открыть меню');
      burger.classList.toggle('is-open', open);
      document.body.classList.toggle('has-menu-open', open);
    };

    burger.addEventListener('click', () => setMenu(menu.hidden));
    menu.addEventListener('click', (event) => {
      if (event.target instanceof Element && event.target.closest('a')) setMenu(false);
    });
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && !menu.hidden) {
        setMenu(false);
        burger.focus();
      }
    });
  }
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 60;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid transparent;
    transition: border-color var(--motion-base) var(--motion-ease),
      box-shadow var(--motion-base) var(--motion-ease);
  }

  .site-header.is-compact {
    border-bottom-color: var(--border);
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.05);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    min-height: 64px;
  }

  .site-header__logo {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    flex-shrink: 0;
    text-decoration: none;
  }

  .site-header__logo img {
    width: 30px;
    height: 30px;
  }

  .site-header__logo-word {
    color: var(--text);
    font-size: 19px;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .site-header__nav {
    display: flex;
    align-items: center;
    gap: 26px;
  }

  .site-header__nav-link {
    color: var(--text);
    font-size: 15px;
    text-decoration: none;
    white-space: nowrap;
    transition: color var(--motion-fast) var(--motion-ease-productive);
  }

  .site-header__nav-link:hover {
    color: var(--accent);
  }

  .site-header__actions {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .site-header__phone {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    color: var(--text);
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
  }

  .site-header__phone:hover {
    color: var(--accent);
  }

  .site-header__cta {
    display: inline-flex;
    align-items: center;
    min-height: 40px;
    padding: 0 18px;
    border-radius: 999px;
    background: var(--accent);
    color: #fff;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
    transition: transform var(--motion-fast) var(--motion-ease-productive),
      background var(--motion-fast) var(--motion-ease-productive);
  }

  .site-header__cta:hover {
    background: #c62d29;
  }

  .site-header__cta:active {
    transform: translateY(1px);
  }

  .site-header__burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    padding: 0;
    border: 0;
    border-radius: 12px;
    background: transparent;
    cursor: pointer;
  }

  .site-header__burger span {
    display: block;
    width: 20px;
    height: 2px;
    margin: 0 auto;
    border-radius: 2px;
    background: var(--text);
    transition: transform var(--motion-fast) var(--motion-ease-productive),
      opacity var(--motion-fast) var(--motion-ease-productive);
  }

  .site-header__burger.is-open span:first-child {
    transform: translateY(3.5px) rotate(45deg);
  }

  .site-header__burger.is-open span:last-child {
    transform: translateY(-3.5px) rotate(-45deg);
  }

  .site-header__menu {
    padding: 8px 16px 20px;
    border-top: 1px solid var(--border);
    background: var(--surface);
  }

  .site-header__menu[hidden] {
    display: none;
  }

  .site-header__menu-nav {
    display: grid;
  }

  .site-header__menu-link {
    padding: 13px 4px;
    border-bottom: 1px solid var(--border);
    color: var(--text);
    font-size: 16px;
    text-decoration: none;
  }

  .site-header__menu-phone {
    display: inline-block;
    margin-top: 16px;
    color: var(--text);
    font-size: 20px;
    font-weight: 700;
    text-decoration: none;
  }

  .site-header__menu-hours {
    margin: 4px 0 0;
    color: var(--muted);
    font-size: 13px;
  }

  :global(body.has-menu-open) {
    overflow: hidden;
  }

  @media (max-width: 900px) {
    .site-header__nav,
    .site-header__cta {
      display: none;
    }

    .site-header__burger {
      display: flex;
    }

    .site-header__phone span {
      display: none;
    }

    .site-header__phone {
      width: 44px;
      height: 44px;
      align-items: center;
      justify-content: center;
      border-radius: 12px;
      background: rgba(17, 17, 17, 0.05);
    }

    .site-header__phone svg {
      width: 19px;
      height: 19px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .site-header,
    .site-header__cta,
    .site-header__burger span {
      transition: none;
    }
  }
</style>
