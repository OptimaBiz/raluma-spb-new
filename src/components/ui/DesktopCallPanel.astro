---
const phoneDisplay = '+7 (812) 330-74-15';
const phoneHref = 'tel:+78123307415';
const hours = 'Ежедневно 9:00–21:00';
---

<div class="desktop-call-panel" data-desktop-call-panel>
  <div class="desktop-call-panel__inner">
    <div class="desktop-call-panel__meta">
      <a class="desktop-call-panel__phone" href={phoneHref} data-goal="phone_click_float" aria-label={`Позвонить ${phoneDisplay}`}>
        {phoneDisplay}
      </a>

      <p class="desktop-call-panel__hours" aria-label={hours}>
        {hours}
      </p>
    </div>

    <a class="desktop-call-panel__cta" href={phoneHref} data-goal="phone_click_float">
      позвонить
    </a>
  </div>
</div>

<script>
  (() => {
    const init = () => {
      const panel = document.querySelector('[data-desktop-call-panel]');
      if (!panel) return;

      const updateState = () => {
        const threshold = Math.min(window.innerHeight * 0.28, 220);
        panel.classList.toggle('is-scrolled', window.scrollY > threshold);
      };

      updateState();

      let ticking = false;
      const onScroll = () => {
        if (ticking) return;
        ticking = true;

        requestAnimationFrame(() => {
          updateState();
          ticking = false;
        });
      };

      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', updateState);
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init, { once: true });
    } else {
      init();
    }
  })();
</script>

<style>
  .desktop-call-panel {
    position: fixed;
    top: 22px;
    right: 22px;
    z-index: 80;
    width: min(348px, calc(100vw - 48px));
    pointer-events: auto;
  }

  .desktop-call-panel__inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 16px;
    padding: 12px 14px;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.96);
    border: 1px solid rgba(17, 17, 17, 0.12);
    box-shadow:
      0 1px 0 rgba(17, 17, 17, 0.06),
      0 18px 48px rgba(17, 17, 17, 0.14);
    backdrop-filter: blur(10px);
    transition:
      padding 0.28s ease,
      border-color 0.28s ease,
      box-shadow 0.28s ease,
      transform 0.28s ease,
      background 0.28s ease;
  }

  .desktop-call-panel__meta {
    min-width: 0;
  }

  .desktop-call-panel__phone {
    display: inline-block;
    font-size: 20px;
    line-height: 1.05;
    letter-spacing: -0.03em;
    font-weight: 700;
    color: #111111;
    text-decoration: underline;
    text-decoration-thickness: 1.5px;
    text-underline-offset: 3px;
    white-space: nowrap;
  }

  .desktop-call-panel__hours {
    margin: 8px 0 0;
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transform: translateY(-4px);
    font-size: 14px;
    line-height: 1.35;
    color: #7a7a7a;
    transition:
      max-height 0.28s ease,
      opacity 0.22s ease,
      transform 0.28s ease,
      margin 0.28s ease;
  }

  .desktop-call-panel__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 122px;
    min-height: 46px;
    padding: 0 18px;
    border-radius: 999px;
    border: 1px solid rgba(17, 17, 17, 0.18);
    background: #f5f5f5;
    color: #111111;
    font-size: 14px;
    line-height: 1;
    font-weight: 700;
    text-transform: uppercase;
    text-decoration: none;
    transition:
      background 0.28s ease,
      color 0.28s ease,
      border-color 0.28s ease,
      transform 0.28s ease,
      box-shadow 0.28s ease;
  }

  .desktop-call-panel__cta:hover {
    transform: translateY(-1px);
  }

  .desktop-call-panel.is-scrolled .desktop-call-panel__inner {
    padding-top: 12px;
    padding-bottom: 12px;
    border-color: rgba(17, 17, 17, 0.14);
    box-shadow:
      0 1px 0 rgba(17, 17, 17, 0.06),
      0 24px 56px rgba(17, 17, 17, 0.18);
  }

  .desktop-call-panel.is-scrolled .desktop-call-panel__hours {
    margin-top: 10px;
    max-height: 24px;
    opacity: 1;
    transform: translateY(0);
  }

  .desktop-call-panel.is-scrolled .desktop-call-panel__cta {
    background: #111111;
    color: #ffffff;
    border-color: #111111;
    box-shadow: 0 10px 24px rgba(17, 17, 17, 0.18);
  }

  @media (max-width: 1023px) {
    .desktop-call-panel {
      display: none;
    }
  }
</style>
