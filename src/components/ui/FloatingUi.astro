---
---

<div class="floating-ui" aria-hidden="false">
  <button
    class="floating-ui__scroll-top"
    type="button"
    aria-label="Наверх"
    data-scroll-top
  >
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path d="M12 5l-7 7 1.6 1.6 4.3-4.3V19h2.2V9.3l4.3 4.3L19 12z" fill="currentColor"></path>
    </svg>
  </button>

  <div class="cookie-widget" data-cookie-widget>
    <!-- panel первый в DOM — при bottom-anchor раскрывается ВВЕРХ от кнопки -->
    <div class="cookie-widget__panel">
      <div class="cookie-widget__panel-inner">
        <p class="cookie-widget__title">Использование cookies</p>
        <p class="cookie-widget__text">
          Мы используем cookies и технические данные для корректной работы сайта,
          анализа посещаемости и улучшения сервиса.
        </p>

        <div class="cookie-widget__actions">
          <button class="cookie-widget__button cookie-widget__button--primary" type="button" data-cookie-accept>
            Принять
          </button>
          <button class="cookie-widget__button cookie-widget__button--secondary" type="button" data-cookie-more>
            Подробнее
          </button>
        </div>
      </div>
    </div>

    <!-- trigger второй в DOM — остаётся внизу при bottom-anchor -->
    <button class="cookie-widget__trigger" type="button" data-cookie-trigger aria-label="Управление cookies">
      <img class="cookie-widget__icon" src="/images/icons/cookies.png" alt="" aria-hidden="true" width="26" height="26" />
    </button>
  </div>

  <dialog class="floating-ui__dialog" id="cookie-info-dialog">
    <div class="floating-ui__dialog-inner">
      <div class="floating-ui__dialog-head">
        <div>
          <p class="floating-ui__dialog-eyebrow">Cookies</p>
          <h3 class="floating-ui__dialog-title">Использование cookies</h3>
        </div>

        <button
          class="floating-ui__dialog-close"
          type="button"
          aria-label="Закрыть"
          data-cookie-dialog-close
        >
          ×
        </button>
      </div>

      <div class="floating-ui__dialog-body">
        <p>
          Мы используем cookies и технические данные для корректной работы сайта,
          анализа посещаемости и улучшения сервиса.
        </p>

        <p>Могут обрабатываться:</p>

        <ul class="floating-ui__dialog-list">
          <li>IP-адрес</li>
          <li>данные браузера и устройства</li>
          <li>действия пользователя на сайте</li>
          <li>источник перехода</li>
          <li>дата и время посещения</li>
        </ul>

        <p>
          Продолжая пользоваться сайтом или нажимая «Принять», вы соглашаетесь с
          использованием cookies.
        </p>

        <p>
          Подробнее об обработке персональных данных —
          <button
            class="floating-ui__policy-link"
            type="button"
            data-cookie-open-privacy
          >
            в Политике конфиденциальности
          </button>.
        </p>
      </div>
    </div>
  </dialog>
</div>

<style is:global>
  /* ── Scroll-top button ── */
  .floating-ui__scroll-top {
    position: fixed;
    right: 22px;
    bottom: 22px;
    z-index: 60;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 999px;
    background: rgba(16, 24, 39, 0.88);
    color: #ffffff;
    box-shadow: 0 8px 24px rgba(5, 10, 20, 0.22);
    backdrop-filter: blur(12px);
    cursor: pointer;
    opacity: 0;
    visibility: hidden;
    transform: translateY(10px);
    transition:
      opacity var(--motion-base) var(--motion-ease-productive),
      visibility var(--motion-base) var(--motion-ease-productive),
      transform var(--motion-page) var(--motion-ease),
      background-color var(--motion-base) var(--motion-ease-productive),
      border-color var(--motion-base) var(--motion-ease-productive);
  }

  .floating-ui__scroll-top.is-visible {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .floating-ui__scroll-top:hover {
    background: rgba(12, 20, 34, 0.96);
    border-color: rgba(255, 255, 255, 0.24);
  }

  .floating-ui__scroll-top svg {
    width: 22px;
    height: 22px;
  }

  /* ── Cookie widget wrapper ── */
  .cookie-widget {
    position: fixed;
    left: 22px;
    bottom: 22px;
    z-index: 60;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    opacity: 0;
    visibility: hidden;
    transform: translateY(12px);
    transition:
      opacity var(--motion-base) var(--motion-ease-productive),
      visibility var(--motion-base) var(--motion-ease-productive),
      transform var(--motion-page) var(--motion-ease);
  }

  .cookie-widget.is-visible {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  /* ── Cookie icon trigger ── */
  .cookie-widget__trigger {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 46px;
    height: 46px;
    padding: 0;
    border-radius: 999px;
    border: 1px solid rgba(17, 17, 17, 0.10);
    background: rgba(255, 255, 255, 0.96);
    box-shadow:
      0 2px 0 rgba(17, 17, 17, 0.04),
      0 8px 22px rgba(9, 17, 30, 0.14);
    cursor: pointer;
    transition:
      transform var(--motion-base) var(--motion-ease),
      box-shadow var(--motion-base) var(--motion-ease-productive);
  }

  .cookie-widget__trigger:hover {
    transform: translateY(-2px);
    box-shadow:
      0 2px 0 rgba(17, 17, 17, 0.04),
      0 12px 28px rgba(9, 17, 30, 0.18);
  }

  .cookie-widget__icon {
    display: block;
    width: 26px;
    height: 26px;
    object-fit: contain;
  }

  /* ── Cookie panel (opens above trigger) ── */
  .cookie-widget__panel {
    display: grid;
    grid-template-rows: 0fr;
    width: min(340px, calc(100vw - 44px));
    margin-bottom: 0;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 20px;
    background: rgba(16, 24, 39, 0.96);
    color: #ffffff;
    box-shadow: 0 16px 48px rgba(5, 10, 20, 0.32);
    backdrop-filter: blur(16px);
    opacity: 0;
    visibility: hidden;
    transform: translateY(8px) scale(0.985);
    pointer-events: none;
    overflow: hidden;
    transition:
      grid-template-rows var(--motion-page) var(--motion-ease),
      margin-bottom var(--motion-page) var(--motion-ease),
      opacity var(--motion-base) var(--motion-ease-productive),
      transform var(--motion-page) var(--motion-ease),
      visibility var(--motion-base) var(--motion-ease-productive);
  }

  .cookie-widget.is-open .cookie-widget__panel {
    grid-template-rows: 1fr;
    margin-bottom: 10px;
    opacity: 1;
    visibility: visible;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }

  .cookie-widget__panel-inner {
    min-height: 0;
    overflow: hidden;
    padding: 0 18px;
    transition: padding var(--motion-page) var(--motion-ease);
  }

  .cookie-widget.is-open .cookie-widget__panel-inner {
    padding-top: 18px;
    padding-bottom: 18px;
  }

  .cookie-widget__title {
    margin: 0;
    font-size: 15px;
    font-weight: 700;
    line-height: 1.2;
  }

  .cookie-widget__text {
    margin: 10px 0 0;
    color: rgba(255, 255, 255, 0.68);
    font-size: 14px;
    line-height: 1.55;
  }

  .cookie-widget__actions {
    display: flex;
    gap: 10px;
    margin-top: 16px;
  }

  .cookie-widget__button {
    min-height: 42px;
    padding: 0 16px;
    border-radius: 999px;
    font: inherit;
    font-size: 14px;
    font-weight: 700;
    cursor: pointer;
    transition:
      transform 0.2s ease,
      opacity 0.2s ease,
      background-color 0.2s ease,
      color 0.2s ease,
      border-color 0.2s ease;
  }

  .cookie-widget__button:hover {
    transform: translateY(-1px);
  }

  .cookie-widget__button--primary {
    border: 0;
    background: #e53935;
    color: #ffffff;
  }

  .cookie-widget__button--secondary {
    border: 1px solid rgba(255, 255, 255, 0.16);
    background: rgba(255, 255, 255, 0.08);
    color: #ffffff;
  }

  /* ── Info dialog ── */
  .floating-ui__dialog {
    width: min(760px, calc(100% - 24px));
    padding: 0;
    border: 0;
    border-radius: 24px;
    background: transparent;
    box-shadow: none;
  }

  .floating-ui__dialog::backdrop {
    background: rgba(8, 12, 21, 0.62);
    backdrop-filter: blur(4px);
  }

  .floating-ui__dialog-inner {
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.78);
    border-radius: 24px;
    background: #ffffff;
    box-shadow: 0 28px 80px rgba(7, 16, 34, 0.26);
  }

  .floating-ui__dialog-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 18px;
    padding: 24px 24px 18px;
    border-bottom: 1px solid rgba(17, 17, 17, 0.08);
  }

  .floating-ui__dialog-eyebrow {
    margin: 0 0 10px;
    color: #d94a43;
    font-size: 12px;
    font-weight: 700;
    line-height: 1;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .floating-ui__dialog-title {
    margin: 0;
    color: #152033;
    font-size: 28px;
    line-height: 1.08;
    letter-spacing: -0.02em;
  }

  .floating-ui__dialog-close {
    flex: 0 0 auto;
    width: 42px;
    height: 42px;
    border: 1px solid rgba(17, 17, 17, 0.08);
    border-radius: 999px;
    background: #f4f6f8;
    color: #152033;
    font-size: 28px;
    line-height: 1;
    cursor: pointer;
  }

  .floating-ui__dialog-body {
    max-height: 70vh;
    overflow: auto;
    padding: 22px 24px 24px;
  }

  .floating-ui__dialog-body p {
    margin: 0 0 14px;
    color: #526174;
    font-size: 15px;
    line-height: 1.7;
  }

  .floating-ui__dialog-list {
    margin: 0 0 16px;
    padding-left: 20px;
    color: #526174;
    font-size: 15px;
    line-height: 1.7;
  }

  .floating-ui__policy-link {
    display: inline;
    padding: 0;
    border: 0;
    background: none;
    color: #2c4e85;
    font: inherit;
    font-weight: 500;
    text-decoration: underline;
    text-underline-offset: 2px;
    cursor: pointer;
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .floating-ui__scroll-top {
      right: 14px;
      bottom: 14px;
      width: 46px;
      height: 46px;
    }

    .cookie-widget {
      left: 14px;
      bottom: 14px;
    }

    .cookie-widget__panel {
      width: min(320px, calc(100vw - 28px));
      border-radius: 18px;
    }

    .cookie-widget__panel-inner {
      padding-right: 16px;
      padding-left: 16px;
    }

    .cookie-widget.is-open .cookie-widget__panel-inner {
      padding-top: 16px;
      padding-bottom: 16px;
    }

    .cookie-widget__actions {
      flex-direction: column;
    }

    .cookie-widget__button {
      width: 100%;
    }

    .floating-ui__dialog {
      width: calc(100% - 16px);
    }

    .floating-ui__dialog-head {
      padding: 18px 18px 14px;
    }

    .floating-ui__dialog-title {
      font-size: 22px;
    }

    .floating-ui__dialog-body {
      padding: 16px 18px 18px;
    }
  }
</style>

<script is:inline>
  const cookieStorageKey = 'raluma-cookie-consent';
  const scrollTopButton = document.querySelector('[data-scroll-top]');
  const cookieWidget = document.querySelector('[data-cookie-widget]');
  const cookieTrigger = document.querySelector('[data-cookie-trigger]');
  const cookieAccept = document.querySelector('[data-cookie-accept]');
  const cookieMore = document.querySelector('[data-cookie-more]');
  const cookieDialog = document.getElementById('cookie-info-dialog');

  const getHeroThreshold = () => {
    const hero = document.querySelector('.hero');
    if (hero) return hero.offsetHeight * 0.85;
    return window.innerHeight * 0.85;
  };

  const updateFloatingUi = () => {
    const showScrollTop = window.scrollY > getHeroThreshold();

    if (scrollTopButton) {
      scrollTopButton.classList.toggle('is-visible', showScrollTop);
    }

    const consentState = window.localStorage.getItem(cookieStorageKey);
    const showCookieWidget = consentState === 'accepted' ? false : window.scrollY > 24;

    if (cookieWidget) {
      cookieWidget.classList.toggle('is-visible', showCookieWidget);
    }
  };

  if (scrollTopButton) {
    scrollTopButton.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }

  if (cookieTrigger && cookieWidget) {
    cookieTrigger.addEventListener('click', () => {
      cookieWidget.classList.toggle('is-open');
    });
  }

  if (cookieAccept && cookieWidget) {
    cookieAccept.addEventListener('click', () => {
      window.localStorage.setItem(cookieStorageKey, 'accepted');
      cookieWidget.classList.remove('is-open');
      cookieWidget.classList.remove('is-visible');
    });
  }

  if (cookieMore && cookieDialog && typeof cookieDialog.showModal === 'function') {
    cookieMore.addEventListener('click', () => {
      cookieDialog.showModal();
    });
  }

  document.querySelectorAll('[data-cookie-dialog-close]').forEach((button) => {
    button.addEventListener('click', () => {
      const dialog = button.closest('dialog');
      if (dialog) dialog.close();
    });
  });

  const openPrivacyDialog = () => {
    const privacyDialog = document.getElementById('privacy-dialog');
    if (cookieDialog) cookieDialog.close();
    if (privacyDialog && typeof privacyDialog.showModal === 'function') {
      privacyDialog.showModal();
    }
  };

  document.querySelectorAll('[data-cookie-open-privacy]').forEach((button) => {
    button.addEventListener('click', openPrivacyDialog);
  });

  if (cookieDialog) {
    cookieDialog.addEventListener('click', (event) => {
      const rect = cookieDialog.getBoundingClientRect();
      const inside =
        rect.top <= event.clientY &&
        event.clientY <= rect.top + rect.height &&
        rect.left <= event.clientX &&
        event.clientX <= rect.left + rect.width;

      if (inside === false) cookieDialog.close();
    });
  }

  document.addEventListener('click', (event) => {
    if (cookieWidget && cookieWidget.classList.contains('is-open')) {
      const target = event.target;
      const clickedInside = target instanceof Node ? cookieWidget.contains(target) : false;
      if (clickedInside === false) {
        cookieWidget.classList.remove('is-open');
      }
    }
  });

  updateFloatingUi();
  let floatingUpdateScheduled = false;
  const scheduleFloatingUiUpdate = () => {
    if (floatingUpdateScheduled) return;
    floatingUpdateScheduled = true;
    window.requestAnimationFrame(() => {
      floatingUpdateScheduled = false;
      updateFloatingUi();
    });
  };

  window.addEventListener('scroll', scheduleFloatingUiUpdate, { passive: true });
  window.addEventListener('resize', scheduleFloatingUiUpdate);
</script>
