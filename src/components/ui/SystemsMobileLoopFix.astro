<style is:global>
  @media (max-width: 1120px) {
    .systems-selector-shell {
      padding-bottom: 42px !important;
    }

    .systems-selector-shell::after {
      display: none !important;
      content: none !important;
    }

    .systems-selector {
      margin-right: 0 !important;
      padding-right: 0 !important;
      overscroll-behavior-inline: contain;
      scroll-padding-inline: 18px;
      touch-action: pan-x pan-y;
    }

    .systems-selector__mobile-hint {
      left: 50% !important;
      right: auto !important;
      transform: translateX(-50%);
      justify-content: center;
      width: max-content;
      max-width: calc(100% - 24px);
      text-align: center;
    }

    .systems-detail {
      display: flex !important;
      flex-direction: column !important;
      grid-template-columns: none !important;
      gap: 14px !important;
      overflow: visible !important;
      touch-action: pan-y pinch-zoom;
    }

    .systems-detail__media,
    .systems-detail__schema-panel {
      position: static !important;
      top: auto !important;
      width: 100% !important;
      max-width: none !important;
      max-height: none !important;
      min-height: 0 !important;
      align-self: stretch !important;
    }

    .systems-detail__media {
      order: 1;
    }

    .systems-detail__schema-panel {
      order: 2;
      display: flex !important;
      overflow: visible !important;
    }

    .systems-detail__schema-main,
    .systems-detail__schema-frame,
    .systems-detail__schema-frame img {
      width: 100% !important;
      max-width: 100% !important;
    }

    .systems-detail__schema-frame {
      box-sizing: border-box;
    }
  }

  @media (max-width: 767px) {
    .systems-selector {
      gap: 10px !important;
      padding-inline: 0 !important;
    }

    .systems-selector__item {
      box-sizing: border-box;
      flex: 0 0 calc(100vw - 48px) !important;
      max-width: calc(100vw - 48px) !important;
    }

    .systems-detail__schema-panel {
      padding: 18px !important;
    }

    .systems-detail__schema-head {
      display: grid !important;
      grid-template-columns: 1fr !important;
      gap: 14px !important;
      align-items: start !important;
    }

    .systems-detail__schema-title {
      max-width: none !important;
    }

    .systems-detail__zoom {
      width: 100% !important;
    }
  }
</style>

<script is:inline>
  (function () {
    function initSystemsLoop() {
      var section = document.querySelector('.systems-section');
      var selector = section && section.querySelector('.systems-selector');
      if (!section || !selector || selector.dataset.loopReady === 'true') return;

      var originals = Array.from(selector.querySelectorAll('[data-system-tab]'));
      if (originals.length < 2) return;

      selector.dataset.loopReady = 'true';
      originals.forEach(function (button) {
        button.dataset.loopOriginal = 'true';
      });

      function makeClone(button) {
        var clone = button.cloneNode(true);
        clone.dataset.loopClone = 'true';
        clone.removeAttribute('id');
        clone.setAttribute('aria-hidden', 'true');
        clone.setAttribute('tabindex', '-1');
        clone.addEventListener('click', function () {
          var target = originals.find(function (item) {
            return item.dataset.systemTab === clone.dataset.systemTab;
          });
          if (target) target.click();
        });
        return clone;
      }

      var leftClones = originals.map(makeClone);
      var rightClones = originals.map(makeClone);
      var leftFragment = document.createDocumentFragment();
      var rightFragment = document.createDocumentFragment();

      leftClones.forEach(function (clone) { leftFragment.appendChild(clone); });
      rightClones.forEach(function (clone) { rightFragment.appendChild(clone); });
      selector.insertBefore(leftFragment, originals[0]);
      selector.appendChild(rightFragment);

      function getActiveOriginal() {
        return originals.find(function (button) {
          return button.classList.contains('is-active');
        }) || originals[0];
      }

      function syncCloneStates() {
        var active = getActiveOriginal();
        var activeId = active ? active.dataset.systemTab || '' : '';
        selector.querySelectorAll('[data-loop-clone]').forEach(function (clone) {
          clone.classList.toggle('is-active', clone.dataset.systemTab === activeId);
        });
      }

      var observer = new MutationObserver(syncCloneStates);
      originals.forEach(function (button) {
        observer.observe(button, { attributes: true, attributeFilter: ['class', 'aria-selected'] });
      });
      syncCloneStates();

      var resetting = false;
      var span = 0;
      var leftBoundary = 0;
      var rightBoundary = 0;
      var horizontalIntentUntil = 0;
      var gestureStartX = 0;
      var gestureStartY = 0;
      var lastViewportWidth = window.innerWidth;

      function centerButton(button) {
        if (!button) return;
        resetting = true;
        var snap = selector.style.scrollSnapType;
        var behavior = selector.style.scrollBehavior;
        selector.style.scrollSnapType = 'none';
        selector.style.scrollBehavior = 'auto';
        selector.scrollLeft = button.offsetLeft - (selector.clientWidth - button.offsetWidth) / 2;
        window.requestAnimationFrame(function () {
          selector.style.scrollSnapType = snap;
          selector.style.scrollBehavior = behavior;
          resetting = false;
        });
      }

      function measureAndPreserveActive() {
        var firstOriginal = originals[0];
        var firstRight = rightClones[0];
        var lastLeft = leftClones[leftClones.length - 1];
        var lastOriginal = originals[originals.length - 1];
        if (!firstOriginal || !firstRight || !lastLeft || !lastOriginal) return;

        span = firstRight.offsetLeft - firstOriginal.offsetLeft;
        leftBoundary = (lastLeft.offsetLeft + lastLeft.offsetWidth + firstOriginal.offsetLeft) / 2;
        rightBoundary = (lastOriginal.offsetLeft + lastOriginal.offsetWidth + firstRight.offsetLeft) / 2;
        centerButton(getActiveOriginal());
      }

      function jumpBy(delta) {
        if (!delta || resetting) return;
        resetting = true;
        var snap = selector.style.scrollSnapType;
        var behavior = selector.style.scrollBehavior;
        selector.style.scrollSnapType = 'none';
        selector.style.scrollBehavior = 'auto';
        selector.scrollLeft += delta;
        window.requestAnimationFrame(function () {
          selector.style.scrollSnapType = snap;
          selector.style.scrollBehavior = behavior;
          resetting = false;
        });
      }

      selector.addEventListener('touchstart', function (event) {
        if (event.touches.length !== 1) return;
        gestureStartX = event.touches[0].clientX;
        gestureStartY = event.touches[0].clientY;
        horizontalIntentUntil = 0;
      }, { passive: true });

      selector.addEventListener('touchmove', function (event) {
        if (event.touches.length !== 1) return;
        var dx = event.touches[0].clientX - gestureStartX;
        var dy = event.touches[0].clientY - gestureStartY;
        if (Math.abs(dx) > 10 && Math.abs(dx) > Math.abs(dy) * 1.25) {
          horizontalIntentUntil = Date.now() + 700;
        }
      }, { passive: true });

      selector.addEventListener('touchend', function () {
        if (horizontalIntentUntil) horizontalIntentUntil = Date.now() + 350;
      }, { passive: true });

      selector.addEventListener('wheel', function (event) {
        if (Math.abs(event.deltaX) > Math.abs(event.deltaY)) {
          horizontalIntentUntil = Date.now() + 500;
        }
      }, { passive: true });

      selector.addEventListener('scroll', function (event) {
        var center = selector.scrollLeft + selector.clientWidth / 2;

        if (!resetting && span) {
          if (center < leftBoundary) jumpBy(span);
          if (center > rightBoundary) jumpBy(-span);
        }

        if (resetting || Date.now() > horizontalIntentUntil) {
          event.stopImmediatePropagation();
        }
      }, { capture: true, passive: true });

      /* The original component also supports swiping the large detail card.
         On a phone this conflicts with normal vertical page scrolling, so the
         detail card is deliberately vertical-only. Systems are changed through
         the selector above, where horizontal intent can be measured reliably. */
      var detail = section.querySelector('.systems-detail');
      if (detail) {
        ['touchmove', 'touchend', 'touchcancel'].forEach(function (type) {
          detail.addEventListener(type, function (event) {
            event.stopImmediatePropagation();
          }, { capture: true, passive: true });
        });
      }

      window.requestAnimationFrame(measureAndPreserveActive);
      if (document.fonts && document.fonts.ready) {
        document.fonts.ready.then(measureAndPreserveActive);
      }

      window.addEventListener('resize', function () {
        var nextWidth = window.innerWidth;

        /* Mobile browsers fire resize while their address bar opens and closes.
           That changes only viewport height and must never move the carousel. */
        if (Math.abs(nextWidth - lastViewportWidth) < 3) return;
        lastViewportWidth = nextWidth;

        window.clearTimeout(selector._systemsLoopResizeTimer);
        selector._systemsLoopResizeTimer = window.setTimeout(measureAndPreserveActive, 120);
      }, { passive: true });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initSystemsLoop, { once: true });
    } else {
      initSystemsLoop();
    }
  })();
</script>
