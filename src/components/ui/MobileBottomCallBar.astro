---
const phoneHref = 'tel:+78123307415';
const isHomePage = Astro.url.pathname === '/';
---

<nav
  class:list={['mobile-actionbar', { 'mobile-actionbar--phone-only': !isHomePage }]}
  aria-label="Быстрые действия"
  data-mobile-actionbar
  data-always-visible={!isHomePage ? '' : undefined}
>
  {isHomePage && (
    <a class="mobile-actionbar__primary" href="#lead-form">
      Получить расчёт
    </a>
  )}

  <a class="mobile-actionbar__phone" href={phoneHref} aria-label="Позвонить в Raluma">
    <svg
      viewBox="0 0 24 24"
      aria-hidden="true"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.86 19.86 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.86 19.86 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.12.9.35 1.78.68 2.62a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.46-1.25a2 2 0 0 1 2.11-.45c.84.33 1.72.56 2.62.68A2 2 0 0 1 22 16.92z" />
    </svg>
  </a>
</nav>

<script>
  const initMobileActionbar = () => {
    const actionbar = document.querySelector('[data-mobile-actionbar]');
    if (!actionbar) return;

    const update = () => {
      const threshold = Math.min(window.innerHeight * 0.55, 420);
      const alwaysVisible = actionbar.hasAttribute('data-always-visible');
      actionbar.classList.toggle('is-visible', alwaysVisible || window.scrollY > threshold);
    };

    update();
    window.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update);
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMobileActionbar, { once: true });
  } else {
    initMobileActionbar();
  }
</script>

<style>
  .mobile-actionbar {
    display: none;
  }

  @media (max-width: 768px) {
    :global(body) {
      padding-bottom: calc(88px + env(safe-area-inset-bottom));
    }

    .mobile-actionbar {
      position: fixed;
      left: 50%;
      bottom: calc(12px + env(safe-area-inset-bottom));
      transform: translateX(-50%);
      z-index: 48;
      display: flex;
      align-items: center;
      gap: 8px;
      opacity: 0;
      visibility: hidden;
      transform: translate(-50%, 12px);
      pointer-events: none;
      transition: opacity 0.2s ease, visibility 0.2s ease, transform 0.2s ease;
    }

    .mobile-actionbar.is-visible {
      opacity: 1;
      visibility: visible;
      transform: translate(-50%, 0);
    }

    .mobile-actionbar__primary,
    .mobile-actionbar__phone {
      pointer-events: auto;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 48px;
      border-radius: 999px;
      text-decoration: none;
      box-shadow: 0 14px 34px rgba(9, 17, 30, 0.18);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
    }

    .mobile-actionbar__primary {
      padding: 0 17px;
      background: rgba(229, 57, 53, 0.96);
      color: #ffffff;
      font-size: 13px;
      line-height: 1;
      font-weight: 800;
      white-space: nowrap;
    }

    .mobile-actionbar__phone {
      flex: 0 0 48px;
      width: 48px;
      border: 1px solid rgba(17, 17, 17, 0.08);
      background: rgba(255, 255, 255, 0.96);
      color: #111111;
    }

    .mobile-actionbar__phone svg {
      width: 18px;
      height: 18px;
    }

    .mobile-actionbar__primary:active,
    .mobile-actionbar__phone:active {
      transform: scale(0.98);
    }
  }

  @media (max-width: 360px) {
    .mobile-actionbar__primary {
      padding: 0 13px;
      font-size: 12px;
    }

    .mobile-actionbar__phone {
      flex-basis: 46px;
      width: 46px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .mobile-actionbar__primary,
    .mobile-actionbar__phone {
      transition: none;
    }
  }
</style>
