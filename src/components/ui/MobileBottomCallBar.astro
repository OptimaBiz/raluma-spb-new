---
import '../../styles/mobile-actionbar.css';

const phoneHref = 'tel:+78123307415';
const isHomePage = Astro.url.pathname === '/';
const isPergolasPage = Astro.url.pathname === '/pergolas' || Astro.url.pathname === '/pergolas/';
const hasLeadForm = isHomePage || isPergolasPage;
---

<nav
  class:list={['mobile-actionbar', { 'mobile-actionbar--phone-only': !hasLeadForm }]}
  aria-label="Быстрые действия"
  data-mobile-actionbar
  data-always-visible={!isHomePage ? '' : undefined}
>
  {hasLeadForm && (
    <a class="mobile-actionbar__primary" href="#lead-form">
      Получить расчёт
    </a>
  )}

  <a class="mobile-actionbar__phone" href={phoneHref} data-goal="phone_click_float" aria-label="Позвонить в Raluma">
    <svg
      viewBox="0 0 24 24"
      aria-hidden="true"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.86 19.86 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.86 19.86 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.12.9.35 1.78.68 2.62a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.46-1.25a2 2 0 0 1 2.11-.45c.84.33 1.72.56 2.62.68A2 2 0 0 1 22 16.92z" />
    </svg>
  </a>
</nav>

<script>
  const initMobileActionbar = () => {
    const actionbar = document.querySelector('[data-mobile-actionbar]');
    if (!actionbar) return;

    const primaryAction = actionbar.querySelector('.mobile-actionbar__primary');
    const leadForm = document.getElementById('lead-form');
    let updateScheduled = false;

    const update = () => {
      const threshold = Math.min(window.innerHeight * 0.55, 420);
      const alwaysVisible = actionbar.hasAttribute('data-always-visible');
      actionbar.classList.toggle('is-visible', alwaysVisible || window.scrollY > threshold);

      if (primaryAction && leadForm) {
        const formTriggerLine = Math.max(0, Math.min(window.innerHeight * 0.72, window.innerHeight - 96));
        const formReached = leadForm.getBoundingClientRect().top <= formTriggerLine;
        primaryAction.hidden = formReached;
        actionbar.classList.toggle('is-form-mode', formReached);
      }
    };

    const scheduleUpdate = () => {
      if (updateScheduled) return;
      updateScheduled = true;
      window.requestAnimationFrame(() => {
        updateScheduled = false;
        update();
      });
    };

    update();
    window.addEventListener('scroll', scheduleUpdate, { passive: true });
    window.addEventListener('resize', scheduleUpdate);
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMobileActionbar, { once: true });
  } else {
    initMobileActionbar();
  }
</script>
