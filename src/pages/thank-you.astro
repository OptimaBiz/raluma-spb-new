---
import BaseLayout from '../layouts/BaseLayout.astro';

const phone = '+7 (812) 330-74-15';
const phoneHref = 'tel:+78123307415';
---

<BaseLayout
  title="Спасибо — Raluma"
  description="Заявка принята. Свяжемся в течение рабочего дня, подберём систему и подготовим расчёт."
  canonical="https://raluma.com.ru/thank-you/"
  noindex={true}
>
  <section class="thank-you-page">
    <div class="thank-you-page__wrap">
      <p class="thank-you-page__eyebrow">Заявка отправлена</p>

      <h1 class="thank-you-page__title">
        Спасибо. Мы получили вашу заявку.
      </h1>

      <p class="thank-you-page__lead">
        Свяжемся в течение рабочего дня, уточним детали объекта и подготовим расчёт
        под ваш проём, сценарий использования и выбранную систему.
      </p>

      <div class="thank-you-page__actions">
        <a class="thank-you-page__button thank-you-page__button--dark" href="/">
          Вернуться на главную
        </a>

        <a class="thank-you-page__button thank-you-page__button--light" href={phoneHref}>
          Позвонить {phone}
        </a>
      </div>
    </div>
  </section>

  <style>
    .thank-you-page {
      min-height: 100svh;
      display: flex;
      align-items: center;
      background:
        radial-gradient(circle at top left, rgba(228, 67, 54, 0.06), transparent 24%),
        linear-gradient(180deg, #f5f3f1 0%, #efedeb 100%);
      color: #111111;
    }

    .thank-you-page__wrap {
      width: 100%;
      max-width: 960px;
      margin: 0 auto;
      padding: clamp(96px, 10vw, 148px) 24px;
      text-align: center;
    }

    .thank-you-page__eyebrow {
      margin: 0 0 16px;
      font-size: 12px;
      line-height: 1.2;
      font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: #e44336;
    }

    .thank-you-page__title {
      margin: 0 auto;
      max-width: 12ch;
      font-size: clamp(40px, 6vw, 72px);
      line-height: 0.96;
      letter-spacing: -0.05em;
      font-weight: 700;
      text-wrap: balance;
    }

    .thank-you-page__lead {
      margin: 22px auto 0;
      max-width: 720px;
      font-size: clamp(18px, 1.55vw, 22px);
      line-height: 1.68;
      color: #5f6773;
      text-wrap: balance;
    }

    .thank-you-page__actions {
      display: flex;
      justify-content: center;
      gap: 12px;
      flex-wrap: wrap;
      margin-top: 30px;
    }

    .thank-you-page__button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 50px;
      padding: 0 20px;
      border-radius: 999px;
      font-size: 14px;
      line-height: 1;
      font-weight: 700;
      text-decoration: none;
      transition:
        transform 0.22s ease,
        background 0.22s ease,
        box-shadow 0.22s ease,
        border-color 0.22s ease;
    }

    .thank-you-page__button:hover {
      transform: translateY(-1px);
    }

    .thank-you-page__button--dark {
      background: #111111;
      color: #ffffff;
      border: 1px solid #111111;
      box-shadow: 0 16px 34px rgba(17, 17, 17, 0.14);
    }

    .thank-you-page__button--light {
      background: rgba(255, 255, 255, 0.82);
      color: #111111;
      border: 1px solid rgba(17, 17, 17, 0.08);
      box-shadow: 0 12px 28px rgba(17, 17, 17, 0.08);
    }

    @media (max-width: 767px) {
      .thank-you-page__wrap {
        padding: 88px 18px;
      }

      .thank-you-page__title {
        max-width: 10ch;
        font-size: clamp(34px, 10vw, 52px);
      }

      .thank-you-page__lead {
        font-size: 16px;
        line-height: 1.62;
      }

      .thank-you-page__actions {
        flex-direction: column;
      }

      .thank-you-page__button {
        width: 100%;
      }
    }
  </style>
</BaseLayout>
