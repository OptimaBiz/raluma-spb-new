          <p class="eyebrow eyebrow--edge">Вопросы до замера</p>
          <h2 class="title" id="pergola-faq-title">Главное о перголах</h2>
          <p class="lead">Точную конфигурацию определяем по объекту, но базовые ответы можно получить заранее.</p>
        </div>

        <div class="pergola-faq__list">
          {faq.map((item, index) => (
            <details class="pergola-faq__item rise" open={index === 0}>
              <summary>
                <span>{item.question}</span>
                <span class="pergola-faq__plus" aria-hidden="true">+</span>
              </summary>
              <p>{item.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section class="pergola-final-cta seams seams--deep" aria-labelledby="pergola-final-title">
      <div class="shell pergola-final-cta__inner rise">
        <p class="eyebrow">Предварительный расчёт</p>
        <h2 id="pergola-final-title">Пришлите фотографию фасада или участка</h2>
        <p>
          Оценим возможную конфигурацию и зададим вопросы, которые действительно влияют
          на стоимость проекта.
        </p>
        <a class="btn pergola-final-cta__button" href="#lead-form" data-pergola-goal="pergolas_final_calculate">
          Перейти к форме
        </a>
      </div>
