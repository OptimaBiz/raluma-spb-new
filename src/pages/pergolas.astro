---
import BaseLayout from '../layouts/BaseLayout.astro';
import LeadFormSection from '../components/sections/LeadFormSection.astro';
import FooterSection from '../components/sections/FooterSection.astro';

const images = {
  hero: 'https://thb.tildacdn.com/tild3830-6335-4235-a337-663062393435/-/resize/1900x/3.jpg',
  louvered: 'https://thb.tildacdn.com/tild3533-6633-4535-b039-323632373730/-/resize/1500x/1.jpg',
  glass: 'https://thb.tildacdn.com/tild3730-3338-4066-b261-626564313738/-/resize/1500x/2.jpg',
  size3x3: 'https://thb.tildacdn.com/tild3533-6633-4535-b039-323632373730/-/resize/1000x/1.jpg',
  size3x4: 'https://thb.tildacdn.com/tild3730-3338-4066-b261-626564313738/-/resize/1000x/2.jpg',
  size4x5: 'https://thb.tildacdn.com/tild3830-6335-4235-a337-663062393435/-/resize/1000x/3.jpg',
  finish: 'https://thb.tildacdn.com/tild3230-3532-4638-b336-623064663766/-/resize/1100x/photo.png',
  glassSample: 'https://thb.tildacdn.com/tild3266-3031-4862-a333-626433303433/-/resize/900x/4.png',
  decor: 'https://thb.tildacdn.com/tild3430-6261-4338-a630-623431613434/-/resize/900x/5.png',
};

const roofStates = [
  {
    id: 'closed',
    number: '01',
    title: 'Полностью закрыты',
    text: 'Ламели образуют плотную крышу и защищают пространство от осадков и прямого солнца.',
    angle: '0°',
  },
  {
    id: 'shade',
    number: '02',
    title: 'Открыты под углом',
    text: 'Мягкая тень сохраняется, а между ламелями проходит воздух — комфортно даже в жаркий день.',
    angle: '45°',
  },
  {
    id: 'open',
    number: '03',
    title: 'Полностью открыты',
    text: 'Максимум естественного света, открытого неба и свободного проветривания.',
    angle: '90°',
  },
];

const sizes = [
  { size: '3 × 3 м', height: 'высота 2,8 м', image: images.size3x3 },
  { size: '3 × 4 м', height: 'высота 2,8 м', image: images.size3x4 },
  { size: '4 × 5 м', height: 'высота 2,8 м', image: images.size4x5 },
];

const faq = [
  {
    question: 'Подходит ли пергола для климата Санкт-Петербурга?',
    answer: 'Да. Конфигурацию рассчитываем с учётом ветровой и снеговой нагрузки конкретного объекта, способа примыкания и места установки. Для Петербурга особенно важны усиленный каркас и корректный водоотвод.',
  },
  {
    question: 'Можно ли установить перголу у уже построенного дома?',
    answer: 'Можно. Пергола может примыкать к фасаду либо стоять отдельно. Перед проектированием проверяем основание, точки крепления, высоты, водостоки и открывание существующих дверей и окон.',
  },
  {
    question: 'Можно ли полностью закрыть перголу стеклом?',
    answer: 'Да. В конструкцию можно интегрировать безрамные системы «Слайд», «Книжка» или «Лифт» и получить защищённое пространство без тяжёлых вертикальных рам.',
  },
  {
    question: 'Куда уходит вода при закрытой ламельной крыше?',
    answer: 'Вода собирается во встроенных желобах и уходит через скрытые каналы внутри колонн. Снаружи не остаётся навесных труб, нарушающих архитектуру.',
  },
  {
    question: 'Можно ли выбрать цвет и дополнительные опции?',
    answer: 'Да. Доступно окрашивание по каталогу RAL, фактурные покрытия и декор под дерево. Также можно предусмотреть освещение, автоматику, датчики погоды, обогрев и остекление.',
  },
  {
    question: 'Сколько занимает изготовление и монтаж?',
    answer: 'Срок зависит от размера, покрытия, автоматики и остекления. После замера и согласования конфигурации фиксируем этапы и срок в договоре.',
  },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Биоклиматические перголы под ключ',
  provider: {
    '@type': 'Organization',
    name: 'Raluma СПб',
    telephone: '+7-812-330-74-15',
  },
  areaServed: ['Санкт-Петербург', 'Ленинградская область'],
  serviceType: 'Проектирование, изготовление и монтаж алюминиевых пергол',
  url: 'https://raluma.com.ru/pergolas/',
};
---

<BaseLayout
  title="Биоклиматические перголы под ключ в Санкт-Петербурге — Raluma"
  description="Алюминиевые биоклиматические перголы с поворотной или стеклянной крышей в Санкт-Петербурге и Ленинградской области. Проектирование, изготовление, монтаж и безрамное остекление."
  canonical="https://raluma.com.ru/pergolas/"
  ogImage={images.hero}
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>

  <main class="pergolas-page">
    <section class="pergola-hero" aria-labelledby="pergola-hero-title">
      <div class="pergola-hero__media" aria-hidden="true">
        <img
          src={images.hero}
          alt=""
          width="1900"
          height="1200"
          loading="eager"
          decoding="async"
          fetchpriority="high"
          referrerpolicy="no-referrer-when-downgrade"
        />
      </div>

      <div class="shell pergola-hero__inner">
        <div class="pergola-hero__copy">
          <p class="eyebrow pergola-hero__eyebrow">Санкт-Петербург и Ленинградская область</p>
          <h1 class="pergola-hero__title" id="pergola-hero-title">
            Биоклиматические перголы под ключ
          </h1>
          <p class="pergola-hero__lead">
            Создаём полноценное пространство с регулируемой или стеклянной крышей,
            скрытым водоотводом, автоматикой и безрамным остеклением.
          </p>

          <div class="pergola-hero__actions">
            <a
              class="btn pergola-hero__primary"
              href="#lead-form"
              data-pergola-goal="pergolas_hero_calculate"
            >
              Рассчитать стоимость
            </a>
            <a
              class="btn btn--on-deep"
              href="tel:+78123307415"
              data-goal="phone_click_pergolas_hero"
            >
              +7 (812) 330-74-15
            </a>
          </div>

          <dl class="pergola-hero__facts">
            <div>
              <dt>2</dt>
              <dd>типа крыши</dd>
            </div>
            <div>
              <dt>3</dt>
              <dd>системы остекления</dd>
            </div>
            <div>
              <dt>RAL</dt>
              <dd>индивидуальный цвет</dd>
            </div>
          </dl>
        </div>
      </div>
    </section>

    <section class="pergola-section pergola-types seams" aria-labelledby="pergola-types-title">
      <div class="shell">
        <div class="pergola-head rise">
          <p class="eyebrow eyebrow--edge">Выберите принцип крыши</p>
          <h2 class="title" id="pergola-types-title">Два решения для разных сценариев</h2>
          <p class="lead">
            Ламели управляют солнцем и вентиляцией. Стеклянная крыша постоянно сохраняет
            естественный свет и защищает от осадков.
          </p>
        </div>

        <div class="pergola-types__grid">
          <article class="pergola-type rise">
            <div class="pergola-type__media">
              <img
                src={images.louvered}
                alt="Ламельная биоклиматическая пергола Raluma"
                width="1500"
                height="980"
                loading="lazy"
                decoding="async"
                referrerpolicy="no-referrer-when-downgrade"
              />
            </div>
            <div class="pergola-type__body">
              <p class="figure pergola-type__number">01 / ламели</p>
              <h3>Регулируемая биоклиматическая крыша</h3>
              <p>
                Поворотные алюминиевые ламели меняют угол от закрытого положения до
                полностью открытого. Управление — дистанционно с пульта.
              </p>
              <ul>
                <li>Контроль солнца и тени</li>
                <li>Естественное проветривание</li>
                <li>Защита от дождя при закрытии</li>
              </ul>
            </div>
          </article>

          <article class="pergola-type rise">
            <div class="pergola-type__media">
              <img
                src={images.glass}
                alt="Алюминиевая пергола Raluma со стеклянной крышей"
                width="1500"
                height="980"
                loading="lazy"
                decoding="async"
                referrerpolicy="no-referrer-when-downgrade"
              />
            </div>
            <div class="pergola-type__body">
              <p class="figure pergola-type__number">02 / стекло</p>
              <h3>Пергола со стеклянной крышей</h3>
              <p>
                Прозрачная кровля наполняет пространство естественным светом и может быть
                самостоятельной конструкцией или продолжением архитектуры дома.
              </p>
              <ul>
                <li>Максимум естественного света</li>
                <li>Постоянная защита от осадков</li>
                <li>Интеграция в фасад или отдельная установка</li>
              </ul>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section class="pergola-section pergola-climate seams seams--deep" aria-labelledby="pergola-climate-title">
      <div class="shell pergola-climate__layout">
        <div class="pergola-climate__intro rise">
          <p class="eyebrow pergola-climate__eyebrow">Рассчитано на погоду</p>
          <h2 id="pergola-climate-title">Не летний навес, а инженерная конструкция</h2>
          <p>
            Для Петербурга важны не только внешний вид и автоматика. Проверяем снеговую и
            ветровую нагрузку, основание, примыкание к фасаду и путь отвода воды.
          </p>
        </div>

        <div class="pergola-climate__specs">
          <article class="pergola-spec rise">
            <span class="figure">105–125</span>
            <strong>кг/м²</strong>
            <p>заявленная снеговая нагрузка в зависимости от серии</p>
          </article>
          <article class="pergola-spec rise">
            <span class="figure">100–120</span>
            <strong>км/ч</strong>
            <p>предельная скорость ветра при открытых ламелях</p>
          </article>
          <article class="pergola-spec rise">
            <span class="figure">0–90°</span>
            <strong>поворот</strong>
            <p>плавная регулировка положения алюминиевых ламелей</p>
          </article>
          <article class="pergola-spec pergola-spec--wide rise">
            <span class="pergola-spec__icon" aria-hidden="true">↓</span>
            <div>
              <strong>Скрытая дренажная система</strong>
              <p>Вода собирается во встроенных желобах и уходит через каналы внутри колонн.</p>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section class="pergola-section pergola-roof seams" aria-labelledby="pergola-roof-title" data-roof-section>
      <div class="shell">
        <div class="pergola-head rise">
          <p class="eyebrow eyebrow--edge">Три состояния крыши</p>
          <h2 class="title" id="pergola-roof-title">Погода меняется — пространство остаётся вашим</h2>
        </div>

        <div class="pergola-roof__layout">
          <div class="pergola-roof__visual rise" data-roof-visual="closed">
            <div class="pergola-roof__frame" aria-hidden="true">
              <span class="pergola-roof__beam pergola-roof__beam--left"></span>
              <span class="pergola-roof__beam pergola-roof__beam--right"></span>
              <span class="pergola-roof__beam pergola-roof__beam--front"></span>
              <span class="pergola-roof__beam pergola-roof__beam--back"></span>
              <div class="pergola-roof__lamellas">
                {Array.from({ length: 12 }).map(() => <span></span>)}
              </div>
            </div>
            <p class="figure pergola-roof__angle" data-roof-angle>0°</p>
          </div>

          <div class="pergola-roof__controls" role="tablist" aria-label="Положения ламелей">
            {roofStates.map((state, index) => (
              <button
                class:list={['pergola-roof__tab', { 'is-active': index === 0 }]}
                type="button"
                role="tab"
                aria-selected={index === 0 ? 'true' : 'false'}
                data-roof-tab={state.id}
                data-angle={state.angle}
              >
                <span class="figure pergola-roof__tab-number">{state.number}</span>
                <span>
                  <strong>{state.title}</strong>
                  <small>{state.text}</small>
                </span>
              </button>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="pergola-section pergola-sizes" aria-labelledby="pergola-sizes-title">
      <div class="shell">
        <div class="pergola-head rise">
          <p class="eyebrow eyebrow--edge">Габариты</p>
          <h2 class="title" id="pergola-sizes-title">Стандартные модули и индивидуальный проект</h2>
          <p class="lead">
            Модуль можно привязать к фасаду, террасе или коммерческой площадке. Размер и
            количество секций уточняются после замера.
          </p>
        </div>

        <div class="pergola-sizes__grid">
          {sizes.map((item) => (
            <article class="pergola-size rise">
              <div class="pergola-size__media">
                <img
                  src={item.image}
                  alt={`Пергола Raluma размером ${item.size}`}
                  width="1000"
                  height="760"
                  loading="lazy"
                  decoding="async"
                  referrerpolicy="no-referrer-when-downgrade"
                />
              </div>
              <div class="pergola-size__body">
                <strong class="figure">{item.size}</strong>
                <span>{item.height}</span>
              </div>
            </article>
          ))}

          <article class="pergola-size pergola-size--custom rise">
            <p class="eyebrow">Под ваш объект</p>
            <h3>Индивидуальный размер</h3>
            <p>
              Рассчитаем конфигурацию по фото, плану или чертежу. Прикрепить файл можно в
              форме ниже.
            </p>
            <a
              class="btn btn--outline"
              href="#lead-form"
              data-pergola-goal="pergolas_sizes_calculate"
            >
              Рассчитать проект
            </a>
          </article>
        </div>
      </div>
    </section>

    <section class="pergola-section pergola-glazing seams seams--deep" aria-labelledby="pergola-glazing-title">
      <div class="shell pergola-glazing__layout">
        <div class="pergola-glazing__intro rise">
          <p class="eyebrow pergola-glazing__eyebrow">Пергола + остекление</p>
          <h2 id="pergola-glazing-title">Из открытой террасы — в защищённое пространство</h2>
          <p>
            Во все перголы можно интегрировать одну из трёх безрамных систем Raluma.
            Подбираем механику под сценарий открывания, высоту проёма и сезонность.
          </p>
          <a class="btn btn--on-deep" href="/#systems">Посмотреть системы остекления</a>
        </div>

        <div class="pergola-glazing__systems">
          <article class="pergola-glazing__system rise">
            <span class="figure">01</span>
            <h3>Слайд</h3>
            <p>Панели сдвигаются параллельно. Простое ежедневное открывание и минимум места.</p>
          </article>
          <article class="pergola-glazing__system rise">
            <span class="figure">02</span>
            <h3>Книжка</h3>
            <p>Панели собираются в парковочную зону и позволяют почти полностью открыть проём.</p>
          </article>
          <article class="pergola-glazing__system rise">
            <span class="figure">03</span>
            <h3>Лифт</h3>
            <p>Вертикальное открывание для барных стоек, ресторанов и компактных фасадов.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="pergola-section pergola-benefits seams" aria-labelledby="pergola-benefits-title">
      <div class="shell">
        <div class="pergola-head rise">
          <p class="eyebrow eyebrow--edge">Что меняется после монтажа</p>
          <h2 class="title" id="pergola-benefits-title">Терраса работает дольше и выглядит частью дома</h2>
        </div>

        <div class="pergola-benefits__grid">
          <article class="pergola-benefit rise">
            <span class="figure">свет</span>
            <h3>Управляемое естественное освещение</h3>
            <p>Открывайте ламели для солнца или создавайте ровную тень без тяжёлого навеса.</p>
          </article>
          <article class="pergola-benefit rise">
            <span class="figure">воздух</span>
            <h3>Режим естественной вентиляции</h3>
            <p>Тёплый воздух выходит через крышу, сохраняя комфортный микроклимат.</p>
          </article>
          <article class="pergola-benefit rise">
            <span class="figure">вода</span>
            <h3>Водоотвод спрятан в конструкции</h3>
            <p>Желоба и каналы внутри колонн не перегружают фасад видимыми трубами.</p>
          </article>
          <article class="pergola-benefit rise">
            <span class="figure">вид</span>
            <h3>Единая архитектура с домом</h3>
            <p>Цвет, размеры, примыкание и остекление проектируются как одна композиция.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="pergola-section pergola-options" aria-labelledby="pergola-options-title">
      <div class="shell">
        <div class="pergola-head rise">
          <p class="eyebrow eyebrow--edge">Материалы и опции</p>
          <h2 class="title" id="pergola-options-title">Не только белый или графит</h2>
          <p class="lead">
            Доступны цвета по каталогу RAL, матовые и фактурные покрытия, декор под дерево,
            варианты стекла, освещение и автоматизация.
          </p>
        </div>

        <div class="pergola-options__grid">
          <article class="pergola-option pergola-option--large rise">
            <img
              src={images.finish}
              alt="Примеры декоративных покрытий Raluma"
              width="1100"
              height="760"
              loading="lazy"
              decoding="async"
              referrerpolicy="no-referrer-when-downgrade"
            />
            <div>
              <p class="eyebrow">Цвет и фактура</p>
              <h3>Окрашивание по RAL и декор</h3>
              <p>Подбираем покрытие под фасад, окна, кровлю и существующие элементы участка.</p>
            </div>
          </article>

          <article class="pergola-option rise">
            <img
              src={images.glassSample}
              alt="Варианты стекла Raluma"
              width="900"
              height="760"
              loading="lazy"
              decoding="async"
              referrerpolicy="no-referrer-when-downgrade"
            />
            <div>
              <p class="eyebrow">Заполнение</p>
              <h3>Прозрачное, осветлённое или тонированное стекло</h3>
            </div>
          </article>

          <article class="pergola-option rise">
            <img
              src={images.decor}
              alt="Декоративные решения Raluma"
              width="900"
              height="760"
              loading="lazy"
              decoding="async"
              referrerpolicy="no-referrer-when-downgrade"
            />
            <div>
              <p class="eyebrow">Комфорт</p>
              <h3>Освещение, датчики погоды и обогрев</h3>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section class="pergola-section pergola-process seams seams--deep" aria-labelledby="pergola-process-title">
      <div class="shell">
        <div class="pergola-process__head rise">
          <p class="eyebrow">Как проходит работа</p>
          <h2 id="pergola-process-title">От фотографии участка до настроенной автоматики</h2>
        </div>

        <ol class="pergola-process__steps">
          <li class="rise"><span class="figure">01</span><strong>Заявка</strong><p>Получаем фото, план или описание задачи.</p></li>
          <li class="rise"><span class="figure">02</span><strong>Замер</strong><p>Проверяем основание, высоты и примыкания.</p></li>
          <li class="rise"><span class="figure">03</span><strong>Проект</strong><p>Выбираем тип крыши, размер, цвет и опции.</p></li>
          <li class="rise"><span class="figure">04</span><strong>Производство</strong><p>Изготавливаем согласованную конструкцию.</p></li>
          <li class="rise"><span class="figure">05</span><strong>Монтаж</strong><p>Собираем, герметизируем и настраиваем систему.</p></li>
        </ol>
      </div>
    </section>

    <section class="pergola-section pergola-faq seams" id="pergolas-faq" aria-labelledby="pergola-faq-title">
