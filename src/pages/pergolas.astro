  </main>

  <FooterSection />

  <script>
    const roofSection = document.querySelector('[data-roof-section]');
    if (roofSection) {
      const visual = roofSection.querySelector('[data-roof-visual]');
      const angle = roofSection.querySelector('[data-roof-angle]');
      const tabs = Array.from(roofSection.querySelectorAll('[data-roof-tab]'));

      tabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          const state = tab.getAttribute('data-roof-tab') || 'closed';
          tabs.forEach((candidate) => {
            const active = candidate === tab;
            candidate.classList.toggle('is-active', active);
            candidate.setAttribute('aria-selected', String(active));
          });
          visual?.setAttribute('data-roof-visual', state);
          if (angle) angle.textContent = tab.getAttribute('data-angle') || '';
          window.safeReachGoal?.('pergolas_roof_state_select');
        });
      });
    }

    document.querySelectorAll('[data-pergola-goal]').forEach((link) => {
      link.addEventListener('click', () => {
        const goal = link.getAttribute('data-pergola-goal');
        if (goal) window.safeReachGoal?.(goal);
      });
    });

    const successPanel = document.getElementById('lead-form-success');
    if (successPanel && typeof MutationObserver !== 'undefined') {
      let sent = false;
      const observer = new MutationObserver(() => {
        if (sent || successPanel.hidden) return;
        sent = true;
        window.safeReachGoal?.('pergolas_form_submit');
        observer.disconnect();
      });
      observer.observe(successPanel, { attributes: true, attributeFilter: ['hidden'] });
    }

    const form = document.getElementById('lead-form-element');
    form?.addEventListener('focusin', () => window.safeReachGoal?.('pergolas_form_start'), { once: true });
  </script>
</BaseLayout>

